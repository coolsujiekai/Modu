page,
.page {
  /* ===== 背景 — 和纸色系 ===== */
  --bg-primary: #F7F6F2;
  --bg-surface: #FCFCFA;
  --bg-surface-soft: #F2F1EB;
  --bg-surface-muted: #ECEAE4;
  --bg-surface-subtle: #ECEAE4;
  --bg-surface-subtle-2: #E5E3DC;
  --bg-surface-accent: rgba(168, 144, 122, 0.08);
  --bg-surface-tag: rgba(168, 144, 122, 0.09);
  --bg-divider: rgba(0, 0, 0, 0.04);

  /* ===== 文字 — 墨色层次（不是纯黑） ===== */
  --text-primary: #2C2B28;
  --text-secondary: #4A4945;
  --text-light: #8A8984;

  /* ===== 边框 ===== */
  --border-color: rgba(0, 0, 0, 0.06);
  --border-warm: var(--border-color);
  --border-soft: rgba(0, 0, 0, 0.03);
  --border-muted: rgba(0, 0, 0, 0.04);
  --border-overlay-soft: rgba(0, 0, 0, 0.04);
  --border-overlay-strong: rgba(0, 0, 0, 0.10);
  --border-overlay-stronger: rgba(0, 0, 0, 0.16);

  /* ===== 品牌色 — 旧书封面褪色的朱 ===== */
  --accent: #A8907A;
  --accent-hover: #9A8270;
  --accent-light: rgba(168, 144, 122, 0.10);

  /* ===== 按钮 ===== */
  --button-bg: var(--accent);
  --button-text: #FFFFFF;
  --button-bg-secondary: var(--bg-surface);
  --button-text-secondary: var(--accent);
  --btn-active-bg-primary: var(--accent-hover);
  --btn-active-bg-secondary: rgba(168, 144, 122, 0.14);
  --btn-letter-spacing: 0.05em;

  /* ===== 字体层级 ===== */
  --font-title: 40rpx;
  --font-body: 30rpx;
  --font-meta: 24rpx;
  --font-title-weight: 300;

  /* ===== 间距 — 呼吸的节奏 ===== */
  --space-1: 18rpx;
  --space-2: 32rpx;
  --space-3: 52rpx;
  --space-4: 80rpx;
  --page-padding-x: 44rpx;
  --page-padding-y: 36rpx;
  --card-padding: 32rpx;

  /* ===== 圆角 ===== */
  --radius-xs: 6rpx;
  --radius-sm: 10rpx;
  --radius-md: 14rpx;
  --radius-lg: 18rpx;
  --radius-xl: 24rpx;

  /* ===== 投影 — 自然光下纸张的层次，柔软、不抢眼 ===== */
  --tap-active-bg: rgba(0, 0, 0, 0.03);

  --shadow-xs: 0 1rpx 4rpx rgba(0, 0, 0, 0.03);
  --shadow-soft: 0 1rpx 0 rgba(0, 0, 0, 0.03), 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  --shadow-card: 0 1rpx 0 rgba(0, 0, 0, 0.03), 0 8rpx 36rpx rgba(0, 0, 0, 0.05);
  --shadow-modal: 0 1rpx 0 rgba(0, 0, 0, 0.03), 0 16rpx 56rpx rgba(0, 0, 0, 0.08);
  --shadow-book-cover: 0 1rpx 0 rgba(0, 0, 0, 0.03), 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  --shadow-floating: 0 1rpx 0 rgba(0, 0, 0, 0.03), 0 20rpx 60rpx rgba(0, 0, 0, 0.08);
  --shadow-inset-soft: inset 0 1rpx 0 rgba(255, 255, 255, 0.6);

  /* ===== 语义变量 ===== */
  --text-title: var(--text-primary);
  --text-warm-muted: var(--text-secondary);
  --text-accent: var(--accent);
  --text-danger: #C87070;
  --text-success: #6B8E6B;
  --text-dim: var(--text-light);
  --text-neutral-700: #6A6965;
  --text-neutral-500: #A6A5A0;
  --text-neutral-800: #2C2B28;
  --text-brand: var(--accent);
  --text-brand-soft: rgba(168, 144, 122, 0.55);
  --text-brand-info: rgba(168, 144, 122, 0.65);
  --text-overlay: rgba(255, 255, 255, 0.92);
  --text-brand-muted: rgba(0, 0, 0, 0.45);
  --overlay-white-20: rgba(255, 255, 255, 0.2);
  --overlay-white-30: rgba(255, 255, 255, 0.3);
  --overlay-mask: rgba(0, 0, 0, 0.24);
  --overlay-mask-strong: rgba(0, 0, 0, 0.36);
  --overlay-mask-stronger: rgba(0, 0, 0, 0.48);
  --overlay-screen: rgba(0, 0, 0, 0.68);
  --overlay-line: rgba(0, 0, 0, 0.06);
  --overlay-brand-faint: rgba(168, 144, 122, 0.04);

  /* ===== 边框色 ===== */
  --border-accent: rgba(168, 144, 122, 0.18);
  --border-soft-2: rgba(0, 0, 0, 0.08);
  --border-light: #D8D6D0;
  --border-brand: var(--accent);
  --border-gold-soft: rgba(168, 144, 122, 0.22);
  --border-gold-light: rgba(168, 144, 122, 0.10);
  --border-dark-soft: rgba(0, 0, 0, 0.12);
  --border-dark-faint: rgba(0, 0, 0, 0.06);

  /* ===== 深色模式 ===== */
  --bg-dark-page: var(--bg-primary);
  --bg-dark-surface: var(--bg-surface);
  --bg-dark-surface-2: var(--bg-surface-muted);
  --bg-dark-surface-3: var(--bg-surface-subtle-2);
  --border-dark: var(--border-color);
  --text-dark-primary: var(--text-primary);
  --text-dark-secondary: var(--text-secondary);
  --text-dark-highlight: var(--text-primary);
  --text-dark-stats: var(--text-light);

  /* ===== 封面配色 — 纸色系柔和渐变 ===== */
  --book-tone-1: linear-gradient(155deg, #EDECF2 0%, #E3E2ED 100%);
  --book-tone-2: linear-gradient(155deg, #EDEEE8 0%, #E5E7DF 100%);
  --book-tone-3: linear-gradient(155deg, #F0E9E5 0%, #EAE1DC 100%);
  --book-tone-4: linear-gradient(155deg, #EAF0E8 0%, #DFE8DD 100%);
  --book-tone-5: linear-gradient(155deg, #ECEAF0 0%, #E3DFE9 100%);
  --book-tone-shine-1: linear-gradient(180deg, rgba(255, 255, 255, 0.64) 0%, transparent 34%);
  --book-tone-shine-2: linear-gradient(180deg, rgba(255, 255, 255, 0.68) 0%, transparent 34%);
  --book-tone-shine-3: linear-gradient(180deg, rgba(255, 255, 255, 0.60) 0%, transparent 32%);
  --book-tone-shine-4: linear-gradient(180deg, rgba(255, 255, 255, 0.62) 0%, transparent 32%);
  --book-tone-shine-5: linear-gradient(180deg, rgba(255, 255, 255, 0.66) 0%, transparent 32%);
  --hero-bg-gradient: linear-gradient(180deg, #FCFCFA 0%, #F7F6F2 100%);
  --cover-shadow-gradient: linear-gradient(180deg, rgba(0, 0, 0, 0.05) 0%, transparent 42%);
  --cover-spine-gradient: linear-gradient(90deg, rgba(0, 0, 0, 0.12) 0%, rgba(0, 0, 0, 0.05) 45%, rgba(0, 0, 0, 0.01) 100%);
  --cover-spine-shadow: 6rpx 0 10rpx rgba(0, 0, 0, 0.05);
  --cover-page-edge-gradient: linear-gradient(180deg, rgba(255, 255, 255, 0.50) 0%, rgba(245, 245, 240, 0.34) 50%, rgba(220, 220, 215, 0.38) 100%);
  --cover-page-edge-shadow: 0 12rpx 20rpx rgba(0, 0, 0, 0.06);
  --cover-shine-gradient: linear-gradient(165deg, rgba(255, 255, 255, 0.44) 0%, rgba(255, 255, 255, 0) 58%);
  --cover-title-color: #2C2B28;
  --cover-author-color: #8A8984;
  --cover-title-shadow: 0 2rpx 8rpx rgba(255, 255, 255, 0.10);
}

/* ============================================
   暗色模式切换 — 通过 .dark-theme 触发
   覆盖所有亮色变量为暗色值
   ============================================ */
.dark-theme {
  --bg-primary: #1E1D1B;
  --bg-surface: #2B2A27;
  --bg-surface-soft: #353430;
  --bg-surface-muted: #3B3A36;
  --bg-surface-subtle: #3B3A36;
  --bg-surface-subtle-2: #454440;
  --bg-surface-accent: rgba(168, 144, 122, 0.10);
  --bg-surface-tag: rgba(168, 144, 122, 0.11);
  --bg-divider: rgba(255, 255, 255, 0.06);

  --text-primary: #F0EFEB;
  --text-secondary: #C8C6C0;
  --text-light: #9A9892;

  --border-color: rgba(255, 255, 255, 0.08);
  --border-soft: rgba(255, 255, 255, 0.04);
  --border-muted: rgba(255, 255, 255, 0.05);
  --border-overlay-soft: rgba(255, 255, 255, 0.04);
  --border-overlay-strong: rgba(255, 255, 255, 0.10);
  --border-overlay-stronger: rgba(255, 255, 255, 0.16);

  --accent: #B8A898;
  --accent-hover: #A89888;
  --accent-light: rgba(184, 168, 152, 0.12);

  --shadow-xs: 0 1rpx 4rpx rgba(0, 0, 0, 0.12);
  --shadow-soft: 0 1rpx 0 rgba(255, 255, 255, 0.02), 0 4rpx 20rpx rgba(0, 0, 0, 0.14);
  --shadow-card: 0 1rpx 0 rgba(255, 255, 255, 0.02), 0 8rpx 36rpx rgba(0, 0, 0, 0.18);
  --shadow-modal: 0 1rpx 0 rgba(255, 255, 255, 0.02), 0 16rpx 56rpx rgba(0, 0, 0, 0.22);
  --shadow-book-cover: 0 1rpx 0 rgba(255, 255, 255, 0.02), 0 4rpx 16rpx rgba(0, 0, 0, 0.16);
  --shadow-floating: 0 1rpx 0 rgba(255, 255, 255, 0.02), 0 20rpx 60rpx rgba(0, 0, 0, 0.20);
  --shadow-inset-soft: inset 0 1rpx 0 rgba(255, 255, 255, 0.06);

  --tap-active-bg: rgba(255, 255, 255, 0.04);

  --text-danger: #D4A0A0;
  --text-success: #90AE90;

  --text-neutral-700: #B0AEA8;
  --text-neutral-500: #8A8882;
  --text-brand-soft: rgba(184, 168, 152, 0.60);
  --text-brand-info: rgba(184, 168, 152, 0.70);
  --text-overlay: rgba(0, 0, 0, 0.92);
  --text-brand-muted: rgba(255, 255, 255, 0.35);

  --border-accent: rgba(184, 168, 152, 0.22);
  --border-soft-2: rgba(255, 255, 255, 0.10);
  --border-light: #4A4A46;
  --border-gold-soft: rgba(184, 168, 152, 0.24);
  --border-gold-light: rgba(184, 168, 152, 0.12);
  --border-dark-soft: rgba(255, 255, 255, 0.14);
  --border-dark-faint: rgba(255, 255, 255, 0.08);

  --overlay-white-20: rgba(0, 0, 0, 0.2);
  --overlay-white-30: rgba(0, 0, 0, 0.3);
  --overlay-mask: rgba(0, 0, 0, 0.40);
  --overlay-mask-strong: rgba(0, 0, 0, 0.52);
  --overlay-mask-stronger: rgba(0, 0, 0, 0.64);
  --overlay-screen: rgba(0, 0, 0, 0.80);
  --overlay-line: rgba(255, 255, 255, 0.06);
  --overlay-brand-faint: rgba(184, 168, 152, 0.06);

  --hero-bg-gradient: linear-gradient(180deg, #2B2A27 0%, #1E1D1B 100%);

  --cover-title-color: #F0EFEB;
  --cover-author-color: #9A9892;
  --cover-title-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.16);

  --book-tone-1: linear-gradient(155deg, #3A3845 0%, #2E2C3A 100%);
  --book-tone-2: linear-gradient(155deg, #3A3E38 0%, #2E322C 100%);
  --book-tone-3: linear-gradient(155deg, #3E3530 0%, #322B26 100%);
  --book-tone-4: linear-gradient(155deg, #353E33 0%, #2A3228 100%);
  --book-tone-5: linear-gradient(155deg, #38353E 0%, #2C2935 100%);
  --book-tone-shine-1: linear-gradient(180deg, rgba(255, 255, 255, 0.08) 0%, transparent 34%);
  --book-tone-shine-2: linear-gradient(180deg, rgba(255, 255, 255, 0.08) 0%, transparent 34%);
  --book-tone-shine-3: linear-gradient(180deg, rgba(255, 255, 255, 0.06) 0%, transparent 32%);
  --book-tone-shine-4: linear-gradient(180deg, rgba(255, 255, 255, 0.08) 0%, transparent 32%);
  --book-tone-shine-5: linear-gradient(180deg, rgba(255, 255, 255, 0.08) 0%, transparent 32%);

  --bg-dark-page: #1E1D1B;
  --bg-dark-surface: #2B2A27;
  --bg-dark-surface-2: #3B3A36;
  --bg-dark-surface-3: #4B4A46;
  --border-dark: rgba(255, 255, 255, 0.10);
  --text-dark-primary: #F0EFEB;
  --text-dark-secondary: #C8C6C0;
  --text-dark-highlight: #FAFAF8;
  --text-dark-stats: #BEBDB8;
}
