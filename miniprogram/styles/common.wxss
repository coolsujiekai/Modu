.page {
  background: var(--bg-primary) !important;
  color: var(--text-primary);
}

.page {
  min-height: 100vh;
  padding: var(--page-padding-y) var(--page-padding-x) calc(var(--page-padding-y) + env(safe-area-inset-bottom)) !important;
  box-sizing: border-box;
}

.page view,
.page text,
.page input,
.page textarea,
.page button {
  font-size: var(--font-body);
  color: var(--text-primary);
  box-sizing: border-box;
}

/* ===== 卡片基础 ===== */
.card,
.hero,
.section-card,
.mini-card,
.form-panel,
.header-panel,
.suggest-card,
.modal,
.modal-content,
.list-card,
.add-card,
.export-card,
.generating-box,
.weui-panel,
.weui-cells {
  background: var(--bg-surface) !important;
  border: none !important;
  border-radius: var(--radius-lg) !important;
  box-shadow: var(--shadow-soft) !important;
  padding: var(--card-padding) !important;
}

.hero,
.header-panel,
.book-panel {
  background: var(--hero-bg-gradient) !important;
  box-shadow: var(--shadow-card) !important;
}

.export-card {
  background: var(--bg-surface-soft) !important;
}

/* ===== 列表项无投影 ===== */
.quote-item,
.result-item,
.book-cover-large,
.add-cover,
.btn-cancel,
.btn-confirm,
.editor,
.note-input,
.modal-input,
.seg,
.seg-item.active,
.seg-item,
.add-plus,
.quote-check,
.spinner,
.preview-btn,
.template-pill,
.section-count,
.author-pill,
.export-icon {
  border-radius: var(--radius-md) !important;
  box-shadow: none !important;
}

.card,
.hero,
.section-card,
.mini-card,
.list-card,
.add-card,
.export-card,
.modal-content,
.modal,
.header-panel,
.suggest-card,
.weui-panel,
.weui-cells {
  margin-top: var(--space-2) !important;
  margin-bottom: var(--space-2) !important;
}

/* ===== 间距 ===== */
.page-head,
.hero-top,
.hero-sub,
.section-hd,
.section-card__hd,
.section-card__bd,
.modal-header,
.modal-search,
.modal-body,
.book-info-section,
.control-section,
.quote-section,
.modal-actions,
.actions,
.row-actions,
.section-actions,
.section-actions--right {
  padding-top: var(--space-2) !important;
  padding-bottom: var(--space-2) !important;
}

.hero-sub,
.page-sub,
.muted,
.hint,
.section-sub,
.result-sub,
.book-meta,
.list-author {
  margin-top: var(--space-1) !important;
  margin-bottom: 0 !important;
}

/* ===== WeUI 基础重置 ===== */
.weui-panel,
.weui-cells {
  overflow: hidden;
}

.weui-panel {
  padding: 0 !important;
}

.weui-panel__hd,
.weui-panel__bd,
.weui-panel__ft {
  padding-left: var(--card-padding) !important;
  padding-right: var(--card-padding) !important;
}

.weui-panel__hd {
  padding-top: calc(var(--card-padding) - 2rpx) !important;
  padding-bottom: 14rpx !important;
  color: var(--text-light) !important;
  font-size: var(--font-meta) !important;
}

.weui-panel__bd,
.weui-panel__ft {
  padding-top: 0 !important;
  padding-bottom: var(--card-padding) !important;
}

.weui-cells {
  margin-top: var(--space-2) !important;
  padding: 0 !important;
}

.weui-cells:before,
.weui-cells:after {
  display: none !important;
}

.weui-cell {
  padding: 30rpx var(--card-padding) !important;
  font-size: var(--font-body) !important;
}

.weui-cell:before {
  display: none !important;
}

.weui-cell__bd,
.weui-cell__ft,
.weui-media-box__desc,
.weui-media-box__title {
  color: var(--text-primary) !important;
}

.weui-cell__ft {
  color: var(--text-light) !important;
}

/* ===== 文字层级 ===== */
.h1,
.h2,
.hero-title,
.page-title,
.section-title,
.title,
.modal-title,
.result-title,
.empty-title,
.list-title,
.header-title,
.export-title,
.cover-title,
.name {
  font-size: var(--font-title) !important;
  font-weight: var(--font-title-weight) !important;
  color: var(--text-primary) !important;
  letter-spacing: -0.02em;
}

.p,
.latest-text,
.quote-text,
.book-info-input,
.modal-input,
.result-sub,
.cover-author,
.list-author,
.section-label,
.book-info-label,
.control-title,
.add-text {
  font-size: var(--font-body) !important;
  color: var(--text-primary) !important;
}

.muted,
.hero-sub,
.page-sub,
.book-meta,
.modal-sub,
.placeholder,
.section-sub,
.section-count,
.book-info-label,
.control-title,
.hint {
  font-size: var(--font-meta) !important;
  color: var(--text-light) !important;
}

/* ===== 按钮 ===== */
.btn-primary,
.weui-btn_primary,
.btn-confirm,
.btn-share-card {
  min-height: 88rpx !important;
  line-height: 88rpx !important;
  background: var(--button-bg) !important;
  color: var(--button-text) !important;
  border-radius: var(--radius-md) !important;
  border: none !important;
  box-shadow: var(--shadow-soft) !important;
  font-weight: 600;
  letter-spacing: var(--btn-letter-spacing);
}

.btn-secondary,
.weui-btn_default {
  min-height: 88rpx !important;
  line-height: 88rpx !important;
  background: var(--bg-surface) !important;
  color: var(--button-text-secondary) !important;
  border-radius: var(--radius-md) !important;
  border: 1.5rpx solid var(--border-color) !important;
  box-shadow: none !important;
  font-weight: 600;
  letter-spacing: var(--btn-letter-spacing);
}

.weui-btn_mini {
  min-height: 60rpx !important;
  line-height: 60rpx !important;
  border-radius: 999rpx !important;
}

.weui-btn_primary:not(.weui-btn_disabled):active,
.btn-primary:active,
.btn-confirm:active,
.btn-share-card:active {
  opacity: 1 !important;
  background: var(--btn-active-bg-primary) !important;
  transform: scale(0.98);
}

.weui-btn_default:not(.weui-btn_disabled):active,
.btn-secondary:active {
  opacity: 1 !important;
  background: var(--btn-active-bg-secondary) !important;
  transform: scale(0.98);
}

.tap-active {
  background: var(--tap-active-bg) !important;
  opacity: 1 !important;
}

/* ===== 滑动删除 ===== */
.slide-row {
  overflow: hidden;
}

.slide-btn-delete {
  background: var(--text-danger);
  color: var(--button-text);
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 0 32rpx;
  font-size: 30rpx;
  font-weight: 700;
}
