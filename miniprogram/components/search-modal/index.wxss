@import "/styles/theme.wxss";
@import "/styles/common.wxss";

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: var(--overlay-mask);
  z-index: 998;
}

.modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 72vh;
  background: var(--bg-surface);
  border-radius: var(--radius-md);
  z-index: 999;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 16rpx 16rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.modal-close {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 40rpx;
  color: var(--text-secondary);
}

.seg {
  margin: 0 16rpx 16rpx;
  background: var(--bg-surface-subtle);
  border-radius: var(--radius-md);
  padding: 16rpx;
  display: flex;
  gap: 16rpx;
}

.seg-item {
  flex: 1 1 0;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-neutral-700);
  border-radius: var(--radius-md);
}

.seg-item.active {
  background: var(--bg-surface);
  color: var(--text-primary);
  font-weight: 700;
}

.modal-search {
  display: flex;
  align-items: center;
  padding: 16rpx 16rpx 16rpx;
}

.modal-input {
  flex: 1 1 auto;
  height: 76rpx;
  background: var(--bg-surface-subtle);
  border-radius: var(--radius-md);
  padding: 0 16rpx;
  font-size: 32rpx;
  color: var(--text-primary);
}

.placeholder {
  color: var(--text-neutral-500);
}

.modal-clear {
  flex: 0 0 auto;
  margin-left: 16rpx;
  font-size: 24rpx;
  color: var(--text-success);
  padding: 16rpx 16rpx;
}

.modal-body {
  flex: 1 1 auto;
  padding: 0 16rpx 16rpx;
  overflow: hidden;
}

.loading {
  padding: 16rpx 16rpx;
}

.result-list {
  height: 100%;
}

.result-item {
  padding: 16rpx 16rpx;
  border-radius: var(--radius-md);
}

.result-item:active {
  background: var(--bg-surface-subtle-2);
}

.result-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.result-sub {
  margin-top: 16rpx;
  font-size: 24rpx;
}

.empty {
  padding: 32rpx 16rpx;
  text-align: center;
}

.empty-icon {
  font-size: 40rpx;
  line-height: 1;
}

.empty-title {
  margin-top: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.empty-desc {
  margin-top: 16rpx;
}

.muted {
  color: var(--text-dim);
  font-size: 24rpx;
}
