@import "/styles/theme.wxss";
@import "/styles/common.wxss";

.page.intro-page {
  min-height: 100vh;
  padding-top: 72rpx !important;
  padding-bottom: 72rpx !important;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.intro-hero {
  padding: 0 8rpx 28rpx;
}

.intro-title {
  font-size: 56rpx;
  font-weight: 900;
  color: var(--text-title);
  letter-spacing: 0.01em;
  line-height: 1.1;
}

.intro-sub {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.6;
}

.intro-card {
  margin-top: 12rpx !important;
  padding: 28rpx 24rpx !important;
}

.h2 {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-title);
  line-height: 1.2;
}

.p {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.55;
}

.muted {
  color: var(--text-secondary);
}

.mt {
  margin-top: 24rpx;
}

.row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx 14rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid var(--border-faint);
}

.row-label {
  flex: none;
  width: 96rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-title);
}

.row-input {
  flex: 1 1 auto;
  min-width: 0;
  font-size: 28rpx;
  color: var(--text-title);
}

.avatar-grid {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.avatar-group {
  margin-top: 12rpx;
}

.avatar-group-title {
  font-size: 22rpx;
}

.avatar-item {
  width: calc((100% - 28rpx) / 3);
  padding: 14rpx 10rpx;
  border-radius: 18rpx;
  border: 1rpx solid var(--border-faint);
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--bg-surface);
  position: relative;
  transition: transform 120ms ease;
}

.avatar-item.active {
  border-color: var(--text-accent);
  border-width: 2rpx;
  box-shadow: 0 12rpx 28rpx rgba(192, 125, 107, 0.18);
  transform: scale(1.02);
}

.check-badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 999rpx;
  background: var(--text-accent);
  color: #fff;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 34rpx;
  text-align: center;
  box-shadow: 0 8rpx 18rpx rgba(192, 125, 107, 0.25);
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 999rpx;
  background: var(--bg-surface-muted);
}

.label {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.upload-row {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 10rpx 10rpx;
  border-radius: 18rpx;
}

.upload-row.active {
  border: 2rpx solid var(--text-accent);
  background: rgba(255, 255, 255, 0.6);
}

.upload-btn.weui-btn {
  flex: 1 1 auto;
  margin: 0;
}

.upload-preview {
  flex: none;
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: var(--bg-surface-muted);
  border: 1rpx solid var(--border-faint);
}

.seg {
  margin-top: 12rpx;
  background: var(--bg-surface-muted);
  border-radius: 999rpx;
  padding: 8rpx;
  display: flex;
  gap: 16rpx;
}

.seg-3 .seg-item {
  flex: 1 1 0;
}

.seg-item {
  flex: 1 1 0;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-secondary);
  border-radius: 999rpx;
}

.seg-item.active {
  background: var(--bg-surface);
  color: var(--text-primary);
  font-weight: 700;
  box-shadow: var(--shadow-soft);
}

.actions {
  margin-top: 22rpx;
  display: flex;
  gap: 14rpx;
}

.btn.weui-btn {
  flex: 1;
  margin: 0;
}

.btn-secondary.weui-btn {
  margin-top: 16rpx;
}

.steps {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.step {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.dot {
  flex: none;
  width: 18rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: var(--text-accent);
  margin-top: 10rpx;
}

.step-title {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-title);
  line-height: 1.2;
}

.step-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.55;
}

