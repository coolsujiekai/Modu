<view class="page {{isDark ? 'dark-theme' : ''}}">
  <block wx:if="{{loading}}">
    <view class="weui-msg">
      <view class="weui-msg__icon-area"><text style="font-size: 80rpx;">⏳</text></view>
      <view class="weui-msg__title">加载中</view>
    </view>
  </block>

  <block wx:elif="{{!book}}">
    <view class="weui-msg">
      <view class="weui-msg__icon-area"><text style="font-size: 80rpx;">📚</text></view>
      <view class="weui-msg__title">没找到这本书</view>
      <view class="weui-msg__desc">可能已被删除或网络异常</view>
    </view>
  </block>

  <block wx:else>
  
    <view class="weui-panel book-panel">
      <view class="weui-panel__hd book-hd">
        <view class="book-title">{{book.bookName}}</view>
        <view class="book-actions">
          <view class="meta-pill" bindtap="editBookInfo">修改</view>
        </view>
      </view>
      <view class="weui-panel__bd">
        <view class="weui-media-box weui-media-box_text">
          <view class="weui-media-box__desc meta-row">
            <text class="meta-label">状态：</text>
            <text class="meta-pill">{{book.status === 'finished' ? '已读' : '在读'}}</text>
          </view>
          <view class="weui-media-box__desc meta-row" wx:if="{{book.authorName}}">
            <text class="meta-label">作者：</text>
            <text class="meta-link" bindtap="openAuthor" data-id="{{book.authorId}}" data-name="{{book.authorName}}">{{book.authorName}}</text>
          </view>
          <view class="weui-media-box__desc muted" style="margin-top: 10rpx;" wx:if="{{startedText}}">
            <text>开始：{{startedText}}</text>
          </view>
          <view class="weui-media-box__desc muted" wx:if="{{book.status === 'finished' && finishedText}}">
            <text>读完：{{finishedText}}</text>
          </view>
          <view class="weui-media-box__desc muted">
            灵感 {{thoughtCount}} 条 · 金句 {{quoteCount}} 条
          </view>
        </view>
      </view>

      <view wx:if="{{book.status === 'finished' && quoteCount > 0}}" class="share-entry" hover-class="share-entry--active" bindtap="generateShareCard">
        <view class="share-entry__icon">✦</view>
        <view class="share-entry__main">
          <view class="share-entry__title">生成分享图片</view>
          <view class="share-entry__desc">加深阅读记忆</view>
        </view>
        <view class="share-entry__arrow">›</view>
      </view>
    </view>

    <view wx:if="{{book.status === 'finished'}}" class="ai-card">
      <view class="ai-card__hd">
        <view class="ai-card__title">AI 总结</view>
        <view class="ai-card__actions">
          <button
            class="weui-btn weui-btn_mini weui-btn_default ai-btn"
            bindtap="toggleAiReflectionEditMode"
            disabled="{{!aiReflection}}"
          >{{aiReflectionEditMode ? '完成' : '编辑'}}</button>
          <button
            class="weui-btn weui-btn_mini weui-btn_default ai-btn"
            bindtap="copyReflection"
            disabled="{{!aiReflection}}"
          >复制</button>
          <button
            class="weui-btn weui-btn_mini weui-btn_primary ai-btn"
            bindtap="onGenerateReflection"
            loading="{{aiReflectionLoading}}"
          >{{aiReflection ? '重新生成' : '生成'}}<text wx:if="{{aiQuotaRemaining > 0}}">({{aiQuotaRemaining}})</text></button>
        </view>
      </view>
      <view class="ai-card__bd">
        <textarea
          wx:if="{{aiReflectionEditMode && aiReflection}}"
          class="ai-textarea"
          value="{{aiReflectionDraft}}"
          maxlength="600"
          auto-height
          bindinput="onReflectionDraftInput"
        />
        <view wx:elif="{{aiReflection}}" class="ai-card__text">{{aiReflection}}</view>
        <view wx:elif="{{aiReflectionLoading}}" class="muted">在把你的记录揉成一段话…</view>
        <view wx:elif="{{aiReflectionError}}" class="muted">生成失败：{{aiReflectionError}}</view>
        <view wx:else class="muted">先回答几道小问题，生成一段 500 字以内、适合转发的读后感。</view>

        <view wx:if="{{aiReflectionEditMode && aiReflection}}" class="ai-bottom-actions">
          <button
            class="weui-btn weui-btn_default weui-btn_mini ai-save-btn"
            bindtap="resetAiReflectionDraft"
          >还原</button>
          <button
            class="weui-btn weui-btn_default weui-btn_mini ai-save-btn"
            bindtap="saveReflectionAsThought"
            loading="{{aiReflectionSaving}}"
            disabled="{{aiReflectionSaving}}"
          >保存为心得</button>
        </view>
      </view>
    </view>

    <!-- AI 读后感问答引导面板 -->
    <view wx:if="{{reflectionWizardVisible}}" class="modal-mask" bindtap="closeReflectionWizard"></view>
    <view wx:if="{{reflectionWizardVisible}}" class="wizard-panel" catchtap="noop">
      <view class="wizard-hd">
        <view class="wizard-title">写一段更像你的读后感</view>
        <view class="wizard-close" bindtap="closeReflectionWizard">×</view>
      </view>

      <scroll-view class="wizard-body" scroll-y>
        <view class="wizard-section">
          <view class="wizard-label">风格（可选）</view>
          <view class="wizard-style-row">
            <view class="pill {{reflectionStyle==='A'?'pill-active':''}}" bindtap="onPickReflectionStyle" data-style="A">真诚</view>
            <view class="pill {{reflectionStyle==='B'?'pill-active':''}}" bindtap="onPickReflectionStyle" data-style="B">犀利</view>
            <view class="pill {{reflectionStyle==='C'?'pill-active':''}}" bindtap="onPickReflectionStyle" data-style="C">治愈</view>
            <view class="pill {{reflectionStyle==='D'?'pill-active':''}}" bindtap="onPickReflectionStyle" data-style="D">干货</view>
            <view class="pill {{reflectionStyle==='E'?'pill-active':''}}" bindtap="onPickReflectionStyle" data-style="E">口语</view>
          </view>
        </view>

        <view class="wizard-section">
          <view class="wizard-label">内容素材（必选）</view>
          <view class="wizard-sub muted">选 1 条“结论” + 勾选 1–3 条金句，剩下交给 AI 组织成 500 字以内。</view>

          <view class="mini-block">
            <view class="mini-title">一句话结论（选 1 条）</view>
            <view class="seg-mini">
              <view class="seg-mini-item {{reflectionConclusionMode==='pick'?'active':''}}" bindtap="setConclusionMode" data-mode="pick">从心得选</view>
              <view class="seg-mini-item {{reflectionConclusionMode==='custom'?'active':''}}" bindtap="setConclusionMode" data-mode="custom">自己写</view>
            </view>

            <view wx:if="{{reflectionConclusionMode==='pick'}}">
              <view wx:if="{{wizardThoughtOptions.length===0}}" class="muted">还没有心得可选，先写 1 条心得或切换到“自己写”。</view>
              <view wx:else class="pick-list">
                <view
                  wx:for="{{wizardThoughtOptions}}"
                  wx:for-item="t"
                  wx:key="timestamp"
                  class="pick-item"
                  bindtap="pickConclusionOption"
                  data-idx="{{index}}"
                >
                  <view class="pick-radio {{reflectionConclusionPickIdx===index ? 'pick-radio--on' : ''}}">
                    <text>{{reflectionConclusionPickIdx===index ? '●' : '○'}}</text>
                  </view>
                  <view class="pick-text">{{t.text}}</view>
                </view>
              </view>
            </view>
            <view wx:else>
              <textarea class="wizard-input" maxlength="120" placeholder="写一句话结论（20–60 字更好）" data-key="conclusionCustom" bindinput="onReflectionInput" value="{{reflectionConclusionCustom}}" />
            </view>
          </view>

          <view class="mini-block">
            <view class="mini-title">金句（选 1–3 条）</view>
            <view wx:if="{{quoteNotes.length===0}}" class="muted">这本书还没有金句，先收 1 条再来。</view>
            <view wx:else class="quote-pick-list">
              <view
                wx:for="{{quoteNotes}}"
                wx:for-item="q"
                wx:key="timestamp"
                class="quote-pick-item"
                bindtap="toggleReflectionQuote"
                data-idx="{{index}}"
              >
                <view class="quote-check {{reflectionSelectedQuoteMap[index] ? 'quote-check--on' : ''}}">
                  <text class="quote-check__mark">{{reflectionSelectedQuoteMap[index] ? '✓' : ''}}</text>
                </view>
                <view class="quote-pick-text">{{q.text}}</view>
              </view>
            </view>
          </view>
        </view>

        <view class="wizard-section">
          <view class="wizard-more" bindtap="toggleReflectionMore">
            <text class="wizard-more__text">{{reflectionMoreVisible ? '收起补充' : '补充一点个性（可选）'}}</text>
            <text class="wizard-more__arrow">{{reflectionMoreVisible ? '˄' : '˅'}}</text>
          </view>

          <view wx:if="{{reflectionMoreVisible}}" class="more-box">
            <view class="quick-row">
              <view class="quick-label">触动点</view>
              <view class="quick-pills">
                <view class="pill" bindtap="applyQuickFill" data-key="touch" data-text="最戳我的是它把“努力”拆成了可执行的动作。">给我动作</view>
                <view class="pill" bindtap="applyQuickFill" data-key="touch" data-text="读到这里我突然意识到：我一直在用错误的方式和自己较劲。">戳中自己</view>
                <view class="pill" bindtap="applyQuickFill" data-key="touch" data-text="它把我以为的“道理”，变成了可以落地的选择。">能落地</view>
              </view>
            </view>
            <textarea class="wizard-input" maxlength="160" placeholder="也可以自己补一句（选填）" data-key="touch" bindinput="onReflectionInput" value="{{reflectionTouch}}" />

            <view class="quick-row">
              <view class="quick-label">反对点</view>
              <view class="quick-pills">
                <view class="pill" bindtap="applyQuickFill" data-key="disagree" data-text="但我不同意它把问题说得太简单：现实里成本远比想象高。">现实成本</view>
                <view class="pill" bindtap="applyQuickFill" data-key="disagree" data-text="我更愿意把它当作参考，而不是标准答案。">当参考</view>
                <view class="pill" bindtap="applyQuickFill" data-key="disagree" data-text="它有点“站在理想里说话”，我需要更具体的边界条件。">要边界</view>
              </view>
            </view>
            <textarea class="wizard-input" maxlength="160" placeholder="也可以自己补一句（选填）" data-key="disagree" bindinput="onReflectionInput" value="{{reflectionDisagree}}" />

            <view class="quick-row">
              <view class="quick-label">真实场景</view>
              <view class="quick-pills">
                <view class="pill" bindtap="applyQuickFill" data-key="scene" data-text="它让我想起某次我明明很累却还在硬撑的晚上。">硬撑</view>
                <view class="pill" bindtap="applyQuickFill" data-key="scene" data-text="我把它对照到工作里：很多事不是做不到，是不敢先做一小步。">先一小步</view>
                <view class="pill" bindtap="applyQuickFill" data-key="scene" data-text="我在关系里也常这样：以为在沟通，其实在争输赢。">争输赢</view>
              </view>
            </view>
            <textarea class="wizard-input" maxlength="180" placeholder="也可以自己补一句（选填）" data-key="scene" bindinput="onReflectionInput" value="{{reflectionScene}}" />

            <view class="quick-row">
              <view class="quick-label">推荐/不推荐</view>
              <view class="quick-pills">
                <view class="pill" bindtap="applyQuickFill" data-key="recommend" data-text="推荐给正在焦虑但又想改变的人；不推荐给只想要速成答案的人。">焦虑&速成</view>
                <view class="pill" bindtap="applyQuickFill" data-key="recommend" data-text="推荐给反复内耗的人；不推荐给把所有问题都归咎外部的人。">内耗&甩锅</view>
                <view class="pill" bindtap="applyQuickFill" data-key="recommend" data-text="推荐给需要重启生活节奏的人；不推荐给只想听好话的人。">重启&好话</view>
              </view>
            </view>
            <textarea class="wizard-input" maxlength="180" placeholder="也可以自己补一句（选填）" data-key="recommend" bindinput="onReflectionInput" value="{{reflectionRecommend}}" />
          </view>
        </view>
      </scroll-view>

      <view class="wizard-actions wizard-actions--fixed">
        <button class="weui-btn weui-btn_primary wizard-btn" bindtap="submitReflectionWizard" loading="{{aiReflectionLoading}}">生成读后感</button>
      </view>
    </view>

    <view class="section-card">
      <view class="section-card__hd">
        <view class="section-title-row">
          <view class="section-title">阅读记忆库</view>
          <view class="section-title-actions">
            <button class="weui-btn weui-btn_mini weui-btn_primary quicknote-mini-btn" bindtap="openQuickNoteForBook">快速记录</button>
            <view class="section-link">共 {{notes.length}} 条</view>
          </view>
        </view>
      </view>
      <view class="section-card__bd">
        <block wx:if="{{timelineGroups.length === 0}}">
          <view class="muted">还没有记录，赶紧写一句吧</view>
        </block>
        <block wx:else>
          <block wx:for="{{timelineGroups}}" wx:key="key" wx:for-item="g">
            <view class="timeline-group">
              <view class="timeline-group__hd">
                <text class="timeline-group__title">{{g.title}}</text>
                <text class="timeline-group__count muted">{{g.count}} 条</text>
              </view>
              <view class="timeline-group__list">
                <view
                  wx:for="{{g.items}}"
                  wx:key="timestamp"
                  wx:for-item="n"
                >
                  <slideview buttons="{{n.slideButtons}}" bind:buttontap="onTimelineSlideButtonTap" data-ts="{{n.timestamp}}">
                    <view
                      class="timeline-item"
                      hover-class="tap-active"
                      hover-stay-time="70"
                      bindlongpress="onTimelineLongPress"
                      bindtap="onTimelineDoubleTapCopy"
                      data-ts="{{n.timestamp}}"
                      data-text="{{n.text}}"
                    >
                      <view class="timeline-item__bd">
                        <view class="corner-tag corner-tag--{{n.type}}">
                          <text class="corner-tag__text">{{n.type === 'quote' ? '摘' : '思'}}</text>
                        </view>
                        <view class="timeline-item__text">
                          <text>{{n.text}}</text>
                        </view>
                        <view class="timeline-item__meta">
                          <text class="timeline-item__time muted">{{n.shortTime}}</text>
                        </view>
                      </view>
                    </view>
                  </slideview>
                </view>
              </view>
            </view>
          </block>
        </block>
      </view>
    </view>

    <view class="soft-divider"></view>
    <view class="export-card">
      <view class="export-main">
        <view class="export-head">
          <view class="export-icon">↗</view>
          <view class="export-title">整理导出</view>
        </view>
        <view class="export-sub muted">{{exportHint}}</view>
      </view>
      <button class="weui-btn weui-btn_default weui-btn_mini export-btn {{!canExport ? 'export-btn--disabled' : ''}}" bindtap="copyAllForBook" disabled="{{!canExport}}">复制</button>
    </view>

    <view wx:if="{{book.status !== 'finished'}}" class="bottom-actions">
      <button class="weui-btn weui-btn_default bottom-actions__btn" bindtap="continueReadingLater">下次再读</button>
      <button class="weui-btn btn-finish bottom-actions__btn" bindtap="finishReading">我读完了</button>
    </view>
    <button wx:else class="weui-btn btn-finish-outline" style="margin-top: 18rpx;" bindtap="markUnfinished">恢复在读</button>
  </block>
</view>

