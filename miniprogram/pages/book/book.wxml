<view class="page">
  <block wx:if="{{loading}}">
    <view class="weui-msg">
      <view class="weui-msg__icon-area"><text style="font-size: 80rpx;">⏳</text></view>
      <view class="weui-msg__title">加载中</view>
    </view>
  </block>

  <block wx:elif="{{!book}}">
    <view class="weui-msg">
      <view class="weui-msg__icon-area"><text style="font-size: 80rpx;">📚</text></view>
      <view class="weui-msg__title">没找到这本书</view>
      <view class="weui-msg__desc">可能已被删除或网络异常</view>
    </view>
  </block>

  <block wx:else>
    <view class="weui-panel book-panel">
      <view class="weui-panel__hd book-hd">
        <view class="book-title">📚 {{book.bookName}}</view>
        <view class="book-edit" bindtap="editBookInfo">修改</view>
      </view>
      <view class="weui-panel__bd">
        <view class="weui-media-box weui-media-box_text">
          <view class="weui-media-box__desc">
            <text class="muted">状态：</text>
            <text>{{book.status === 'finished' ? '已读' : '在读'}}</text>
          </view>
          <view class="weui-media-box__desc" wx:if="{{book.authorName}}">
            <text class="muted">作者：</text>
            <text class="link" bindtap="openAuthor" data-id="{{book.authorId}}" data-name="{{book.authorName}}">{{book.authorName}}</text>
          </view>
          <view class="weui-media-box__desc muted" style="margin-top: 10rpx;">
            <text wx:if="{{startedText}}">开始读：{{startedText}}</text>
            <text wx:if="{{book.status === 'finished' && finishedText}}">　｜　读完：{{finishedText}}</text>
          </view>
          <view class="weui-media-box__desc muted">
            灵感 {{thoughtCount}} 条 · 金句 {{quoteCount}} 条
          </view>
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-card__hd">
        <view class="section-title-row">
          <view class="section-title">心得</view>
          <view class="section-link" bindtap="openNoteList" data-type="thought">查看全部({{thoughtCount}})</view>
        </view>
      </view>
      <view class="section-card__bd">
        <textarea class="note-input {{thoughtFocused ? 'note-input--focused' : 'note-input--compact'}}" placeholder="写下此刻的想法…" value="{{thoughtText}}" bindinput="onThoughtInput" bindfocus="onThoughtFocus" bindblur="onThoughtBlur" maxlength="2000" auto-height />
        <view class="section-actions section-actions--right" wx:if="{{canSaveThought}}">
          <button class="weui-btn weui-btn_primary weui-btn_mini mini-action-btn" data-type="thought" bindtap="addNote">保存</button>
        </view>
        <view class="saved-inline muted" wx:if="{{savedHintType === 'thought'}}">已保存到心得</view>
      </view>
    </view>

    <view class="weui-cells" style="margin-top: 0;">
      <block wx:if="{{!latestThought}}">
        <view class="weui-cell">
          <view class="weui-cell__bd muted">还没有心得</view>
        </view>
      </block>
      <block wx:else>
        <view class="weui-cell">
          <view class="weui-cell__bd">
            <view class="latest-text ellipsis-2">💭 {{latestThought.text}}</view>
            <view class="muted" style="margin-top: 10rpx;">{{latestThought.timeText}}</view>
            <view class="row-actions">
              <text class="btn-link" bindtap="editNote" data-ts="{{latestThought.timestamp}}">编辑</text>
              <text class="btn-link" bindtap="openLatestMore" data-ts="{{latestThought.timestamp}}" data-text="{{latestThought.text}}">更多</text>
            </view>
          </view>
        </view>
      </block>
    </view>

    <view class="section-card">
      <view class="section-card__hd">
        <view class="section-title-row">
          <view class="section-title">金句</view>
          <view class="section-link" bindtap="openNoteList" data-type="quote">查看全部({{quoteCount}})</view>
        </view>
      </view>
      <view class="section-card__bd">
        <textarea class="note-input {{quoteFocused ? 'note-input--focused' : 'note-input--compact'}}" placeholder="记下一句打动你的话…" value="{{quoteText}}" bindinput="onQuoteInput" bindfocus="onQuoteFocus" bindblur="onQuoteBlur" maxlength="500" auto-height />
        <view class="section-actions section-actions--right" wx:if="{{canSaveQuote}}">
          <button class="weui-btn weui-btn_primary weui-btn_mini mini-action-btn" data-type="quote" bindtap="addNote">添加</button>
        </view>
        <view class="saved-inline muted" wx:if="{{savedHintType === 'quote'}}">已保存到金句</view>
      </view>
    </view>

    <view class="weui-cells" style="margin-top: 0;">
      <block wx:if="{{!latestQuote}}">
        <view class="weui-cell">
          <view class="weui-cell__bd muted">还没有金句</view>
        </view>
      </block>
      <block wx:else>
        <view class="weui-cell">
          <view class="weui-cell__bd">
            <view class="latest-text ellipsis-2">📖 {{latestQuote.text}}</view>
            <view class="muted" style="margin-top: 10rpx;">{{latestQuote.timeText}}</view>
            <view class="row-actions">
              <text class="btn-link" bindtap="editNote" data-ts="{{latestQuote.timestamp}}">编辑</text>
              <text class="btn-link" bindtap="openLatestMore" data-ts="{{latestQuote.timestamp}}" data-text="{{latestQuote.text}}">更多</text>
            </view>
          </view>
        </view>
      </block>
    </view>

    <view class="soft-divider"></view>
    <view class="export-card">
      <view class="export-main">
        <view class="export-head">
          <view class="export-icon">↗</view>
          <view class="export-title">整理导出</view>
        </view>
        <view class="export-sub muted">{{exportHint}}</view>
      </view>
      <button class="weui-btn weui-btn_default weui-btn_mini export-btn {{!canExport ? 'export-btn--disabled' : ''}}" bindtap="copyAllForBook" disabled="{{!canExport}}">复制</button>
    </view>

    <button wx:if="{{book.status !== 'finished'}}" class="weui-btn btn-finish" style="margin-top: 18rpx;" bindtap="finishReading">我读完了</button>
    <button wx:else class="weui-btn btn-finish-outline" style="margin-top: 18rpx;" bindtap="markUnfinished">恢复在读</button>

    <view class="share-card-section" wx:if="{{book.status === 'finished' && quoteCount > 0}}">
      <button class="btn-share-card" bindtap="generateShareCard">生成阅读分享卡</button>
    </view>
  </block>
</view>

