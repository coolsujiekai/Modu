@import "/styles/theme.wxss";
@import "/styles/common.wxss";

.page {
  min-height: 100vh;
}

.muted {
  color: var(--text-warm-muted);
  font-size: 24rpx;
}

.mini-card {
  margin-top: 16rpx;
  background: var(--bg-surface);
  border-radius: var(--radius-md);
  padding: 16rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
border: 1rpx solid var(--border-warm);
}

.mini-card__left {
  flex: 1;
  min-width: 0;
}

.section-card {
  margin-top: 16rpx;
  background: var(--bg-surface);
  border-radius: var(--radius-md);
  overflow: hidden;
border: 1rpx solid var(--border-warm);
}

.section-card__hd {
  padding: 16rpx 16rpx 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-title);
}

.section-title-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
}

.section-link {
  flex: none;
  color: var(--text-accent);
  font-size: 24rpx;
  font-weight: 600;
  padding: 16rpx 0;
}

.section-card__bd {
  padding: 16rpx 16rpx 16rpx;
}

.note-input {
  width: 100%;
  font-size: 24rpx;
  line-height: 1.6;
  background: var(--bg-primary-warm);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-warm);
  padding: 16rpx;
  box-sizing: border-box;
  transition: border-color 0.2s ease, background-color 0.2s ease, min-height 0.2s ease;
}

.note-input--compact {
  min-height: 92rpx;
}

.note-input--focused {
  min-height: 200rpx;
  border-color: var(--border-accent);
  background: var(--bg-surface-soft);
}

.section-actions {
  margin-top: 16rpx;
}

.section-actions--right {
  display: flex;
  justify-content: flex-end;
}

.saved-inline {
  margin-top: 16rpx;
  text-align: right;
}

.note-voice-row {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.note-voice-btn.weui-btn,
.note-voice-btn {
  flex: none;
  margin: 0;
  padding: 0 18rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: var(--radius-md);
  background: var(--bg-surface-subtle);
  color: var(--text-title);
  font-size: 24rpx;
  font-weight: 650;
  border: 1rpx solid var(--border-overlay-soft);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.note-voice-btn::after {
  border: none;
}

.note-voice-btn:active {
  background: var(--tap-active-bg);
  transform: scale(0.985);
}

.note-voice-btn--recording {
  background: var(--border-gold-light);
  border-color: var(--border-gold-soft);
}

.note-tool__icon {
  font-size: 26rpx;
  line-height: 1;
}

.note-tool__label {
  font-size: 24rpx;
  line-height: 1;
}

.note-ocr-btn.weui-btn,
.note-ocr-btn {
  flex: none;
  margin: 0;
  padding: 0 18rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: var(--radius-md);
  background: var(--bg-surface-soft);
  color: var(--text-title);
  font-size: 24rpx;
  font-weight: 650;
  border: 1rpx solid var(--border-overlay-soft);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.note-ocr-btn::after {
  border: none;
}

.note-ocr-btn:active {
  background: var(--tap-active-bg);
  transform: scale(0.985);
}

.mini-action-btn {
  border-radius: var(--radius-md);
  min-width: 128rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.meta-label {
  flex: none;
  font-size: 26rpx;
  line-height: 1.2;
  color: var(--text-secondary);
  letter-spacing: 0.02em;
}

.meta-pill {
  flex: none;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  line-height: 1.2;
  color: var(--text-secondary);
  background: var(--bg-surface-tag);
  border: 1rpx solid var(--border-muted);
}

.meta-link {
  flex: none;
  font-size: 26rpx;
  line-height: 1.2;
  color: var(--accent-strong);
  font-weight: 600;
}

.meta-link:active {
  opacity: 0.9;
}

.book-panel {
  position: relative;
}

.book-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.book-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.book-title {
  flex: 1;
  min-width: 0;
}

.book-edit {
  flex: none;
  color: var(--text-accent);
  font-size: 24rpx;
  font-weight: 700;
  padding: 16rpx 16rpx;
}

.share-entry {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 20rpx;
  background: var(--border-gold-light);
  border: 1rpx solid var(--border-gold-soft);
  border-radius: var(--radius-md);
  transition: opacity 0.15s ease;
}

.share-entry--active {
  opacity: 1;
  background: var(--border-gold-soft);
}

.share-entry__icon {
  flex: none;
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-md);
  background: var(--bg-surface);
  color: #B88A47;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid var(--border-gold-soft);
}

.share-entry__main {
  flex: 1;
  min-width: 0;
}

.share-entry__title {
  color: var(--text-title);
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.3;
}

.share-entry__desc {
  margin-top: 6rpx;
  color: var(--text-warm-muted);
  font-size: 22rpx;
  line-height: 1.4;
}

.share-entry__arrow {
  flex: none;
  color: var(--text-light);
  font-size: 36rpx;
  line-height: 1;
  padding-left: 8rpx;
}

.row-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

/* ============ 时间流（按天分组） ============ */
.timeline-group {
  margin-top: 20rpx;
}

.timeline-group:first-child {
  margin-top: 0;
}

.timeline-group__hd {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
  padding: 8rpx 4rpx 14rpx;
}

.timeline-group__title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-title);
}

.timeline-group__list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.timeline-item {
  background: var(--bg-surface-soft);
  border: 1rpx solid var(--border-muted);
  border-radius: var(--radius-md);
  padding: 18rpx 18rpx;
  position: relative;
  overflow: hidden;
}

.timeline-item__bd {
  position: relative;
}

.corner-tag {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 72rpx;
  height: 72rpx;
  pointer-events: none;
}

.corner-tag--quote {
  background: linear-gradient(315deg, var(--bg-surface-tag) 0 50%, transparent 50%);
}

.corner-tag--thought {
  background: linear-gradient(315deg, var(--bg-surface-subtle) 0 50%, transparent 50%);
}

.corner-tag__text {
  position: absolute;
  bottom: 10rpx;
  right: 10rpx;
  font-size: 18rpx;
  line-height: 1;
  color: var(--text-secondary);
  font-weight: 700;
  letter-spacing: 0.04em;
}

.corner-tag--quote .corner-tag__text {
  color: var(--accent-strong);
}

.timeline-item__text {
  font-size: 26rpx;
  line-height: 1.65;
  color: var(--text-title);
  word-break: break-word;
}

.timeline-item__emoji {
  margin-right: 8rpx;
}

.timeline-item__meta {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 22rpx;
}

.timeline-item__time {
  flex: none;
}

.timeline-item__spacer {
  flex: 1;
  min-width: 0;
}

.timeline-item__action {
  flex: none;
  font-size: 22rpx;
}

.ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.export-card {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  background: var(--bg-surface-soft);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-warm);
  padding: 16rpx 16rpx;
}

.soft-divider {
  margin-top: 16rpx;
  height: 1rpx;
  background: var(--bg-divider);
}

.export-main {
  flex: 1;
  min-width: 0;
}

.export-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.export-icon {
  width: 34rpx;
  height: 34rpx;
  border-radius: var(--radius-md);
  background: var(--bg-surface-tag);
  color: var(--text-accent);
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.export-title {
  color: var(--text-title);
  font-size: 32rpx;
  font-weight: 700;
}

.export-sub {
  margin-top: 16rpx;
}

.export-btn {
  flex: none;
  border-radius: var(--radius-md);
  padding: 0 16rpx;
  font-size: 24rpx;
  color: var(--text-accent);
  border-color: var(--border-accent);
  background: var(--bg-primary-warm);
}

.export-btn.weui-btn {
  margin: 0;
}

.export-btn--disabled {
  color: var(--text-light) !important;
  border-color: var(--border-muted) !important;
  background: var(--bg-primary) !important;
}

.btn-finish {
  background: var(--button-bg);
  color: var(--button-text);
  border-radius: var(--radius-md);
  border-top: 1rpx solid rgba(255, 255, 255, 0.16);
  font-weight: 700;
  letter-spacing: var(--btn-letter-spacing);
}

.btn-finish:active {
  background: var(--btn-active-bg-primary);
  transform: scale(0.982);
}

.bottom-actions {
  margin-top: 18rpx;
  display: flex;
  gap: 16rpx;
}

.bottom-actions__btn.weui-btn {
  flex: 1;
  margin: 0;
}

.btn-finish-outline {
  background: var(--button-bg-secondary);
  color: var(--button-text-secondary);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-accent);
  font-weight: 700;
  letter-spacing: var(--btn-letter-spacing);
}

.btn-finish-outline:active {
  background: var(--btn-active-bg-secondary);
  transform: scale(0.982);
}

.share-card-section {
  padding: 0 32rpx 16rpx;
}

.btn-share-card {
  background: var(--text-brand);
  color: var(--button-text);
  border-radius: var(--radius-md);
  border: none;
  font-size: 24rpx;
  font-weight: 600;
  padding: 0;
  line-height: 2.6;
}

.btn-link {
  color: var(--text-accent);
  font-size: 24rpx;
}

.btn-danger {
  color: var(--text-danger);
  font-size: 24rpx;
}

.link {
  color: var(--text-accent);
  font-weight: 600;
}

