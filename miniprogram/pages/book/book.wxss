.page {
  min-height: 100vh;
  padding: 32rpx 32rpx 40rpx;
}

.muted {
  color: #8C8279;
  font-size: 26rpx;
}

.mini-card {
  margin-top: 16rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 18rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  box-shadow: none;
  border: 1rpx solid #EDE8E0;
}

.mini-card__left {
  flex: 1;
  min-width: 0;
}

.section-card {
  margin-top: 16rpx;
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: none;
  border: 1rpx solid #EDE8E0;
}

.section-card__hd {
  padding: 18rpx 18rpx 8rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D2A26;
}

.section-title-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12rpx;
}

.section-link {
  flex: none;
  color: #8B7355;
  font-size: 26rpx;
  font-weight: 600;
  padding: 6rpx 0;
}

.section-card__bd {
  padding: 10rpx 18rpx 18rpx;
}

.note-input {
  width: 100%;
  font-size: 28rpx;
  line-height: 1.6;
  background: #FAF8F5;
  border-radius: 12rpx;
  border: 1rpx solid #EDE8E0;
  padding: 16rpx;
  box-sizing: border-box;
  transition: border-color 0.2s ease, background-color 0.2s ease, min-height 0.2s ease;
}

.note-input--compact {
  min-height: 92rpx;
}

.note-input--focused {
  min-height: 200rpx;
  border-color: #D4C4A8;
  background: #FFFCF8;
}

.section-actions {
  margin-top: 12rpx;
}

.section-actions--right {
  display: flex;
  justify-content: flex-end;
}

.saved-inline {
  margin-top: 10rpx;
  text-align: right;
}

.mini-action-btn {
  border-radius: 999rpx;
  min-width: 128rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
}

.book-panel {
  position: relative;
}

.book-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.book-title {
  flex: 1;
  min-width: 0;
}

.book-edit {
  flex: none;
  color: #8B7355;
  font-size: 28rpx;
  font-weight: 700;
  padding: 6rpx 10rpx;
}

.row-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.latest-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #2D2A26;
}

.ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.export-card {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  background: #FFFCF8;
  border-radius: 20rpx;
  border: 1rpx solid #EDE8E0;
  padding: 16rpx 18rpx;
}

.soft-divider {
  margin-top: 16rpx;
  height: 1rpx;
  background: #EFE8DE;
}

.export-main {
  flex: 1;
  min-width: 0;
}

.export-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.export-icon {
  width: 34rpx;
  height: 34rpx;
  border-radius: 10rpx;
  background: #F3ECE2;
  color: #8B7355;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.export-title {
  color: #2D2A26;
  font-size: 30rpx;
  font-weight: 700;
}

.export-sub {
  margin-top: 6rpx;
}

.export-btn {
  flex: none;
  border-radius: 999rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #8B7355;
  border-color: #D4C4A8;
  background: #FAF8F5;
}

.export-btn.weui-btn {
  margin: 0;
}

.export-btn--disabled {
  color: #B4A99A !important;
  border-color: #E8E1D8 !important;
  background: #F8F4EF !important;
}

.btn-finish {
  background: #8B7355;
  color: #fff;
  border-radius: 999rpx;
  border: 1rpx solid #8B7355;
  font-weight: 700;
}

.btn-finish:active {
  opacity: 0.92;
}

.btn-finish-outline {
  background: transparent;
  color: #8B7355;
  border-radius: 999rpx;
  border: 1rpx solid #D4C4A8;
  font-weight: 700;
}

.btn-finish-outline:active {
  opacity: 0.92;
}

.btn-link {
  color: #8B7355;
  font-size: 26rpx;
}

.btn-danger {
  color: #C07D6B;
  font-size: 26rpx;
}

.link {
  color: #8B7355;
  font-weight: 600;
}

