@import "/styles/theme.wxss";
@import "/styles/common.wxss";

.page {
  min-height: 100vh;
}

.muted {
  color: var(--text-warm-muted);
  font-size: 24rpx;
}

.mini-card {
  margin-top: 16rpx;
  background: var(--bg-surface);
  border-radius: var(--radius-md);
  padding: 16rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
border: 1rpx solid var(--border-warm);
}

.mini-card__left {
  flex: 1;
  min-width: 0;
}

.section-card {
  margin-top: 16rpx;
  background: var(--bg-surface);
  border-radius: var(--radius-md);
  overflow: hidden;
border: 1rpx solid var(--border-warm);
}

.section-card__hd {
  padding: 16rpx 16rpx 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-title);
}

.section-title-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
}

.section-link {
  flex: none;
  color: var(--text-accent);
  font-size: 24rpx;
  font-weight: 600;
  padding: 16rpx 0;
}

.section-card__bd {
  padding: 16rpx 16rpx 16rpx;
}

.note-input {
  width: 100%;
  font-size: 24rpx;
  line-height: 1.6;
  background: var(--bg-primary-warm);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-warm);
  padding: 16rpx;
  box-sizing: border-box;
  transition: border-color 0.2s ease, background-color 0.2s ease, min-height 0.2s ease;
}

.note-input--compact {
  min-height: 92rpx;
}

.note-input--focused {
  min-height: 200rpx;
  border-color: var(--border-accent);
  background: var(--bg-surface-soft);
}

.section-actions {
  margin-top: 16rpx;
}

.section-actions--right {
  display: flex;
  justify-content: flex-end;
}

.saved-inline {
  margin-top: 16rpx;
  text-align: right;
}

.mini-action-btn {
  border-radius: var(--radius-md);
  min-width: 128rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
}

.book-panel {
  position: relative;
}

.book-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.book-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.book-title {
  flex: 1;
  min-width: 0;
}

.book-edit {
  flex: none;
  color: var(--text-accent);
  font-size: 24rpx;
  font-weight: 700;
  padding: 16rpx 16rpx;
}

.share-entry {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 20rpx;
  background: var(--border-gold-light);
  border: 1rpx solid var(--border-gold-soft);
  border-radius: var(--radius-md);
  transition: opacity 0.15s ease;
}

.share-entry--active {
  opacity: 0.7;
}

.share-entry__icon {
  flex: none;
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-md);
  background: var(--bg-surface);
  color: #B88A47;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid var(--border-gold-soft);
}

.share-entry__main {
  flex: 1;
  min-width: 0;
}

.share-entry__title {
  color: var(--text-title);
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.3;
}

.share-entry__desc {
  margin-top: 6rpx;
  color: var(--text-warm-muted);
  font-size: 22rpx;
  line-height: 1.4;
}

.share-entry__arrow {
  flex: none;
  color: var(--text-light);
  font-size: 36rpx;
  line-height: 1;
  padding-left: 8rpx;
}

.row-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

/* ============ 时间流（按天分组） ============ */
.timeline-group {
  margin-top: 20rpx;
}

.timeline-group:first-child {
  margin-top: 0;
}

.timeline-group__hd {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
  padding: 8rpx 4rpx 14rpx;
}

.timeline-group__title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-title);
}

.timeline-group__list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.timeline-item {
  background: var(--bg-surface-soft);
  border: 1rpx solid var(--border-muted);
  border-radius: var(--radius-md);
  padding: 18rpx 18rpx;
}

.timeline-item__text {
  font-size: 26rpx;
  line-height: 1.65;
  color: var(--text-title);
  word-break: break-word;
}

.timeline-item__emoji {
  margin-right: 8rpx;
}

.timeline-item__meta {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 22rpx;
}

.timeline-item__time {
  flex: none;
}

.timeline-item__spacer {
  flex: 1;
  min-width: 0;
}

.timeline-item__action {
  flex: none;
  font-size: 22rpx;
}

.type-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: var(--radius-md);
  font-size: 24rpx;
  color: var(--text-secondary);
  background: var(--bg-surface-subtle);
}

.type-tag--quote {
  background: var(--bg-surface-tag);
}

.type-tag--thought {
  background: var(--bg-surface-subtle);
}

.ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.export-card {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  background: var(--bg-surface-soft);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-warm);
  padding: 16rpx 16rpx;
}

.soft-divider {
  margin-top: 16rpx;
  height: 1rpx;
  background: var(--bg-divider);
}

.export-main {
  flex: 1;
  min-width: 0;
}

.export-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.export-icon {
  width: 34rpx;
  height: 34rpx;
  border-radius: var(--radius-md);
  background: var(--bg-surface-tag);
  color: var(--text-accent);
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.export-title {
  color: var(--text-title);
  font-size: 32rpx;
  font-weight: 700;
}

.export-sub {
  margin-top: 16rpx;
}

.export-btn {
  flex: none;
  border-radius: var(--radius-md);
  padding: 0 16rpx;
  font-size: 24rpx;
  color: var(--text-accent);
  border-color: var(--border-accent);
  background: var(--bg-primary-warm);
}

.export-btn.weui-btn {
  margin: 0;
}

.export-btn--disabled {
  color: var(--text-light) !important;
  border-color: var(--border-muted) !important;
  background: var(--bg-primary) !important;
}

.btn-finish {
  background: var(--text-accent);
  color: var(--button-text);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--text-accent);
  font-weight: 700;
}

.btn-finish:active {
  opacity: 0.92;
}

.bottom-actions {
  margin-top: 18rpx;
  display: flex;
  gap: 16rpx;
}

.bottom-actions__btn.weui-btn {
  flex: 1;
  margin: 0;
}

.btn-finish-outline {
  background: transparent;
  color: var(--text-accent);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-accent);
  font-weight: 700;
}

.btn-finish-outline:active {
  opacity: 0.92;
}

.share-card-section {
  padding: 0 32rpx 16rpx;
}

.btn-share-card {
  background: var(--text-brand);
  color: var(--button-text);
  border-radius: var(--radius-md);
  border: none;
  font-size: 24rpx;
  font-weight: 600;
  padding: 0;
  line-height: 2.6;
}

.btn-link {
  color: var(--text-accent);
  font-size: 24rpx;
}

.btn-danger {
  color: var(--text-danger);
  font-size: 24rpx;
}

.link {
  color: var(--text-accent);
  font-weight: 600;
}

