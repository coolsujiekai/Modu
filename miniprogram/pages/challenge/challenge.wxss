@import "/styles/theme.wxss";
@import "/styles/common.wxss";

.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.state {
  padding: 40rpx 24rpx;
  text-align: center;
  font-size: 26rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-title);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-light);
  text-align: center;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-title);
  margin-bottom: 16rpx;
}

.hero-card {
  background: linear-gradient(135deg, rgba(139, 115, 85, 0.12), rgba(168, 144, 112, 0.10));
}

.hero-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-title);
  margin-bottom: 10rpx;
}

.hero-desc {
  font-size: 24rpx;
  color: var(--text-light);
  line-height: 1.55;
  margin-bottom: 16rpx;
}

.hero-stats {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.hero-stat {
  font-size: 24rpx;
  color: var(--text-title);
}

.hero-num {
  font-weight: 800;
  color: var(--primary);
}

.selected-book {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-title);
  margin-bottom: 16rpx;
}

.btn-row {
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  margin: 0;
}

.action-card .primary-btn {
  margin-top: 0;
}

.secondary-btn {
  margin-top: 16rpx;
}

/* 日历 */
.calendar {
  margin-bottom: 16rpx;
}

.cal-month {
  text-align: center;
  font-size: 26rpx;
  color: var(--text-light);
  margin-bottom: 16rpx;
}

.cal-weekdays {
  display: flex;
  margin-bottom: 8rpx;
}

.cal-weekday {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-light);
  padding: 8rpx 0;
}

.cal-days {
  display: flex;
  flex-wrap: wrap;
}

.cal-day {
  width: calc(100% / 7);
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--text-light);
  box-sizing: border-box;
}

.cal-day.inRange {
  color: var(--text-title);
}

.cal-day.hasCheckin {
  background: var(--primary);
  color: #fff;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: 800;
  box-shadow: 0 6rpx 14rpx rgba(7, 193, 96, 0.24);
}

.cal-day.hasCheckin::after {
  content: '';
}

.cal-day-disabled {
  color: var(--text-light);
  opacity: 0.4;
}

.cal-legend {
  display: flex;
  gap: 24rpx;
  justify-content: center;
  margin-top: 12rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: var(--text-light);
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  border: 2rpx solid var(--text-light);
}

.legend-dot.checked {
  background: var(--primary);
  border-color: var(--primary);
}

/* 统计行 */
.stat-row {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  border-top: 1rpx solid var(--border-soft);
  border-bottom: 1rpx solid var(--border-soft);
  margin: 16rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-title);
}

.stat-num.completed {
  color: var(--primary);
}

.stat-label {
  font-size: 22rpx;
}

/* 打卡记录 */
.checkin-item {
  padding: 16rpx 0;
  border-top: 1rpx solid var(--border-soft);
}

.checkin-book {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-title);
  margin-bottom: 8rpx;
}

.checkin-time {
  font-size: 22rpx;
}

.empty-tip {
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
}
