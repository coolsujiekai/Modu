<view class="page">
  <view wx:if="{{loading}}" class="state muted">加载中...</view>

  <!-- 无活动 -->
  <view wx:elif="{{!challenge}}" class="empty-state">
    <text class="empty-icon">📖</text>
    <view class="empty-title">暂无阅读活动</view>
    <view class="empty-desc">活动开启后，可以每天打卡记录阅读。</view>
  </view>

  <view wx:else>
    <!-- 顶部状态卡 -->
    <view class="card hero-card">
      <view class="hero-title">{{challenge.name || '每日阅读打卡'}}</view>
      <view class="hero-desc">每天读一点，点一下就算坚持。写金句或心得，也会自动完成当天打卡。</view>
      <view class="hero-stats">
        <view class="hero-stat">本期已打卡 <text class="hero-num">{{checkinDays}}</text> 天</view>
        <view class="hero-stat" wx:if="{{todayChecked}}">今日已完成 ✅</view>
        <view class="hero-stat" wx:else>今日未打卡</view>
      </view>
    </view>

    <!-- 当前书籍选择 -->
    <view class="card">
      <view class="section-title">当前书籍</view>

      <view wx:if="{{selectedBook}}" class="selected-book">
        《{{selectedBook.bookName}}》
      </view>
      <view wx:else class="muted">先选择一本正在读的书</view>

      <view class="btn-row">
        <button class="weui-btn weui-btn_default btn" bindtap="openBookPicker" disabled="{{operating}}">选择在读书籍</button>
        <button class="weui-btn weui-btn_default btn" bindtap="addBookAndCheckin" disabled="{{operating}}">新增一本书</button>
      </view>
    </view>

    <!-- 主操作 -->
    <view class="card action-card">
      <button
        class="weui-btn weui-btn_primary primary-btn"
        disabled="{{!selectedBook || todayChecked || operating}}"
        loading="{{operating}}"
        bindtap="onCheckinToday"
      >
        {{todayChecked ? '今天已打卡' : '今日打卡'}}
      </button>

      <button wx:if="{{selectedBook}}" class="weui-btn weui-btn_default secondary-btn" bindtap="goBookDetail" disabled="{{operating}}">
        去记录心得
      </button>
    </view>

    <!-- 日历 -->
    <view class="card">
      <view class="section-title">本月打卡</view>
      <view class="calendar">
        <view class="cal-month">{{calYear}} 年 {{calMonth + 1}} 月</view>
        <view class="cal-weekdays">
          <text wx:for="{{weekdays}}" wx:key="index" class="cal-weekday">{{item}}</text>
        </view>
        <view class="cal-days">
          <view
            wx:for="{{calDays}}"
            wx:key="index"
            class="cal-day {{item.inRange ? 'inRange' : 'cal-day-disabled'}} {{item.hasCheckin ? 'hasCheckin' : ''}}"
          >{{item.hasCheckin ? '✓' : item.day}}</view>
        </view>
      </view>
      <view class="cal-legend">
        <view class="legend-item"><view class="legend-dot checked"></view> 已打卡</view>
        <view class="legend-item"><view class="legend-dot"></view> 未打卡</view>
      </view>
    </view>

    <!-- 最近打卡 -->
    <view class="card">
      <view class="section-title">最近打卡</view>
      <view wx:if="{{checkins.length === 0}}" class="muted empty-tip">暂无记录</view>
      <view wx:for="{{checkins}}" wx:key="_id" class="checkin-item">
        <view class="checkin-book">{{item.checkinDate || formatDate(item.checkedAt)}} 《{{item.bookName}}》</view>
        <view class="checkin-time muted">{{item.source === 'note' ? '来自笔记自动打卡' : '活动页打卡'}}</view>
      </view>
    </view>
  </view>
</view>
