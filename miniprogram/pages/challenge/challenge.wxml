<view class="page">
  <!-- 无活动 -->
  <view wx:if="{{!challenge}}" class="empty-state">
    <text class="empty-icon">📖</text>
    <view class="empty-title">暂无进行中的活动</view>
    <view class="empty-desc">关注首页横幅，活动开启时第一时间参与</view>
  </view>

  <block wx:else>
    <!-- 活动信息头部 -->
    <view class="card challenge-header">
      <view class="challenge-name">{{challenge.name}}</view>
      <view class="challenge-desc muted" wx:if="{{challenge.desc}}">{{challenge.desc}}</view>
      <view class="challenge-dates">
        <text class="date-badge">{{formatDate(challenge.startDate)}}</text>
        <text class="date-arrow">→</text>
        <text class="date-badge">{{formatDate(challenge.endDate)}}</text>
      </view>
    </view>

    <!-- 未报名 -->
    <view wx:if="{{!joined && challenge.status === 'active'}}" class="card">
      <view class="notice-box">
        <text>报名后可参与打卡，记录阅读心得和金句</text>
      </view>
      <button class="weui-btn weui-btn_primary" bindtap="join" loading="{{joining}}">立即报名</button>
    </view>

    <!-- 已报名：两个 Tab -->
    <view wx:if="{{joined}}">
      <view class="tab-bar">
        <view class="tab-item {{activeTab === 'participate' ? 'active' : ''}}" bindtap="switchTab" data-tab="participate">参与</view>
        <view class="tab-item {{activeTab === 'rank' ? 'active' : ''}}" bindtap="switchTab" data-tab="rank">排行榜</view>
      </view>

      <!-- 参与 Tab -->
      <view wx:if="{{activeTab === 'participate'}}" class="tab-content">
        <view class="card">
          <view class="section-title">打卡日历</view>
          <view class="calendar">
            <view class="cal-month">{{calYear}} 年 {{calMonth + 1}} 月</view>
            <view class="cal-weekdays">
              <text wx:for="{{weekdays}}" wx:key="index" class="cal-weekday">{{item}}</text>
            </view>
            <view class="cal-days">
              <view
                wx:for="{{calDays}}"
                wx:key="index"
                class="cal-day {{item.inRange ? 'inRange' : 'cal-day-disabled'}} {{item.hasCheckin ? 'hasCheckin' : ''}}"
              >{{item.hasCheckin ? '✓' : item.day}}</view>
            </view>
          </view>
          <view class="cal-legend">
            <view class="legend-item"><view class="legend-dot checked"></view> 已打卡</view>
            <view class="legend-item"><view class="legend-dot"></view> 未打卡</view>
          </view>
          <view class="stat-row">
            <view class="stat-item">
              <text class="stat-num">{{checkinDays}}</text>
              <text class="stat-label muted">打卡天数</text>
            </view>
            <view class="stat-item">
              <text class="stat-num">{{checkinBooks.length}}</text>
              <text class="stat-label muted">阅读书目</text>
            </view>
            <view class="stat-item">
              <text class="stat-num {{completed ? 'completed' : ''}}">{{completed ? '✓' : '○'}}</text>
              <text class="stat-label muted">完成状态</text>
            </view>
          </view>
          <button wx:if="{{!completed}}" class="weui-btn weui-btn_default small" bindtap="markDone" loading="{{markingDone}}">标记为已读完</button>
        </view>

        <!-- 打卡记录 -->
        <view class="card">
          <view class="section-title">打卡记录</view>
          <view wx:if="{{checkins.length === 0}}" class="muted empty-tip">暂无记录，立即录入第一条</view>
          <view wx:for="{{checkins}}" wx:key="_id" class="checkin-item">
            <view class="checkin-book">《{{item.bookName}}》</view>
            <view class="checkin-content">{{item.content}}</view>
            <view class="checkin-time muted">{{formatDate(item.checkedAt)}}</view>
          </view>
        </view>

        <!-- 录入 -->
        <view class="card">
          <view class="section-title">录入心得 / 金句</view>
          <view class="form-row">
            <view class="form-label">书名</view>
            <picker mode="selector" range="{{readingBooks}}" range-key="bookName" value="{{bookIndex}}" bindchange="onBookChange">
              <view class="picker-value">{{selectedBookName || '选择书目'}}</view>
            </picker>
          </view>
          <view class="form-row">
            <view class="form-label">书名</view>
            <input class="form-input" placeholder="或输入书名" value="{{customBookName}}" bindinput="onCustomBookInput" />
          </view>
          <view class="form-row">
            <view class="form-label">内容</view>
          </view>
          <textarea
            class="textarea"
            placeholder="写下你的心得体会或金句..."
            maxlength="300"
            value="{{checkinContent}}"
            bindinput="onContentInput"
          />
          <view class="muted counter">{{checkinContent.length}} / 300</view>
          <button class="weui-btn weui-btn_primary" bindtap="submitCheckin" loading="{{submitting}}" disabled="{{!canSubmit}}">打卡</button>
        </view>
      </view>

      <!-- 排行榜 Tab -->
      <view wx:if="{{activeTab === 'rank'}}" class="tab-content">
        <view wx:if="{{challenge.status !== 'ended'}}" class="card">
          <view class="muted notice-box">排行榜将在活动结束后公开</view>
        </view>
        <view wx:else>
          <view wx:if="{{rankings.length === 0}}" class="empty-state">
            <text class="empty-icon">🏆</text>
            <view class="empty-title">暂无排行数据</view>
          </view>
          <view wx:else class="card">
            <view wx:for="{{rankings}}" wx:key="index" class="rank-item">
              <view class="rank-num {{item.rank <= 3 ? 'rank-top' : ''}}">{{item.rank}}</view>
              <image wx:if="{{item.avatar}}" class="rank-avatar" src="{{item.avatar}}" mode="aspectFill" />
              <view wx:else class="rank-avatar rank-avatar-default">{{item.nickname ? item.nickname.charAt(0) : '?'}}</view>
              <view class="rank-info">
                <view class="rank-nickname">{{item.nickname}}</view>
                <view class="rank-books muted">{{item.books.join('、') || '未录入'}}</view>
              </view>
              <view class="rank-badges">
                <text class="badge-days">{{item.checkinDays}}天</text>
                <text wx:if="{{item.completed}}" class="badge-done">✓已读完</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 已结束：显示排行榜入口 -->
    <view wx:if="{{challenge.status === 'ended' && !joined}}" class="card">
      <view class="muted notice-box">活动已结束，查看最终排行榜</view>
      <button class="weui-btn weui-btn_default" bindtap="switchTab" data-tab="rank">查看排行榜</button>
    </view>
  </block>
</view>
