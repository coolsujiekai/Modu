@import "/styles/theme.wxss";
@import "/styles/common.wxss";

.page {
  min-height: 100vh;
}

.hero {
  background: var(--bg-surface);
  border-radius: var(--radius-md);
  padding: 16rpx 16rpx;
  border: 1rpx solid var(--border-warm);
}

.hero-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-title);
}

.hero-sub {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: var(--text-warm-muted);
}

.add-card {
  margin-top: 16rpx;
  border-radius: var(--radius-md);
  border: 1rpx dashed var(--border-soft);
  background: var(--bg-surface-soft);
  padding: 16rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.add-plus {
  width: 40rpx;
  height: 40rpx;
  border-radius: var(--radius-md);
  background: var(--bg-surface-tag);
  color: var(--text-accent);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  line-height: 1;
}

.add-text {
  color: var(--text-accent);
  font-size: 24rpx;
  font-weight: 600;
}

.list-title {
  margin-top: 16rpx;
  margin-bottom: 16rpx;
  color: var(--text-warm-muted);
  font-size: 24rpx;
}

.list-cells {
  margin-top: 0 !important;
}

.muted {
  color: var(--text-warm-muted);
  font-size: 24rpx;
}

