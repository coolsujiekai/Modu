.page {
  min-height: 100vh;
  padding: 32rpx 32rpx 40rpx;
}

.hero {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 22rpx;
  border: 1rpx solid #EDE8E0;
}

.hero-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2D2A26;
}

.hero-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8C8279;
}

.add-card {
  margin-top: 16rpx;
  border-radius: 18rpx;
  border: 1rpx dashed #DCCFBE;
  background: #FFFCF8;
  padding: 18rpx 18rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.add-plus {
  width: 40rpx;
  height: 40rpx;
  border-radius: 999rpx;
  background: #F3ECE2;
  color: #8B7355;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  line-height: 1;
}

.add-text {
  color: #8B7355;
  font-size: 28rpx;
  font-weight: 600;
}

.list-title {
  margin-top: 18rpx;
  margin-bottom: 8rpx;
  color: #8C8279;
  font-size: 24rpx;
}

.list-cells {
  margin-top: 0 !important;
}

.muted {
  color: #8C8279;
  font-size: 26rpx;
}

.btn-delete {
  color: #C07D6B !important;
}

.tap-active {
  opacity: 0.86;
}

