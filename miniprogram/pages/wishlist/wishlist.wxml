<view class="page">
  <view class="weui-panel weui-panel_access">
    <view class="weui-panel__hd">📚 书单</view>
    <view class="weui-panel__bd">
      <view class="weui-media-box weui-media-box_text">
        <view class="weui-media-box__desc muted">不追热点，只藏好书｜解锁阅读的另一种酷方式</view>
      </view>
    </view>
  </view>

  <view class="weui-cells" style="margin-top: 16rpx;">
    <view class="weui-cell weui-cell_access" bindtap="addItem">
      <view class="weui-cell__bd">＋ 添加一本想读的书</view>
      <view class="weui-cell__ft"></view>
    </view>
  </view>

  <view class="weui-cells__title">列表（{{items.length}}）</view>
  <view class="weui-cells">
    <block wx:if="{{items.length === 0}}">
      <view class="weui-cell">
        <view class="weui-cell__bd muted">还没有书单内容</view>
      </view>
    </block>

    <view class="weui-cell" wx:for="{{items}}" wx:key="_id">
      <view class="weui-cell__bd">
        <view>{{item.title}}</view>
        <view class="muted">{{item.createdText}}</view>
      </view>
      <view class="weui-cell__ft" style="color:#fa5151;" bindtap="remove" data-id="{{item._id}}">删除</view>
    </view>
  </view>
</view>

