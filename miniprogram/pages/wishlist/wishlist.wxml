<view class="page">
  <view class="hero">
    <view class="hero-title">想读书单</view>
    <view class="hero-sub">先收藏，想读的时候再开始。</view>
  </view>

  <view class="add-card" bindtap="addItem" hover-class="tap-active" hover-stay-time="70">
    <view class="add-plus">+</view>
    <view class="add-text">添加一本想读的书</view>
  </view>

  <view class="list-title">共 {{items.length}} 本</view>
  <view class="weui-cells list-cells">
    <block wx:if="{{items.length === 0}}">
      <view class="weui-cell">
        <view class="weui-cell__bd muted">还没有想读的书</view>
      </view>
    </block>

    <view wx:for="{{items}}" wx:key="_id" class="slide-row">
      <slideview buttons="{{item.slideButtons}}" bind:buttontap="onSlideButtonTap" data-id="{{item._id}}">
        <view class="weui-cell">
          <view class="weui-cell__bd">
            <view>{{item.title}}</view>
            <view class="muted">{{item.createdText}}</view>
          </view>
        </view>
      </slideview>
    </view>
  </view>
</view>

