@import "/styles/theme.wxss";
@import "/styles/common.wxss";

.page {
  min-height: 100vh;
}

.card {
  background: var(--bg-surface);
  border-radius: var(--radius-md);
  padding: 32rpx 16rpx;
border: 1rpx solid var(--border-warm);
  margin-bottom: 16rpx;
}

.h1 {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-title);
}

.h2 {
  margin-top: 16rpx;
  margin-bottom: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-title);
}

.p {
  font-size: 24rpx;
  line-height: 1.65;
  color: var(--text-title);
  margin-top: 16rpx;
  white-space: pre-wrap;
}

.muted {
  color: var(--text-warm-muted);
}

.footer {
  text-align: center;
  margin-top: 16rpx;
  font-size: 24rpx;
}

