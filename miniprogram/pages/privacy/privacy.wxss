.page {
  min-height: 100vh;
  padding: 32rpx 32rpx 60rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 26rpx 24rpx;
  box-shadow: none;
  border: 1rpx solid #EDE8E0;
  margin-bottom: 24rpx;
}

.h1 {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D2A26;
}

.h2 {
  margin-top: 6rpx;
  margin-bottom: 10rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #2D2A26;
}

.p {
  font-size: 28rpx;
  line-height: 1.65;
  color: #2D2A26;
  margin-top: 10rpx;
  white-space: pre-wrap;
}

.muted {
  color: #8C8279;
}

.footer {
  text-align: center;
  margin-top: 20rpx;
  font-size: 24rpx;
}

