@import "/styles/theme.wxss";
@import "/styles/common.wxss";

.page.onboarding-page {
  min-height: 100vh;
  padding-top: 72rpx !important;
  padding-bottom: 72rpx !important;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.onboarding-hero {
  padding: 0 8rpx 28rpx;
}

.onboarding-title {
  font-size: 56rpx;
  font-weight: 900;
  color: var(--text-title);
  letter-spacing: 0.01em;
  line-height: 1.1;
}

.onboarding-sub {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.onboarding-card {
  margin-top: 12rpx !important;
  padding: 28rpx 24rpx !important;
}

.onboarding-steps {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.step {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.step__dot {
  flex: none;
  width: 18rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: var(--text-accent);
  margin-top: 10rpx;
}

.step__title {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-title);
  line-height: 1.2;
}

.step__desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.55;
}

.onboarding-actions {
  margin-top: 28rpx;
  padding: 0 8rpx 0;
}

.onboarding-btn.weui-btn {
  margin: 0;
}

.onboarding-btn--secondary.weui-btn {
  margin-top: 16rpx;
}

