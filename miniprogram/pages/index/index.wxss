@import "/styles/theme.wxss";
@import "/styles/common.wxss";

.page.home-page {
  min-height: 100vh;
  position: relative;
}

/* ============ 主 Hero ============ */
.home-hero {
  margin-top: 0;
  padding: 40rpx 36rpx !important;
  border-radius: var(--radius-xl) !important;
  background: var(--hero-bg-gradient) !important;
}

.home-hero__title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-title);
  line-height: 1.14;
  letter-spacing: -0.02em;
}

.home-hero__sub {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--text-light);
}

.home-hero__actions {
  margin-top: 32rpx;
  display: flex;
  gap: 16rpx;
}

.home-hero__btn.weui-btn {
  flex: 1;
  margin: 0;
}

.home-empty {
  padding: 8rpx 8rpx 24rpx;
}

/* ============ 最近记录 ============ */
.recent-section {
  margin-top: 44rpx;
  margin-bottom: 32rpx;
}

.recent-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 0 6rpx 18rpx;
}

.recent-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-title);
  letter-spacing: -0.02em;
}

.recent-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.recent-item {
  padding: 28rpx;
  border-radius: var(--radius-lg);
  background: var(--bg-surface);
  box-shadow: var(--shadow-soft);
  transition: opacity 0.15s ease;
}

.recent-item__text {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-title);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  word-break: break-word;
}

.recent-item__tag {
  margin-right: 8rpx;
}

.recent-item__meta {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  font-size: 22rpx;
  color: var(--text-light);
}

.recent-item__book {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: var(--text-accent);
}

.recent-item__time {
  flex: none;
}

/* ============ 在读书架（横向弱化） ============ */
.shelf-head {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  padding: 0 6rpx 18rpx;
}

.shelf-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-title);
  letter-spacing: -0.02em;
}

.shelf-count {
  font-size: 24rpx;
  color: var(--text-light);
}

.shelf-scroll {
  width: 100%;
  white-space: nowrap;
  margin: 0 -32rpx;
  padding: 0 32rpx;
  box-sizing: content-box;
}

.shelf-inner {
  display: inline-flex;
  gap: 24rpx;
  padding-right: 32rpx;
}

.shelf-item {
  flex: none;
  width: 168rpx;
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.shelf-cover {
  position: relative;
  width: 168rpx;
  height: 228rpx;
  border-radius: 24rpx;
  border: none;
  overflow: hidden;
  display: flex;
  align-items: stretch;
  box-shadow: var(--shadow-book-cover);
}

.shelf-cover__spine {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 10rpx;
  background: var(--cover-spine-gradient);
  border-right: 1rpx solid var(--border-dark-faint);
  z-index: 1;
}

.shelf-cover__inner {
  flex: 1;
  padding: 18rpx 16rpx 16rpx 24rpx;
  display: flex;
  align-items: flex-start;
  z-index: 2;
}

.shelf-cover__title {
  font-size: 24rpx;
  line-height: 1.45;
  font-weight: 600;
  color: var(--cover-title-color);
  letter-spacing: 0.01em;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 5;
  overflow: hidden;
  word-break: break-word;
  white-space: normal;
}

/* 复用首页既有的底色变量 */
.cover-tone-1 {
  background: var(--book-tone-shine-1), var(--book-tone-1);
}
.cover-tone-2 {
  background: var(--book-tone-shine-2), var(--book-tone-2);
}
.cover-tone-3 {
  background: var(--book-tone-shine-3), var(--book-tone-3);
}
.cover-tone-4 {
  background: var(--book-tone-shine-4), var(--book-tone-4);
}
.cover-tone-5 {
  background: var(--book-tone-shine-5), var(--book-tone-5);
}

.shelf-author {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--text-light);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.shelf-add {
  width: 168rpx;
  height: 228rpx;
  border-radius: 24rpx;
  background: var(--bg-surface);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-soft);
}

.shelf-add__plus {
  font-size: 56rpx;
  color: var(--text-light);
  line-height: 1;
  font-weight: 200;
}

/* ============ 空书架 ============ */
.empty-shelf {
  padding: 96rpx 32rpx;
  text-align: center;
}

.empty-shelf__icon {
  font-size: 84rpx;
  margin-bottom: 16rpx;
}

.empty-shelf__title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-title);
}

.empty-shelf__desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--text-warm-muted);
}

.empty-shelf__btn {
  margin-top: 32rpx !important;
  display: inline-block;
  min-width: 240rpx;
}

.tap-active {
  opacity: 0.86;
}
