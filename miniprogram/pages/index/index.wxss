@import "/styles/theme.wxss";
@import "/styles/common.wxss";

.page.home-page {
  min-height: 100vh;
  background: #FAFAF8;
  padding: 0 40rpx;
}

/* ============ 顶部状态栏占位 ============ */
.top-bar {
  height: calc(var(--status-bar-height) + 16rpx);
}

/* ============ 书架区域 ============ */
.shelf-section {
  padding-bottom: 8rpx;
}

.shelf-header {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  margin-bottom: 32rpx;
}

.shelf-label {
  font-size: 44rpx;
  font-weight: 700;
  color: #1A1A1A;
  letter-spacing: -0.03em;
}

.shelf-count {
  font-size: 24rpx;
  color: #9A9A9A;
  font-weight: 400;
}

.shelf-loading {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

/* ============ 空书架 ============ */
.shelf-empty {
  padding: 40rpx 0;
}

.shelf-empty__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 0;
}

.shelf-empty__icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 20rpx;
  opacity: 0.4;
}

.shelf-empty__text {
  font-size: 28rpx;
  color: #B0B0B0;
  display: block;
  margin-bottom: 32rpx;
}

.shelf-empty__btn {
  background: #8B7355 !important;
  color: #fff !important;
  border: none !important;
  font-size: 26rpx !important;
}

/* ============ 书籍行 ============ */
.book-row {
  display: flex;
  gap: 28rpx;
  overflow-x: auto;
  padding-bottom: 12rpx;
  margin: 0 -40rpx;
  padding-left: 40rpx;
  padding-right: 40rpx;
  -webkit-overflow-scrolling: touch;
}

.book-row::-webkit-scrollbar {
  display: none;
}

.book-item {
  flex: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

/* ============ 书籍封面 ============ */
.book-cover {
  position: relative;
  width: 120rpx;
  height: 168rpx;
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.10), 0 1rpx 4rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: stretch;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.book-item:active .book-cover {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.book-cover__left-bar {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: rgba(0, 0, 0, 0.12);
  z-index: 1;
}

.book-cover__content {
  flex: 1;
  padding: 14rpx 12rpx 14rpx 18rpx;
  display: flex;
  align-items: flex-start;
  z-index: 2;
}

.book-cover__title {
  font-size: 22rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #2C2C2C;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
  overflow: hidden;
  word-break: break-word;
}

.book-cover--add {
  background: #F0EFED !important;
  border: 1.5rpx dashed #CFCFC9 !important;
  align-items: center;
  justify-content: center;
  box-shadow: none !important;
}

.book-cover__plus {
  font-size: 48rpx;
  color: #B0B0B0;
  font-weight: 300;
  line-height: 1;
}

/* 封面配色 */
.book-cover.cover-tone-1 { background: linear-gradient(155deg, #F2F4FF 0%, #E8EDFF 100%); }
.book-cover.cover-tone-2 { background: linear-gradient(155deg, #F5F6FA 0%, #EDF1F7 100%); }
.book-cover.cover-tone-3 { background: linear-gradient(155deg, #FFF3EC 0%, #FFE8DF 100%); }
.book-cover.cover-tone-4 { background: linear-gradient(155deg, #F3FFF6 0%, #E4F8EC 100%); }
.book-cover.cover-tone-5 { background: linear-gradient(155deg, #F8F4FF 0%, #EEE6FF 100%); }

/* ============ 书名 ============ */
.book-name {
  font-size: 22rpx;
  color: #2C2C2C;
  font-weight: 500;
  text-align: center;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.book-name--muted {
  color: #B0B0B0;
  font-weight: 400;
}

/* ============ 分隔线 ============ */
.divider {
  height: 1rpx;
  background: #EBEBEB;
  margin: 40rpx 0;
}

/* ============ 笔记区域 ============ */
.notes-section {
  padding-bottom: 20rpx;
}

.notes-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.notes-label {
  font-size: 44rpx;
  font-weight: 700;
  color: #1A1A1A;
  letter-spacing: -0.03em;
}

.notes-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: #9A9A9A;
}

.notes-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.note-item {
  padding: 28rpx 32rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.note-item__top {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.note-item__book {
  font-size: 22rpx;
  color: #9A9A9A;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.note-item__text {
  font-size: 28rpx;
  line-height: 1.7;
  color: #1A1A1A;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  word-break: break-word;
}

.note-item__time {
  display: block;
  margin-top: 12rpx;
  font-size: 21rpx;
  color: #C0C0C0;
}

/* ============ 安全区 ============ */
.safe-area {
  height: calc(env(safe-area-inset-bottom) + 24rpx);
}

/* ============ 阅读活动横幅 ============ */
.challenge-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 24rpx 16rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #8B7355, #A89070);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(139, 115, 85, 0.25);
}

.banner-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.banner-tag {
  font-size: 32rpx;
  flex: none;
}

.banner-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.banner-arrow {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  flex: none;
  margin-left: 16rpx;
}
