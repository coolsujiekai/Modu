@import "/styles/theme.wxss";
@import "/styles/common.wxss";

.page.home-page {
  min-height: 100vh;
  background: var(--bg-primary);
  padding: 0 var(--page-padding-x);
}

/* ============ 打卡横幅 ============ */
.checkin-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: var(--accent-light);
  border: 1rpx solid var(--border-gold-light);
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-2);
  box-shadow: var(--shadow-xs);
  transition: all 0.38s cubic-bezier(0.25, 0.1, 0.25, 1);
}

.checkin-banner:active {
  transform: scale(0.985);
  background: var(--bg-surface-soft);
}

.checkin-banner--done {
  background: var(--bg-surface-soft);
  border-color: var(--border-soft);
  box-shadow: none;
}

.checkin-banner__left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.checkin-banner__icon {
  font-size: 28rpx;
}

.checkin-banner__text {
  font-size: 26rpx;
  font-weight: 400;
  color: var(--accent);
  letter-spacing: 0.03em;
}

.checkin-banner--done .checkin-banner__text {
  color: var(--text-light);
}

.checkin-banner__right {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.checkin-banner__streak {
  font-size: 22rpx;
  color: var(--text-light);
  letter-spacing: 0.04em;
}

.dark-theme .checkin-banner {
  background: var(--bg-dark-surface-2);
  border-color: var(--border-dark);
}

.dark-theme .checkin-banner__text {
  color: var(--text-dark-highlight);
}

.dark-theme .checkin-banner--done {
  background: var(--bg-dark-surface-3);
}

/* ============ 顶部状态栏占位 ============ */
.top-bar {
  height: calc(var(--status-bar-height) + 16rpx);
}

/* ============ 书架区域 ============ */
.shelf-section {
  padding-bottom: 8rpx;
}

.shelf-header {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  margin-bottom: var(--space-2);
}

.shelf-label {
  font-size: 44rpx;
  font-weight: var(--font-title-weight);
  color: var(--text-primary);
  letter-spacing: 0.04em;
}

.shelf-count {
  font-size: var(--font-meta);
  color: var(--text-light);
  font-weight: 300;
}

.shelf-loading {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

/* ============ 空书架 ============ */
.shelf-empty {
  padding: 40rpx 0;
}

.shelf-empty__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-xl) 0;
}

.shelf-empty__icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 20rpx;
  opacity: 0.3;
}

.shelf-empty__text {
  font-size: 28rpx;
  color: var(--text-light);
  display: block;
  margin-bottom: var(--space-2);
  letter-spacing: 0.04em;
}

.shelf-empty__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 40rpx;
  border-radius: 999rpx;
  background: var(--accent);
  color: var(--button-text);
  font-size: 26rpx;
  font-weight: 400;
  letter-spacing: 0.05em;
  transition: all 0.38s cubic-bezier(0.25, 0.1, 0.25, 1);
}

.shelf-empty__btn:active {
  transform: scale(0.96);
  opacity: 0.85;
}

/* ============ 箭头图标 ============ */
.arrow-icon {
  font-size: 24rpx;
  color: var(--accent);
  font-weight: 200;
  line-height: 1;
  transition: transform 0.38s cubic-bezier(0.25, 0.1, 0.25, 1);
}

.arrow-icon--done {
  color: var(--text-light);
}

/* ============ 加载旋转 ============ */
.spinner {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid var(--bg-surface-muted);
  border-top-color: var(--accent);
  border-radius: 999rpx;
  animation: spin 1.2s cubic-bezier(0.6, 0.2, 0.4, 0.8) infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ============ 笔记类型标签 ============ */
.note-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 400;
  line-height: 1.6;
  letter-spacing: 0.04em;
}

.tag-quote {
  background: #F0E9E2;
  color: #A08870;
}

.tag-note {
  background: #E2E8F0;
  color: #7088A0;
}

.tag-thought {
  background: #EAEAEA;
  color: #8A8A8A;
}

/* ============ 书籍行 ============ */
.book-row {
  display: flex;
  gap: 28rpx;
  overflow-x: auto;
  padding-bottom: 12rpx;
  margin: 0 calc(-1 * var(--page-padding-x));
  padding-left: var(--page-padding-x);
  padding-right: var(--page-padding-x);
  -webkit-overflow-scrolling: touch;
}

.book-row::-webkit-scrollbar {
  display: none;
}

.book-item {
  flex: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

/* ============ 书籍封面 ============ */
.book-cover {
  position: relative;
  width: 120rpx;
  height: 168rpx;
  border-radius: var(--radius-xs);
  overflow: hidden;
  box-shadow: var(--shadow-book-cover);
  display: flex;
  align-items: stretch;
  transition: transform 0.38s cubic-bezier(0.25, 0.1, 0.25, 1), box-shadow 0.38s ease;
}

.book-item:active .book-cover {
  transform: scale(0.96);
  box-shadow: var(--shadow-xs);
}

.book-cover__left-bar {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: rgba(0, 0, 0, 0.10);
  z-index: 1;
}

.book-cover__content {
  flex: 1;
  padding: 14rpx 12rpx 14rpx 18rpx;
  display: flex;
  align-items: flex-start;
  z-index: 2;
}

.book-cover__title {
  font-size: 22rpx;
  line-height: 1.6;
  font-weight: 500;
  color: var(--cover-title-color);
  letter-spacing: 0.03em;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
  overflow: hidden;
  word-break: break-word;
}

.book-cover--add {
  background: var(--bg-surface-muted) !important;
  border: 1.5rpx dashed var(--border-light) !important;
  align-items: center;
  justify-content: center;
  box-shadow: none !important;
}

.book-cover__plus {
  font-size: 48rpx;
  color: var(--text-light);
  font-weight: 200;
  line-height: 1;
}

/* 封面配色 — 使用主题变量 */
.book-cover.cover-tone-1 { background: var(--book-tone-1); }
.book-cover.cover-tone-2 { background: var(--book-tone-2); }
.book-cover.cover-tone-3 { background: var(--book-tone-3); }
.book-cover.cover-tone-4 { background: var(--book-tone-4); }
.book-cover.cover-tone-5 { background: var(--book-tone-5); }

/* ============ 书名 ============ */
.book-name {
  font-size: 22rpx;
  color: var(--text-primary);
  font-weight: 400;
  text-align: center;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  letter-spacing: 0.03em;
}

.book-name--muted {
  color: var(--text-light);
  font-weight: 300;
}

/* ============ 分隔线 ============ */
.divider {
  height: 1rpx;
  background: var(--bg-divider);
  margin: var(--space-3) 0;
}

/* ============ 笔记区域 ============ */
.notes-section {
  padding-bottom: 20rpx;
}

.notes-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: var(--space-2);
}

.notes-label {
  font-size: 44rpx;
  font-weight: var(--font-title-weight);
  color: var(--text-primary);
  letter-spacing: 0.04em;
}

.notes-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: var(--font-meta);
  color: var(--text-light);
  letter-spacing: 0.04em;
}

.notes-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.note-item {
  padding: var(--card-padding);
  background: var(--bg-surface);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  transition: all 0.38s cubic-bezier(0.25, 0.1, 0.25, 1);
}

.note-item:active {
  transform: scale(0.985);
  box-shadow: var(--shadow-xs);
}

.note-item__top {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.note-item__book {
  font-size: 22rpx;
  color: var(--text-light);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  letter-spacing: 0.03em;
}

.note-item__text {
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--text-primary);
  letter-spacing: 0.03em;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  word-break: break-word;
}

.note-item__time {
  display: block;
  margin-top: 12rpx;
  font-size: 21rpx;
  color: var(--text-light);
  letter-spacing: 0.04em;
}

/* ============ 安全区 ============ */
.safe-area {
  height: calc(env(safe-area-inset-bottom) + 24rpx);
}

/* ============ AI 助手悬浮按钮 ============ */
.fab-ingot {
  position: fixed;
  right: 50rpx;
  bottom: calc(0rpx + env(safe-area-inset-bottom));
  width: 100rpx;
  height: 100rpx;
  background: transparent;
  border: 2rpx solid var(--accent);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: transparent;
  /* 书脊：中间一条细线 */
  background-image: linear-gradient(var(--accent), var(--accent));
  background-repeat: no-repeat;
  background-size: 2rpx 44rpx;
  background-position: 50% 52%;
  box-shadow: 0 6rpx 24rpx rgba(168, 144, 122, 0.45);
  animation: fab-float 3s ease-in-out infinite;
  z-index: 100;
  box-sizing: border-box;
}
.fab-ingot:active {
  transform: scale(0.88);
}

/* 中间“一本翻开的书”（纯 CSS 伪元素绘制） */
.fab-ingot::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 52%;
  width: 32rpx;
  height: 44rpx;
  transform: translate(-50%, -50%);
  margin-left: -16rpx;
  box-sizing: border-box;
  border: 2rpx solid var(--accent);
  border-right: none;
  border-radius: 6rpx 0 0 6rpx;
  background: rgba(168, 144, 122, 0.10);
}
.fab-ingot::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 52%;
  width: 32rpx;
  height: 44rpx;
  transform: translate(-50%, -50%);
  margin-left: 16rpx;
  box-sizing: border-box;
  border: 2rpx solid var(--accent);
  border-left: none;
  border-radius: 0 6rpx 6rpx 0;
  background: rgba(168, 144, 122, 0.06);
}
@keyframes fab-float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

/* ============ 暗色模式 ============ */
.dark-theme .spinner {
  border-color: var(--bg-dark-surface-3);
  border-top-color: var(--accent);
}

.dark-theme .tag-quote {
  background: #3A3028;
  color: #C0A080;
}

.dark-theme .tag-note {
  background: #202838;
  color: #8098C0;
}

.dark-theme .tag-thought {
  background: #2A2A2A;
  color: #A0A0A0;
}

.dark-theme .shelf-empty__btn {
  background: var(--accent);
}

.dark-theme .arrow-icon {
  color: var(--accent);
}

.dark-theme .arrow-icon--done {
  color: var(--text-light);
}
