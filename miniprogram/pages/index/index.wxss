.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
}

.weui-btn_mini {
  margin-left: 20rpx;
}

.hero {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 18rpx;
  /* 阴影由全局 weui-panel/weui-cells 统一，这里不重复 */
}

.hero-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #111;
}

.hero-sub {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #666;
}

.hero-actions {
  margin-top: 18rpx;
  display: flex;
  gap: 16rpx;
}

.list-card {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  /* 阴影由全局 weui-panel/weui-cells 统一，这里不重复 */
}

.cell-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111;
}

.cell-sub {
  margin-top: 6rpx;
  font-size: 26rpx;
  color: #999;
}

.fab {
  margin-top: 18rpx;
}

.slide-row {
  overflow: hidden;
}

.slide-btn-delete {
  background: #e64340;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 0 40rpx;
  font-size: 30rpx;
  font-weight: 600;
}