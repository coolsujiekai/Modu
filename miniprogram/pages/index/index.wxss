.page {
  min-height: 100vh;
  padding: 32rpx 32rpx 40rpx;
}

.hero {
  background: linear-gradient(180deg, #fffdf9 0%, #ffffff 100%);
  border-radius: 20rpx;
  padding: 24rpx 22rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #EDE8E0;
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2D2A26;
}

.hero-count {
  flex: none;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #F3ECE2;
  color: #8B7355;
  font-size: 24rpx;
  font-weight: 600;
}

.hero-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8C8279;
}

.cover-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx 20rpx;
}

.list-card {
  background: #ffffff;
  border-radius: 18rpx;
  border: 1rpx solid #EDE8E0;
  overflow: hidden;
}

.list-cells {
  margin-top: 0 !important;
}

.list-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2A26;
}

.list-add {
  color: #8B7355;
  font-size: 28rpx;
  font-weight: 600;
}

.cover-item {
  border-radius: 18rpx;
  overflow: hidden;
}

.book-cover-large,
.add-cover {
  height: 368rpx;
  border-radius: 18rpx;
  background: #FAF8F5;
  border: 1rpx solid #E6DDD2;
}

.book-cover-large {
  width: 100%;
  padding: 24rpx 20rpx 20rpx 30rpx;
  box-sizing: border-box;
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  border: 1rpx solid #E6DDD2;
  position: relative;
  overflow: hidden;
}

.cover-spine {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 10rpx;
  background: rgba(109, 90, 70, 0.12);
  border-right: 1rpx solid rgba(109, 90, 70, 0.16);
}

.cover-text-large {
  font-size: 30rpx;
  line-height: 1.45;
  font-weight: 600;
  color: #6D5A46;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 6;
  overflow: hidden;
  word-break: break-all;
}

.cover-tone-1 {
  background: linear-gradient(160deg, #F8F1E7 0%, #EFE3D4 100%);
}

.cover-tone-2 {
  background: linear-gradient(160deg, #F2EFE6 0%, #E7E2D6 100%);
}

.cover-tone-3 {
  background: linear-gradient(160deg, #F6ECE4 0%, #ECDCCF 100%);
}

.cover-tone-4 {
  background: linear-gradient(160deg, #F1EDE9 0%, #E5DFD8 100%);
}

.cover-tone-5 {
  background: linear-gradient(160deg, #F4EFEA 0%, #E8E1D8 100%);
}

.add-cover {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #FFFCF8;
  border-style: dashed;
  border-color: #DCCFBE;
}

.add-plus {
  width: 86rpx;
  height: 86rpx;
  border-radius: 999rpx;
  background: #F3ECE2;
  color: #8B7355;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  line-height: 1;
}

.add-text {
  margin-top: 18rpx;
  font-size: 28rpx;
  color: #8B7355;
  font-weight: 600;
}

.tap-active {
  opacity: 0.86;
}