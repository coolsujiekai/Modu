@import "/styles/theme.wxss";
@import "/styles/common.wxss";

.page.home-page {
  min-height: 100vh;
  background: #FAFAF8;
  padding: 0 40rpx;
}

/* ============ 打卡横幅 ============ */
.checkin-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: var(--accent-light);
  border: 1rpx solid var(--border-gold-light);
  border-radius: var(--radius-lg);
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-xs);
  transition: opacity 0.2s;
}

.checkin-banner:active {
  opacity: 0.85;
}

.checkin-banner--done {
  background: var(--bg-surface-soft);
  border-color: var(--border-soft);
  box-shadow: none;
}

.checkin-banner__left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.checkin-banner__icon {
  font-size: 28rpx;
}

.checkin-banner__text {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--accent);
}

.checkin-banner--done .checkin-banner__text {
  color: var(--text-light);
}

.checkin-banner__right {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.checkin-banner__streak {
  font-size: 22rpx;
  color: var(--text-light);
}

[data-weui-theme="dark"] .checkin-banner {
  background: var(--bg-dark-surface-2);
  border-color: var(--border-dark);
}

[data-weui-theme="dark"] .checkin-banner__text {
  color: var(--text-dark-highlight);
}

[data-weui-theme="dark"] .checkin-banner--done {
  background: var(--bg-dark-surface-3);
}

/* ============ 顶部状态栏占位 ============ */
.top-bar {
  height: calc(var(--status-bar-height) + 16rpx);
}

/* ============ 书架区域 ============ */
.shelf-section {
  padding-bottom: 8rpx;
}

.shelf-header {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  margin-bottom: 32rpx;
}

.shelf-label {
  font-size: 44rpx;
  font-weight: 700;
  color: #1A1A1A;
  letter-spacing: -0.03em;
}

.shelf-count {
  font-size: 24rpx;
  color: #9A9A9A;
  font-weight: 400;
}

.shelf-loading {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

/* ============ 空书架 ============ */
.shelf-empty {
  padding: 40rpx 0;
}

.shelf-empty__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 0;
}

.shelf-empty__icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 20rpx;
  opacity: 0.4;
}

.shelf-empty__text {
  font-size: 28rpx;
  color: #B0B0B0;
  display: block;
  margin-bottom: 32rpx;
}

.shelf-empty__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 40rpx;
  border-radius: 999rpx;
  background: #8B7355;
  color: #fff;
  font-size: 26rpx;
  font-weight: 500;
}

/* ============ 箭头图标 ============ */
.arrow-icon {
  font-size: 24rpx;
  color: #8B7355;
  font-weight: 300;
  line-height: 1;
}

.arrow-icon--done {
  color: #9A9A96;
}

/* ============ 加载旋转 ============ */
.spinner {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid #EEEDEA;
  border-top-color: #8B7355;
  border-radius: 999rpx;
  animation: spin 0.7s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ============ 笔记类型标签 ============ */
.note-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 500;
  line-height: 1.6;
}

.tag-quote {
  background: #FFF6E8;
  color: #C8871A;
}

.tag-note {
  background: #E8F0FF;
  color: #4A7EC7;
}

.tag-thought {
  background: #F0F0F0;
  color: #8A8A8A;
}

/* ============ 书籍行 ============ */
.book-row {
  display: flex;
  gap: 28rpx;
  overflow-x: auto;
  padding-bottom: 12rpx;
  margin: 0 -40rpx;
  padding-left: 40rpx;
  padding-right: 40rpx;
  -webkit-overflow-scrolling: touch;
}

.book-row::-webkit-scrollbar {
  display: none;
}

.book-item {
  flex: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

/* ============ 书籍封面 ============ */
.book-cover {
  position: relative;
  width: 120rpx;
  height: 168rpx;
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.10), 0 1rpx 4rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: stretch;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.book-item:active .book-cover {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.book-cover__left-bar {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: rgba(0, 0, 0, 0.12);
  z-index: 1;
}

.book-cover__content {
  flex: 1;
  padding: 14rpx 12rpx 14rpx 18rpx;
  display: flex;
  align-items: flex-start;
  z-index: 2;
}

.book-cover__title {
  font-size: 22rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #2C2C2C;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
  overflow: hidden;
  word-break: break-word;
}

.book-cover--add {
  background: #F0EFED !important;
  border: 1.5rpx dashed #CFCFC9 !important;
  align-items: center;
  justify-content: center;
  box-shadow: none !important;
}

.book-cover__plus {
  font-size: 48rpx;
  color: #B0B0B0;
  font-weight: 300;
  line-height: 1;
}

/* 封面配色 */
.book-cover.cover-tone-1 { background: linear-gradient(155deg, #F2F4FF 0%, #E8EDFF 100%); }
.book-cover.cover-tone-2 { background: linear-gradient(155deg, #F5F6FA 0%, #EDF1F7 100%); }
.book-cover.cover-tone-3 { background: linear-gradient(155deg, #FFF3EC 0%, #FFE8DF 100%); }
.book-cover.cover-tone-4 { background: linear-gradient(155deg, #F3FFF6 0%, #E4F8EC 100%); }
.book-cover.cover-tone-5 { background: linear-gradient(155deg, #F8F4FF 0%, #EEE6FF 100%); }

/* ============ 书名 ============ */
.book-name {
  font-size: 22rpx;
  color: #2C2C2C;
  font-weight: 500;
  text-align: center;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.book-name--muted {
  color: #B0B0B0;
  font-weight: 400;
}

/* ============ 分隔线 ============ */
.divider {
  height: 1rpx;
  background: #EBEBEB;
  margin: 40rpx 0;
}

/* ============ 笔记区域 ============ */
.notes-section {
  padding-bottom: 20rpx;
}

.notes-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.notes-label {
  font-size: 44rpx;
  font-weight: 700;
  color: #1A1A1A;
  letter-spacing: -0.03em;
}

.notes-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: #9A9A9A;
}

.notes-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.note-item {
  padding: 28rpx 32rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.note-item__top {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.note-item__book {
  font-size: 22rpx;
  color: #9A9A9A;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.note-item__text {
  font-size: 28rpx;
  line-height: 1.7;
  color: #1A1A1A;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  word-break: break-word;
}

.note-item__time {
  display: block;
  margin-top: 12rpx;
  font-size: 21rpx;
  color: #C0C0C0;
}

/* ============ 安全区 ============ */
.safe-area {
  height: calc(env(safe-area-inset-bottom) + 24rpx);
}

/* ============ 暗色模式 ============ */
[data-weui-theme="dark"] .spinner {
  border-color: #3A3A3A;
  border-top-color: #B0A088;
}

[data-weui-theme="dark"] .tag-quote {
  background: #3D2E1A;
  color: #E0A840;
}

[data-weui-theme="dark"] .tag-note {
  background: #1A2A3D;
  color: #7AA8E0;
}

[data-weui-theme="dark"] .tag-thought {
  background: #2A2A2A;
  color: #A0A0A0;
}

[data-weui-theme="dark"] .shelf-empty__btn {
  background: #8B7355;
}

[data-weui-theme="dark"] .arrow-icon {
  color: #B0A088;
}

[data-weui-theme="dark"] .arrow-icon--done {
  color: #6A6A6A;
}

