.page {
  min-height: 100vh;
  padding: 32rpx 32rpx 40rpx;
}

.weui-btn_mini {
  margin-left: 20rpx;
}

.hero {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #EDE8E0;
}

.hero-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #2D2A26;
}

.hero-sub {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #8C8279;
}

.hero-actions {
  margin-top: 18rpx;
  display: flex;
  gap: 16rpx;
}

.list-card {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid #EDE8E0;
}

.book-cover {
  width: 120rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: #FAF8F5;
  margin-right: 18rpx;
}

.cell-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D2A26;
}

.cell-sub {
  margin-top: 6rpx;
  font-size: 26rpx;
  color: #8C8279;
}

.fab {
  margin-top: 24rpx;
}

.slide-row {
  overflow: hidden;
}

.slide-btn-delete {
  background: #C07D6B;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 0 40rpx;
  font-size: 30rpx;
  font-weight: 600;
}