<view class="page">
  <view class="hero">
    <view class="hero-top">
      <view class="hero-title">正在阅读</view>
      <view class="hero-count">{{readingCount}} 本</view>
    </view>
    <view class="hero-sub">{{heroSub}}</view>
  </view>

  <block wx:if="{{loading}}">
    <view class="weui-msg">
      <view class="weui-msg__icon-area">
        <text style="font-size: 84rpx;">⏳</text>
      </view>
      <view class="weui-msg__title">正在整理书架…</view>
    </view>
  </block>

  <block wx:elif="{{readingBooks.length === 0}}">
    <view class="weui-msg">
      <view class="weui-msg__icon-area">
        <text style="font-size: 84rpx;">📖</text>
      </view>
      <view class="weui-msg__title">今天想读哪一本？</view>
      <view class="weui-msg__desc">先把第一本放进书架</view>
      <view class="weui-msg__opr-area">
        <button class="weui-btn weui-btn_primary" bindtap="startReading">新增第一本</button>
      </view>
    </view>
  </block>

  <block wx:else>
    <block wx:if="{{homeViewMode === 'grid'}}">
      <view class="cover-grid">
        <view wx:for="{{readingBooks}}" wx:key="_id" class="cover-item" catchtap="openBook" bindlongpress="onBookLongPress" data-id="{{item._id}}" data-name="{{item.bookName}}" hover-class="tap-active" hover-stay-time="70">
          <view class="book-cover-large {{item.coverToneClass}}">
            <view class="cover-spine"></view>
            <text class="cover-text-large">{{item.coverText}}</text>
          </view>
        </view>

        <view class="cover-item" catchtap="startReading" hover-class="tap-active" hover-stay-time="70">
          <view class="add-cover">
            <view class="add-plus">+</view>
            <view class="add-text">新增一本</view>
          </view>
        </view>
      </view>
    </block>
    <block wx:else>
      <view class="list-card">
        <view class="weui-cells list-cells">
          <view wx:for="{{readingBooks}}" wx:key="_id" class="weui-cell weui-cell_access" catchtap="openBook" bindlongpress="onBookLongPress" data-id="{{item._id}}" data-name="{{item.bookName}}" hover-class="tap-active" hover-stay-time="70">
            <view class="weui-cell__bd">
              <view class="list-title">{{item.bookName}}</view>
            </view>
            <view class="weui-cell__ft"></view>
          </view>
          <view class="weui-cell weui-cell_access" catchtap="startReading" hover-class="tap-active" hover-stay-time="70">
            <view class="weui-cell__bd list-add">+ 新增一本</view>
            <view class="weui-cell__ft"></view>
          </view>
        </view>
      </view>
    </block>
  </block>
</view>