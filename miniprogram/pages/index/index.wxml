<view class="page home-page">
  <!-- 主 Hero：继续阅读 / 记录入口 -->
  <view class="home-hero hero">
    <view class="home-hero__hd">
      <view class="home-hero__title">{{primaryBook ? '上次你读了：' : '开始今天的阅读'}}</view>
      <view class="home-hero__sub ">
        <block wx:if="{{primaryBook}}">
          《{{primaryBook.bookName}}》
        </block>
        <block wx:else>
          从一本书开始，把触动你的句子记下来
        </block>
      </view>
    </view>
    <view class="home-hero__actions">
      <block wx:if="{{primaryBook}}">
        <button class="weui-btn weui-btn_primary home-hero__btn" bindtap="onQuickRecordTap">快速记录</button>
        <button class="weui-btn weui-btn_default home-hero__btn" bindtap="openPrimaryBook">打开书籍</button>
      </block>
      <block wx:else>
        <button class="weui-btn weui-btn_primary home-hero__btn" bindtap="startReading">添加书籍</button>
      </block>
    </view>
  </view>

  <!-- 在读书架 -->
  <block wx:if="{{loading}}">
    <view class="weui-msg">
      <view class="weui-msg__icon-area">
        <text style="font-size: 84rpx;">⏳</text>
      </view>
      <view class="weui-msg__title">正在整理书架…</view>
    </view>
  </block>

  <block wx:elif="{{readingBooks.length === 0}}">
    <view class="home-empty muted">书架还空着。添加一本书后，这里会出现“在读书架”。</view>
  </block>

  <block wx:else>
    <view class="shelf-head">
      <text class="shelf-title">在读</text>
      <text class="shelf-count">{{readingCount}} 本</text>
    </view>
    <scroll-view class="shelf-scroll" scroll-x="{{true}}" show-scrollbar="{{false}}" enhanced="{{true}}">
      <view class="shelf-inner">
        <view
          wx:for="{{readingBooks}}"
          wx:key="_id"
          class="shelf-item"
          catchtap="openBook"
          bindlongpress="onBookLongPress"
          data-id="{{item._id}}"
          data-name="{{item.bookName}}"
          hover-class="tap-active"
          hover-stay-time="70"
        >
          <view class="shelf-cover {{item.coverToneClass}}">
            <view class="shelf-cover__spine"></view>
            <view class="shelf-cover__inner">
              <text class="shelf-cover__title">{{item.bookName}}</text>
            </view>
          </view>
   
        </view>

        <view
          class="shelf-item"
          catchtap="startReading"
          hover-class="tap-active"
          hover-stay-time="70"
        >
          <view class="shelf-add">
            <view class="shelf-add__plus">+</view>
          </view>
          
        </view>
      </view>
    </scroll-view>
  </block>

  <!-- 最近记录 -->
  <view wx:if="{{recentNotes.length > 0}}" class="recent-section">
    <view class="recent-head">
      <text class="recent-title">最近记录</text>
    </view>
    <view class="recent-list">
      <view
        wx:for="{{recentNotes}}"
        wx:key="key"
        class="recent-item"
        catchtap="onRecentNoteTap"
        data-bookid="{{item.bookId}}"
        data-text="{{item.text}}"
        data-key="{{item.key}}"
        hover-class="tap-active"
        hover-stay-time="70"
      >
        <view class="recent-item__text">
          <text>{{item.text}}</text>
        </view>
        <view class="recent-item__meta">
          <text class="recent-item__book">《{{item.bookName}}》</text>
          <text class="recent-item__time">{{item.timeText}}</text>
        </view>
      </view>
    </view>
  </view>

</view>
