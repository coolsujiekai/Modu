<view class="page home-page">
  <!-- 顶部间距 -->
  <view class="top-bar"></view>

  <!-- 打卡横幅 -->
  <view class="checkin-banner {{checkin.checkedIn ? 'checkin-banner--done' : ''}}" bindtap="goChallenge">
    <view class="checkin-banner__left">
      <text class="checkin-banner__icon">{{checkin.checkedIn ? '✅' : '📖'}}</text>
      <text class="checkin-banner__text">{{checkin.checkedIn ? '今日已打卡' : '打卡记录今天的阅读'}}</text>
    </view>
    <view class="checkin-banner__right">
      <text class="checkin-banner__streak">连续 {{checkin.streak}} 天</text>
      <text class="arrow-icon {{checkin.checkedIn ? 'arrow-icon--done' : ''}}">›</text>
    </view>
  </view>

  <!-- 书架区域 -->
  <view class="shelf-section">
    <view class="shelf-header">
      <text class="shelf-label">在读</text>
      <text class="shelf-count" wx:if="{{readingCount > 0}}">{{readingCount}} 本</text>
    </view>

    <view wx:if="{{loading}}" class="shelf-loading">
      <view class="spinner"></view>
    </view>

    <view wx:if="{{!loading && readingBooks.length === 0}}" class="shelf-empty">
      <view class="shelf-empty__inner">
        <text class="shelf-empty__icon">📚</text>
        <text class="shelf-empty__text">书架空无一书</text>
        <view class="shelf-empty__btn" bindtap="startReading">添加第一本</view>
      </view>
    </view>

    <view wx:if="{{readingBooks.length > 0}}" class="book-row">
      <view
        wx:for="{{readingBooks}}"
        wx:key="_id"
        class="book-item"
        bindtap="openBook"
        data-id="{{item._id}}"
      >
        <!-- 封面 -->
        <view class="book-cover {{item.coverToneClass}}">
          <view class="book-cover__left-bar"></view>
          <view class="book-cover__content">
            <text class="book-cover__title">{{item.bookName}}</text>
          </view>
        </view>
       
      </view>

      <!-- 加书 -->
      <view class="book-item" bindtap="startReading">
        <view class="book-cover book-cover--add">
          <text class="book-cover__plus">+</text>
        </view>
  
      </view>
    </view>
  </view>

  <!-- 分隔线 -->
  <view class="divider" wx:if="{{readingBooks.length > 0 || recentNotes.length > 0}}"></view>

  <!-- 最近笔记 -->
  <view class="notes-section" wx:if="{{recentNotes.length > 0}}">
    <view class="notes-header">
      <text class="notes-label">最近笔记</text>
      <view class="notes-more" bindtap="goHistory">
        <text>全部</text>
        <text class="arrow-icon">›</text>
      </view>
    </view>

    <view class="notes-list">
      <view wx:for="{{recentNotes}}" wx:key="key" class="slide-row">
        <slideview buttons="{{item.slideButtons}}" bind:buttontap="onRecentNoteSlideButtonTap" data-ts="{{item.timestamp}}" data-bookid="{{item.bookId}}">
          <view
            class="note-item"
            catchtap="onRecentNoteTap"
            data-bookid="{{item.bookId}}"
            data-text="{{item.text}}"
            data-key="{{item.key}}"
          >
            <view class="note-item__top">
              <view class="note-tag tag-quote" wx:if="{{item.type === 'quote'}}">金句</view>
              <view class="note-tag tag-note" wx:elif="{{item.type === 'note'}}">笔记</view>
              <view class="note-tag tag-thought" wx:else>心得</view>
              <text class="note-item__book">{{item.bookName}}</text>
            </view>
            <text class="note-item__text">{{item.text}}</text>
            <text class="note-item__time">{{item.timeText}}</text>
          </view>
        </slideview>
      </view>
    </view>
  </view>

  <!-- 底部安全区 -->
  <view class="safe-area"></view>
</view>
