<view class="page">
  <block wx:if="{{loading}}">
    <view class="weui-msg">
      <view class="weui-msg__icon-area"><text style="font-size: 80rpx;">⏳</text></view>
      <view class="weui-msg__title">加载中</view>
    </view>
  </block>

  <block wx:elif="{{!book}}">
    <view class="weui-msg">
      <view class="weui-msg__icon-area"><text style="font-size: 80rpx;">📚</text></view>
      <view class="weui-msg__title">没找到这本书</view>
      <view class="weui-msg__desc">可能已被删除或网络异常</view>
    </view>
  </block>

  <block wx:else>
    <view class="weui-panel header-panel">
      <view class="weui-panel__hd header-hd">
        <view class="header-title">{{book.bookName}}</view>
        <view class="header-sub muted">{{typeText}} · 共 {{notes.length}} 条</view>
      </view>
    </view>

    <view class="weui-cells" style="margin-top: 0;">
      <block wx:if="{{notes.length === 0}}">
        <view class="weui-cell">
          <view class="weui-cell__bd muted">还没有{{typeText}}</view>
        </view>
      </block>
      <view wx:for="{{notes}}" wx:key="timestamp" class="slide-row">
        <slideview buttons="{{item.slideButtons}}" bind:buttontap="onSlideButtonTap" data-ts="{{item.timestamp}}" data-text="{{item.text}}">
          <view class="weui-cell note-cell">
            <view class="weui-cell__bd">
              <view class="corner-tag corner-tag--{{item.type}}">
                <text class="corner-tag__text">{{item.type === 'quote' ? '摘' : '思'}}</text>
              </view>
              <view
                class="note-text"
                style="white-space: pre-wrap;"
                bindtap="onNoteDoubleTapCopy"
                data-ts="{{item.timestamp}}"
                data-text="{{item.text}}"
              >{{item.text}}</view>
              <view class="note-meta muted">{{item.timeText}}</view>
            </view>
          </view>
        </slideview>
      </view>
    </view>
  </block>
</view>

