.page {
  min-height: 100vh;
  padding: 32rpx 32rpx 40rpx;
}

.muted {
  color: #8C8279;
  font-size: 26rpx;
}

.header-panel {
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: none;
  border: 1rpx solid #EDE8E0;
}

.header-hd {
  padding: 18rpx 18rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D2A26;
}

.header-sub {
  margin-top: 6rpx;
}

.note-meta {
  margin-top: 10rpx;
}

.row-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.btn-link {
  color: #8B7355;
  font-size: 26rpx;
}

