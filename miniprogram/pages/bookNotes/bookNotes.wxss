@import "/styles/theme.wxss";
@import "/styles/common.wxss";

.page {
  min-height: 100vh;
}

.muted {
  color: var(--text-warm-muted);
  font-size: 24rpx;
}

.header-panel {
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 1rpx solid var(--border-warm);
}

.header-hd {
  padding: 16rpx 16rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-title);
}

.header-sub {
  margin-top: 16rpx;
}

.note-meta {
  margin-top: 16rpx;
}

.note-text {
  font-size: 26rpx;
  line-height: 1.65;
  color: var(--text-title);
  word-break: break-word;
}

.note-meta.muted {
  font-size: 22rpx;
  color: var(--text-light);
}

.row-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.btn-link {
  color: var(--text-accent);
  font-size: 24rpx;
}

.slide-row {
  overflow: hidden;
}

.slide-btn-delete {
  background: var(--text-danger);
  color: var(--button-text);
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 0 32rpx;
  font-size: 32rpx;
  font-weight: 600;
}

