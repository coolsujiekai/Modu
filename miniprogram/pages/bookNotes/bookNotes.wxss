@import "/styles/theme.wxss";
@import "/styles/common.wxss";

.page {
  min-height: 100vh;
}

.muted {
  color: var(--text-light);
  font-size: 24rpx;
}

.header-panel {
  border-radius: var(--radius-xl);
  overflow: hidden;
  border: 1rpx solid var(--border-soft);
  box-shadow: var(--shadow-card);
}

.header-hd {
  padding: 16rpx 16rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-title);
  letter-spacing: -0.02em;
}

.header-sub {
  margin-top: 16rpx;
}

.note-meta {
  margin-top: 16rpx;
}

.note-text {
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--text-title);
  word-break: break-word;
}

.note-meta.muted {
  font-size: 22rpx;
  color: var(--text-light);
}

.note-cell {
  position: relative;
  overflow: hidden;
}

.corner-tag {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 72rpx;
  height: 72rpx;
  pointer-events: none;
}

.corner-tag--quote {
  background: linear-gradient(315deg, var(--bg-surface-tag) 0 50%, transparent 50%);
}

.corner-tag--thought {
  background: linear-gradient(315deg, var(--bg-surface-subtle) 0 50%, transparent 50%);
}

.corner-tag__text {
  position: absolute;
  bottom: 10rpx;
  right: 10rpx;
  font-size: 18rpx;
  line-height: 1;
  color: var(--text-secondary);
  font-weight: 700;
  letter-spacing: 0.04em;
}

.corner-tag--quote .corner-tag__text {
  color: var(--accent-strong);
}

.row-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.btn-link {
  color: var(--text-accent);
  font-size: 24rpx;
}

.slide-row {
  overflow: hidden;
}

.slide-btn-delete {
  background: var(--text-danger);
  color: var(--button-text);
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 0 32rpx;
  font-size: 32rpx;
  font-weight: 600;
}

