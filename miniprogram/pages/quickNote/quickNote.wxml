<view class="qn-page">
  <textarea
    class="qn-input"
    placeholder="快速记下刚打动你的那句话，或闪过的念头…"
    value="{{draft}}"
    focus="{{autoFocus && !sheetVisible}}"
    disabled="{{sheetVisible}}"
    maxlength="2000"
    cursor-spacing="120"
    adjust-position="{{false}}"
    bindinput="onDraftInput"
    bindkeyboardheightchange="onKeyboardHeightChange"
    show-confirm-bar="{{false}}"
  />

  <view class="qn-bar" style="bottom: {{barBottom}}px;">
    <view class="qn-bar__top">
      <text class="qn-count">{{draftLength}}/2000</text>
    </view>

    <view class="qn-bar__bottom">
      <button
        class="qn-tool {{isRecording ? 'qn-tool--recording' : ''}}"
        disabled="{{saving}}"
        bindtap="onVoiceToggleTap"
      >
        <view class="qn-tool__icon qn-icon qn-icon--mic"></view>
        <text class="qn-tool__label">{{isRecording ? '停止' : '听写'}}</text>
      </button>

      <button
        class="qn-tool"
        disabled="{{saving}}"
        bindtap="onOcrPick"
      >
        <view class="qn-tool__icon qn-icon qn-icon--camera"></view>
        <text class="qn-tool__label">识字</text>
      </button>

      <button
        class="qn-save {{canNext ? '' : 'qn-save--disabled'}}"
        disabled="{{!canNext || saving}}"
        bindtap="onNext"
      >{{saving ? '保存中…' : '下一步'}}</button>
    </view>
  </view>

  <view wx:if="{{isRecording}}" class="qn-rec-hint" style="bottom: {{barBottom + 100}}px;">
    正在听写…再点一次结束
  </view>

  <half-screen-dialog
    show="{{sheetVisible}}"
    title="保存设置"
    closabled="{{true}}"
    maskClosable="{{true}}"
    rootPortal="{{true}}"
    bind:close="onSheetClose"
    extClass="qn-sheet"
  >
    <view slot="desc" class="qn-sheet__body" catchtap="noop">
      <view class="qn-sheet__section">
        <view class="qn-sheet__sectionTitle">保存到</view>

        <view wx:if="{{fixedBookId}}" class="qn-sheet__single">
          <text>《{{currentBookName || '未命名'}}》</text>
        </view>

        <view wx:elif="{{readingBooks.length === 0}}" class="qn-sheet__empty">
          <view class="qn-sheet__emptyTitle">还没有在读的书</view>
          <view class="qn-sheet__emptySub">新增一本，就能开始记录</view>
          <button class="weui-btn weui-btn_primary qn-sheet__emptyBtn" disabled="{{saving}}" bindtap="onCreateBookFromSheet">新增一本</button>
        </view>

        <view wx:elif="{{readingBooks.length === 1}}" class="qn-sheet__single">
          <text>《{{currentBookName || '未命名'}}》</text>
        </view>

        <view wx:else class="qn-sheet__list">
          <view
            wx:for="{{readingBooks}}"
            wx:key="_id"
            class="qn-sheet__bookItem {{sheetBookId === item._id ? 'qn-sheet__bookItem--active' : ''}}"
            catchtap="onSheetPickBook"
            data-id="{{item._id}}"
            data-name="{{item.bookName}}"
            hover-class="tap-active"
            hover-stay-time="70"
          >
            <view class="qn-sheet__radio">
              <view class="qn-sheet__radioDot {{sheetBookId === item._id ? 'qn-sheet__radioDot--on' : ''}}"></view>
            </view>
            <view class="qn-sheet__bookName">《{{item.bookName || '未命名'}}》</view>
          </view>
        </view>
      </view>

      <view class="qn-sheet__section">
        <view class="qn-sheet__sectionTitle">类型</view>
        <view class="qn-sheet__seg">
          <view class="qn-sheet__segItem {{sheetType === 'quote' ? 'qn-sheet__segItem--active' : ''}}" catchtap="onSheetPickType" data-type="quote">金句</view>
          <view class="qn-sheet__segItem {{sheetType === 'thought' ? 'qn-sheet__segItem--active' : ''}}" catchtap="onSheetPickType" data-type="thought">想法</view>
        </view>
      </view>

      <view class="qn-sheet__section" wx:if="{{challengeActive}}">
        <view class="qn-sheet__sectionTitle">阅读挑战</view>
        <view class="qn-sheet__seg">
          <view class="qn-sheet__segItem {{countToChallenge ? 'qn-sheet__segItem--active' : ''}}" catchtap="onToggleChallenge">计入本次挑战打卡</view>
        </view>
        <view wx:if="{{!joinedChallenge}}" class="qn-sheet__challenge-hint">需要先报名挑战才能计入 <text class="link" catchtap="goJoinChallenge">去报名</text></view>
      </view>
    </view>

    <view slot="footer" class="qn-sheet__footer" catchtap="noop">
      <button
        class="weui-btn weui-btn_primary qn-sheet__confirmBtn {{(sheetBookId && draftHasText) ? '' : 'qn-sheet__confirmBtn--disabled'}}"
        disabled="{{saving || !sheetBookId || !draftHasText}}"
        bindtap="onSheetConfirmSave"
      >确认保存</button>
    </view>
  </half-screen-dialog>
</view>
