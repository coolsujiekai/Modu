@import "/styles/theme.wxss";

.qn-page {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
  background: var(--bg-primary);
  display: flex;
  flex-direction: column;
}

.qn-input {
  flex: 1;
  width: 100%;
  padding: 48rpx 42rpx 340rpx;
  box-sizing: border-box;
  font-size: 38rpx;
  line-height: 1.68;
  color: var(--text-title);
  background: var(--bg-surface);
  border: none;
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
  min-height: 0;
}

.qn-input[placeholder] {
  color: var(--text-light);
}

/* ============ 底部工具栏 ============ */
.qn-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  border: none;
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-floating);
  padding: 22rpx 26rpx;
  padding-bottom: calc(22rpx + env(safe-area-inset-bottom));
  transition: bottom 0.2s ease;
  z-index: 10;
  backdrop-filter: blur(24rpx);
}

.qn-bar__top {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.qn-target {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  margin: -12rpx -16rpx;
  border-radius: var(--radius-md);
  font-size: 26rpx;
  color: var(--text-title);
  transition: opacity 0.15s ease;
}

.qn-target--active {
  background: var(--tap-active-bg);
  opacity: 1;
}

.qn-target__prefix {
  color: var(--text-warm-muted);
  font-size: 26rpx;
}

.qn-target__name {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 600;
}

.qn-target__empty {
  flex: 1;
  color: var(--text-light);
}

.qn-target__arrow {
  flex: none;
  font-size: 22rpx;
  color: var(--text-accent);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  background: var(--bg-surface-tag);
}

.qn-count {
  flex: none;
  font-size: 22rpx;
  color: var(--text-light);
}

/* ============ 类型 + 保存 ============ */
.qn-bar__bottom {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.qn-tool {
  flex: 1;
  margin: 0 !important;
  padding: 0 16rpx !important;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx !important;
  background: var(--bg-surface-muted) !important;
  color: var(--text-title) !important;
  font-size: 24rpx !important;
  font-weight: 650 !important;
  border: none !important;
  box-shadow: var(--shadow-soft);
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  gap: 8rpx !important;
  min-width: 0;
}

.qn-tool::after {
  border: none;
}

.qn-tool:active {
  background: var(--tap-active-bg) !important;
  transform: scale(0.985);
}

.qn-tool[disabled] {
  opacity: 0.6;
}

.qn-tool__icon {
  width: 36rpx;
  height: 36rpx;
}

.qn-tool__label {
  font-size: 24rpx;
  line-height: 1;
  color: var(--text-warm-muted);
}

.qn-tool--recording {
  background: var(--border-gold-light) !important;
  border-color: var(--border-gold-soft) !important;
}

.qn-tool--recording .qn-tool__label {
  color: var(--text-title);
}

.qn-icon {
  position: relative;
  display: inline-block;
  width: 36rpx;
  height: 36rpx;
}

/* 最简单的线条图案：纯 CSS 画麦克风 */
.qn-icon--mic::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 6rpx;
  width: 16rpx;
  height: 20rpx;
  transform: translateX(-50%);
  border: 3rpx solid currentColor;
  border-radius: 10rpx;
  box-sizing: border-box;
}

.qn-icon--mic::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 28rpx;
  width: 22rpx;
  height: 8rpx;
  transform: translateX(-50%);
  border-bottom: 3rpx solid currentColor;
  border-left: 3rpx solid transparent;
  border-right: 3rpx solid transparent;
  box-sizing: border-box;
}

/* 最简单的线条图案：纯 CSS 画相机 */
.qn-icon--camera::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 9rpx;
  width: 26rpx;
  height: 18rpx;
  transform: translateX(-50%);
  border: 3rpx solid currentColor;
  border-radius: 6rpx;
  box-sizing: border-box;
}

.qn-icon--camera::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 14rpx;
  width: 10rpx;
  height: 10rpx;
  transform: translateX(-50%);
  border: 3rpx solid currentColor;
  border-radius: 999rpx;
  box-sizing: border-box;
  background: transparent;
}

.qn-rec-hint {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(28, 28, 30, 0.84);
  color: rgba(255, 255, 255, 0.92);
  font-size: 24rpx;
  text-align: center;
  z-index: 12;
  backdrop-filter: blur(12rpx);
}

/* ============ half-screen-dialog 内容 ============ */
.qn-sheet .weui-half-screen-dialog__bd {
  padding-top: 0;
}

.qn-sheet .weui-half-screen-dialog,
.qn-sheet .weui-half-screen-dialog__wrp,
.qn-sheet .weui-half-screen-dialog__hd,
.qn-sheet .weui-half-screen-dialog__bd,
.qn-sheet .weui-half-screen-dialog__ft {
  background: var(--bg-surface);
}

.qn-sheet .weui-half-screen-dialog {
  border-top-left-radius: 36rpx;
  border-top-right-radius: 36rpx;
  overflow: hidden;
  box-shadow: var(--shadow-modal);
}

.qn-sheet .weui-half-screen-dialog__hd {
  padding-top: 20rpx;
}

.qn-sheet__body {
  padding: 0 32rpx 24rpx;
}

.qn-sheet__section {
  padding: 24rpx 0;
  border-bottom: none;
}

.qn-sheet__section:last-child {
  border-bottom: none;
}

.qn-sheet__sectionTitle {
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 14rpx;
  letter-spacing: 0.01em;
}

.qn-sheet__empty {
  padding: 24rpx 22rpx 18rpx;
  border-radius: var(--radius-lg);
  background: var(--bg-surface-soft);
  border: none;
  box-shadow: var(--shadow-soft);
}

.qn-sheet__emptyTitle {
  font-size: 28rpx;
  font-weight: 650;
  color: var(--text-title);
}

.qn-sheet__emptySub {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 6rpx;
  margin-bottom: 14rpx;
}

.qn-sheet__emptyBtn {
  margin: 0 !important;
}

.qn-sheet__single {
  padding: 20rpx 22rpx;
  border-radius: var(--radius-lg);
  background: var(--bg-surface-soft);
  border: none;
  box-shadow: var(--shadow-soft);
  font-size: 28rpx;
  color: var(--text-title);
  font-weight: 650;
}

.qn-sheet__list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.qn-sheet__bookItem {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx;
  border-radius: var(--radius-lg);
  background: var(--bg-surface-soft);
  border: none;
  box-shadow: var(--shadow-soft);
}

.qn-sheet__bookItem--active {
  background: rgba(10, 132, 255, 0.08);
  box-shadow: 0 10rpx 24rpx rgba(10, 132, 255, 0.12);
}

.qn-sheet__radio {
  width: 32rpx;
  height: 32rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(60, 60, 67, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
}

.qn-sheet__radioDot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: transparent;
}

.qn-sheet__radioDot--on {
  background: var(--accent);
}

.qn-sheet__bookName {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 28rpx;
  color: var(--text-title);
  font-weight: 650;
}

.qn-sheet__seg {
  display: flex;
  gap: 10rpx;
  padding: 6rpx;
  border-radius: 999rpx;
  background: var(--bg-surface-muted);
  border: none;
}

.qn-sheet__segItem {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: var(--text-light);
  font-weight: 650;
  background: rgba(17, 17, 17, 0.03);
  box-shadow: none;
  border: 1rpx solid transparent;
  transition: background 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease,
    color 0.18s ease, transform 0.18s ease;
}

.qn-sheet__segItem--active {
  background: var(--bg-surface);
  color: var(--text-title);
  border-color: rgba(10, 132, 255, 0.22);
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.10);
  transform: translateY(-1rpx);
}

.qn-sheet__footer {
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
}

.qn-sheet__confirmBtn {
  margin: 0 !important;
  border-radius: var(--radius-lg) !important;
  box-shadow: 0 12rpx 28rpx rgba(10, 132, 255, 0.22);
}

.qn-sheet__confirmBtn--disabled {
  opacity: 0.6;
}

.qn-type {
  flex: none;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 22rpx;
  border-radius: var(--radius-md);
  background: var(--bg-surface-subtle);
  border: 1rpx solid transparent;
  transition: background 0.15s ease, border-color 0.15s ease;
}

.qn-type__icon {
  font-size: 26rpx;
  line-height: 1;
}

.qn-type__label {
  font-size: 26rpx;
  color: var(--text-warm-muted);
  font-weight: 500;
}

.qn-type--active {
  background: var(--border-gold-light);
  border-color: var(--border-gold-soft);
}

.qn-type--active .qn-type__label {
  color: var(--text-title);
  font-weight: 600;
}

.qn-save {
  flex: 1;
  margin: 0 !important;
  padding: 0 !important;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx !important;
  background: var(--button-bg) !important;
  color: var(--button-text) !important;
  font-size: 28rpx !important;
  font-weight: 700 !important;
  letter-spacing: var(--btn-letter-spacing);
  border: none !important;
  box-shadow: 0 12rpx 26rpx rgba(10, 132, 255, 0.22);
}

.qn-save::after {
  border: none;
}

.qn-save:active {
  background: var(--btn-active-bg-primary) !important;
  transform: scale(0.982);
}

.qn-save--disabled {
  background: var(--border-light) !important;
  color: var(--text-light) !important;
  box-shadow: none !important;
}

.qn-sheet__challenge-hint {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 8rpx;
}

.qn-sheet__challenge-hint .link {
  color: var(--primary);
  font-weight: 600;
}
