<view class="page {{isDark ? 'dark-theme' : ''}}" bindtap="onPageTap">
  <view class="hero">
    <view class="hero-row">
      <view class="hero-left">
        <view class="hero-title">书架统计</view>
        <view class="hero-sub">累计读完 {{finishedCount}} 本 · 心得 {{totalThoughts}} 条 · 金句 {{totalQuotes}} 条</view>
      </view>
      <button class="weui-btn weui-btn_mini weui-btn_default hero-mini-btn" bindtap="openReadingStats">统计</button>
    </view>
  </view>

  <block wx:if="{{groupedBooks.length === 0}}">
    <view class="weui-msg">
      <view class="weui-msg__icon-area"><text style="font-size: 80rpx;">📚</text></view>
      <view class="weui-msg__title">还没有读完的书</view>
      <view class="weui-msg__desc">读完后会自动出现在这里</view>
    </view>
  </block>
  <block wx:else>
    <view wx:for="{{groupedBooks}}" wx:for-item="group" wx:key="yearMonth">
      <view class="group-title">
        📅 {{group.yearMonthText}}
      </view>
      <view class="weui-cells cells-no-top-margin">
        <view wx:for="{{group.books}}" wx:for-item="book" wx:key="_id" class="slide-row">
          <slideview
            buttons="{{book.slideButtons}}"
            show="{{openSlideId === book._id}}"
            data-id="{{book._id}}"
            bind:show="onSlideShow"
            bind:hide="onSlideHide"
            bind:buttontap="onFinishedSlideButtonTap"
          >
            <view class="weui-cell weui-cell_access" catchtap="viewBookDetail" data-book="{{book}}">
              <view class="weui-cell__bd">
                <view>{{book.bookName}}</view>
                <view class="book-meta">{{book.endText}} 读完</view>              </view>
            </view>
          </slideview>
        </view>
      </view>
    </view>
  </block>
</view>