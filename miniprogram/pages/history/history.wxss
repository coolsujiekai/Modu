@import "/styles/theme.wxss";
@import "/styles/common.wxss";

.page {
  min-height: 100vh;
}

.top-search {
  position: sticky;
  top: 0;
  z-index: 12;
  background: var(--bg-page);
  padding: 18rpx 18rpx 12rpx;
}

.top-search__box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: var(--bg-surface);
  border: 1rpx solid var(--border-soft);
  border-radius: var(--radius-lg);
  padding: 18rpx 18rpx;
  box-shadow: var(--shadow-soft);
}

.top-search__icon {
  flex: none;
  font-size: 26rpx;
  color: var(--text-light);
  line-height: 1;
}

.top-search__placeholder {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: var(--text-warm-muted);
}

.hero {
  background: var(--bg-surface);
  border-radius: var(--radius-xl);
  padding: 24rpx 22rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid var(--border-soft);
  box-shadow: var(--shadow-card);
}

.hero-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.hero-left {
  flex: 1;
  min-width: 0;
}

.hero-mini-btn.weui-btn {
  flex: none;
  margin: 0;
  padding: 0 18rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.hero-title {
  font-size: 42rpx;
  font-weight: 700;
  color: var(--text-title);
  letter-spacing: -0.02em;
}

.hero-sub {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: var(--text-light);
}

.group-title {
  padding: 16rpx 16rpx 16rpx;
  color: var(--text-light);
  font-size: 24rpx;
  font-weight: 600;
}

.cells-no-top-margin {
  margin-top: 0 !important;
}

.slide-row {
  overflow: hidden;
}

.slide-btn-delete {
  background: var(--text-danger);
  color: var(--button-text);
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 0 32rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.book-meta {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: var(--text-light);
}

.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0 40rpx;
}

.load-more__text {
  font-size: 26rpx;
  color: var(--text-accent);
  font-weight: 600;
}

.load-more__count {
  font-size: 24rpx;
  color: var(--text-light);
  margin-left: 4rpx;
}