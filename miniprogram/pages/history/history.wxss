@import "/styles/theme.wxss";
@import "/styles/common.wxss";

.page {
  min-height: 100vh;
}

.hero {
  background: var(--bg-surface);
  border-radius: var(--radius-xl);
  padding: 24rpx 22rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid var(--border-soft);
  box-shadow: var(--shadow-card);
}

.hero-title {
  font-size: 42rpx;
  font-weight: 700;
  color: var(--text-title);
  letter-spacing: -0.02em;
}

.hero-sub {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: var(--text-light);
}

.group-title {
  padding: 16rpx 16rpx 16rpx;
  color: var(--text-light);
  font-size: 24rpx;
  font-weight: 600;
}

.cells-no-top-margin {
  margin-top: 0 !important;
}

.slide-row {
  overflow: hidden;
}

.slide-btn-delete {
  background: var(--text-danger);
  color: var(--button-text);
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 0 32rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.book-meta {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: var(--text-light);
}