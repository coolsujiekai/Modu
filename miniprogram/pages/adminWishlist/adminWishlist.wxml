<view class="page">
  <view class="card">
    <view class="h1">热门书单</view>
    <view class="p muted">按“想读书单”标题聚合。</view>
  </view>

  <view class="card">
    <view class="seg">
      <view class="seg-item {{mode === 'top10' ? 'active' : ''}}" data-mode="top10" bindtap="setMode">Top10</view>
      <view class="seg-item {{mode === 'all' ? 'active' : ''}}" data-mode="all" bindtap="setMode">全部</view>
    </view>
  </view>

  <view class="card">
    <view wx:if="{{items.length === 0}}" class="muted">暂无</view>
    <view wx:for="{{items}}" wx:key="title" class="row">
      <view class="title">{{item.title}}</view>
      <view class="count muted">{{item.count}}</view>
    </view>
    <button wx:if="{{hasMore && mode === 'all'}}" class="weui-btn weui-btn_default" bindtap="loadMore" loading="{{loadingMore}}" disabled="{{loadingMore}}">加载更多</button>
  </view>
</view>

