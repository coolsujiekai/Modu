<view class="page">
  <view class="card">
    <view class="hint">编辑{{typeText}}</view>
    <textarea class="editor" value="{{text}}" placeholder="写下内容…" bindinput="onInput" maxlength="2000" auto-height />
    <view class="actions">
      <button class="weui-btn weui-btn_primary" bindtap="save" loading="{{saving}}" disabled="{{saving}}">保存</button>
    </view>
  </view>
</view>

