@import "/styles/theme.wxss";
@import "/styles/common.wxss";

.page {
  background-color: var(--bg-primary-warm);
  min-height: 100vh;
}

.card {
  background: var(--bg-surface);
  border-radius: var(--radius-md);
  padding: 16rpx;
border: 1rpx solid var(--border-warm);
}

.hint {
  font-size: 24rpx;
  color: var(--text-warm-muted);
  margin-bottom: 16rpx;
}

.editor {
  width: 100%;
  min-height: 420rpx;
  font-size: 32rpx;
  line-height: 1.6;
  background: var(--bg-surface-soft);
  border: 1rpx solid var(--border-warm);
  border-radius: var(--radius-md);
  padding: 16rpx;
  box-sizing: border-box;
}

.actions {
  margin-top: 16rpx;
}

