.page {
  background-color: #FAF8F5;
  min-height: 100vh;
  padding: 32rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: none;
  border: 1rpx solid #EDE8E0;
}

.hint {
  font-size: 26rpx;
  color: #8C8279;
  margin-bottom: 16rpx;
}

.editor {
  width: 100%;
  min-height: 520rpx;
  font-size: 32rpx;
  line-height: 1.6;
}

.actions {
  margin-top: 18rpx;
}

