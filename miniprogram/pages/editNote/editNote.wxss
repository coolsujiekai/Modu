.page {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.04);
}

.hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.editor {
  width: 100%;
  min-height: 520rpx;
  font-size: 32rpx;
  line-height: 1.6;
}

.actions {
  margin-top: 18rpx;
}

