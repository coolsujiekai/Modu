.page {
  min-height: 100vh;
  padding: 32rpx 32rpx 60rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 26rpx 24rpx;
  box-shadow: none;
  border: 1rpx solid #EDE8E0;
  margin-bottom: 24rpx;
}

.h1 {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D2A26;
}

.h2 {
  margin-top: 6rpx;
  margin-bottom: 10rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #2D2A26;
}

.p {
  font-size: 28rpx;
  line-height: 1.65;
  color: #2D2A26;
  margin-top: 10rpx;
  white-space: pre-wrap;
}

.muted {
  color: #8C8279;
  font-size: 26rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.label {
  font-size: 30rpx;
  font-weight: 700;
  color: #2D2A26;
}

.profile {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: #f3f4f6;
  flex: 0 0 auto;
}

.info {
  margin-left: 18rpx;
}

.name {
  font-size: 32rpx;
  font-weight: 700;
  color: #111;
  margin-bottom: 6rpx;
}

