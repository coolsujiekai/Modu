@import "/styles/theme.wxss";
@import "/styles/common.wxss";

.page {
  min-height: 100vh;
}

.card {
  background: var(--bg-surface);
  border-radius: var(--radius-md);
  padding: 32rpx 16rpx;
border: 1rpx solid var(--border-warm);
  margin-bottom: 16rpx;
}

.h1 {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-title);
}

.h2 {
  margin-top: 16rpx;
  margin-bottom: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-title);
}

.p {
  font-size: 24rpx;
  line-height: 1.65;
  color: var(--text-title);
  margin-top: 16rpx;
  white-space: pre-wrap;
}

.muted {
  color: var(--text-warm-muted);
  font-size: 24rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.label {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-title);
}

.setting-row {
  margin-top: 16rpx;
}

.setting-title {
  font-size: 24rpx;
  color: var(--text-title);
  margin-bottom: 16rpx;
}

.seg {
  display: flex;
  gap: 16rpx;
  background: var(--bg-surface-muted);
  border-radius: var(--radius-md);
  padding: 16rpx;
}

.seg-3 .seg-item {
  min-width: 0;
}

.seg-item {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-warm-muted);
  border-radius: var(--radius-md);
  padding: 16rpx 16rpx;
}

.seg-item.active {
  background: var(--bg-surface);
  color: var(--text-accent);
  font-weight: 700;
}

.profile {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-md);
  background: var(--bg-surface-subtle);
  flex: 0 0 auto;
}

.info {
  margin-left: 16rpx;
}

.name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

