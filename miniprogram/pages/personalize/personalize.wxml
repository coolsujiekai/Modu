<view class="page">
  <view class="card">
    <view class="h1">个性化</view>
    <view class="p muted">仅在本机显示头像与昵称，不影响阅读数据。</view>
  </view>

  <view class="card">
    <view class="row">
      <view class="left">
        <view class="label">头像与昵称</view>
        <view class="muted">{{enabled ? '已开启' : '未开启'}}</view>
      </view>
      <view class="right">
        <button class="weui-btn weui-btn_mini weui-btn_primary" bindtap="enable" wx:if="{{!enabled}}">开启</button>
        <button class="weui-btn weui-btn_mini weui-btn_default" bindtap="disable" wx:if="{{enabled}}">关闭</button>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="h2">阅读体验</view>
    <view class="setting-row">
      <view class="setting-title">首页视图</view>
      <view class="seg">
        <view class="seg-item {{settings.homeViewMode === 'grid' ? 'active' : ''}}" data-mode="grid" bindtap="setHomeViewMode">书封</view>
        <view class="seg-item {{settings.homeViewMode === 'list' ? 'active' : ''}}" data-mode="list" bindtap="setHomeViewMode">列表</view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="h2">记录习惯</view>
    <view class="setting-row">
      <view class="setting-title">时间显示</view>
      <view class="seg seg-3">
        <view class="seg-item {{settings.noteTimeMode === 'both' ? 'active' : ''}}" data-mode="both" bindtap="setNoteTimeMode">两者</view>
        <view class="seg-item {{settings.noteTimeMode === 'relative' ? 'active' : ''}}" data-mode="relative" bindtap="setNoteTimeMode">相对</view>
        <view class="seg-item {{settings.noteTimeMode === 'absolute' ? 'active' : ''}}" data-mode="absolute" bindtap="setNoteTimeMode">日期</view>
      </view>
    </view>
    <view class="setting-row">
      <view class="setting-title">保存后输入框</view>
      <view class="seg">
        <view class="seg-item {{settings.saveInputMode === 'clear' ? 'active' : ''}}" data-mode="clear" bindtap="setSaveInputMode">清空</view>
        <view class="seg-item {{settings.saveInputMode === 'keep' ? 'active' : ''}}" data-mode="keep" bindtap="setSaveInputMode">保留</view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="h2">分享卡默认样式</view>
    <view class="setting-row">
      <view class="setting-title">默认模板</view>
      <view class="seg seg-3">
        <view class="seg-item {{settings.shareTemplateId === 'nebula' ? 'active' : ''}}" data-template="nebula" bindtap="setShareTemplate">夜色</view>
        <view class="seg-item {{settings.shareTemplateId === 'paper' ? 'active' : ''}}" data-template="paper" bindtap="setShareTemplate">纸页</view>
        <view class="seg-item {{settings.shareTemplateId === 'sunset' ? 'active' : ''}}" data-template="sunset" bindtap="setShareTemplate">暮光</view>
      </view>
    </view>
    <view class="p muted">首次生成时会提示，之后可在这里统一修改默认模板。</view>
  </view>

  <view class="card" wx:if="{{enabled}}">
    <view class="h2">当前显示</view>
    <view class="profile">
      <image class="avatar" src="{{profile.avatarUrl || defaultAvatar}}" mode="aspectFill" />
      <view class="info">
        <view class="name">{{profile.nickName || '未设置昵称'}}</view>
        <view class="muted">仅用于本机展示，可随时关闭。</view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="h2">说明</view>
    <view class="p muted">设置项仅在本机生效，不影响云端阅读数据。</view>
  </view>
</view>

