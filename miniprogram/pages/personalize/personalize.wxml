<view class="page {{isDark ? 'dark-theme' : ''}}">
  <view class="card">
    <view class="h1">个性化</view>
  </view>

  <view class="card">
    <view class="h2">记录习惯</view>
    <view class="setting-row">
      <view class="setting-title">时间显示</view>
      <view class="seg seg-3">
        <view class="seg-item {{settings.noteTimeMode === 'both' ? 'active' : ''}}" data-mode="both" bindtap="setNoteTimeMode">两者</view>
        <view class="seg-item {{settings.noteTimeMode === 'relative' ? 'active' : ''}}" data-mode="relative" bindtap="setNoteTimeMode">相对</view>
        <view class="seg-item {{settings.noteTimeMode === 'absolute' ? 'active' : ''}}" data-mode="absolute" bindtap="setNoteTimeMode">日期</view>
      </view>
    </view>
    <view class="setting-row">
      <view class="setting-title">保存后输入框</view>
      <view class="seg">
        <view class="seg-item {{settings.saveInputMode === 'clear' ? 'active' : ''}}" data-mode="clear" bindtap="setSaveInputMode">清空</view>
        <view class="seg-item {{settings.saveInputMode === 'keep' ? 'active' : ''}}" data-mode="keep" bindtap="setSaveInputMode">保留</view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="h2">外观</view>
    <view class="setting-row">
      <view class="setting-title">主题</view>
      <view class="seg seg-3">
        <view class="seg-item {{themeMode === 'auto' ? 'active' : ''}}" data-mode="auto" bindtap="setTheme">跟随系统</view>
        <view class="seg-item {{themeMode === 'light' ? 'active' : ''}}" data-mode="light" bindtap="setTheme">浅色</view>
        <view class="seg-item {{themeMode === 'dark' ? 'active' : ''}}" data-mode="dark" bindtap="setTheme">深色</view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="h2">阅读分享图片模版</view>
    <view class="setting-row">
      <view class="seg seg-3">
        <view class="seg-item {{settings.shareTemplateId === 'nebula' ? 'active' : ''}}" data-template="nebula" bindtap="setShareTemplate">夜色</view>
        <view class="seg-item {{settings.shareTemplateId === 'paper' ? 'active' : ''}}" data-template="paper" bindtap="setShareTemplate">纸页</view>
        <view class="seg-item {{settings.shareTemplateId === 'sunset' ? 'active' : ''}}" data-template="sunset" bindtap="setShareTemplate">暮光</view>
      </view>
    </view>
    <view class="p muted">首次生成时会提示，之后可在这里统一修改默认模板。</view>
  </view>

</view>
