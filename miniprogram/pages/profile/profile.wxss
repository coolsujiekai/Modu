@import "/styles/theme.wxss";
@import "/styles/common.wxss";

.page {
  min-height: 100vh;
}

.page-head {
  margin-bottom: 18rpx;
}

.page-title {
  font-size: 42rpx;
  font-weight: 700;
  color: var(--text-title);
  letter-spacing: -0.02em;
}

.page-sub {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--text-light);
}

.card {
  background: var(--bg-surface);
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1rpx solid var(--border-soft);
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-soft);
}

.weui-cells_in-card {
  margin-top: 0 !important;
}

.weui-cells_in-card:before,
.weui-cells_in-card:after {
  display: none;
}

.weui-cells_in-card .weui-cell:before {
  left: 76rpx;
}

.icon-wrap {
  width: 52rpx;
  height: 52rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  background: rgba(10, 132, 255, 0.12);
  border: 1rpx solid var(--border-accent);
}

.icon-wishlist {
  background: var(--border-accent);
}

.icon-search {
  background: var(--border-accent);
}

.icon-privacy {
  background: var(--border-accent);
}

.icon-personalize {
  background: var(--border-accent);
}

.icon-danger {
  background: var(--text-danger);
  border-color: var(--text-danger);
}

.cell-icon {
  width: 30rpx;
  height: 30rpx;
}

.dark-theme .icon-wrap {
  background: var(--bg-dark-surface-3);
  border-color: var(--border-dark);
}

.danger-text {
  color: var(--text-danger);
  font-weight: 700;
}

.muted {
  color: var(--text-light);
  font-size: 24rpx;
}

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: var(--overlay-mask);
  z-index: 998;
}

.modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 72vh;
  background: var(--bg-surface);
  border-top-left-radius: var(--radius-xl);
  border-top-right-radius: var(--radius-xl);
  z-index: 999;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 16rpx 16rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.modal-close {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 40rpx;
  color: var(--text-secondary);
}

.seg {
  margin: 0 16rpx 16rpx;
  background: var(--bg-surface-muted);
  border-radius: 999rpx;
  padding: 8rpx;
  display: flex;
  gap: 16rpx;
}

.seg-item {
  flex: 1 1 0;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-light);
  border-radius: 999rpx;
}

.seg-item.active {
  background: var(--bg-surface);
  color: var(--text-primary);
  font-weight: 700;
  box-shadow: var(--shadow-soft);
}

.modal-search {
  display: flex;
  align-items: center;
  padding: 16rpx 16rpx 16rpx;
}

.modal-input {
  flex: 1 1 auto;
  height: 76rpx;
  background: var(--bg-surface-soft);
  border-radius: var(--radius-lg);
  padding: 0 16rpx;
  font-size: 32rpx;
  color: var(--text-primary);
  border: 1rpx solid var(--border-soft);
}

.placeholder {
  color: var(--text-neutral-500);
}

.modal-clear {
  flex: 0 0 auto;
  margin-left: 16rpx;
  font-size: 24rpx;
  color: var(--text-accent);
  padding: 16rpx 16rpx;
}

.modal-body {
  flex: 1 1 auto;
  padding: 0 16rpx 16rpx;
  overflow: hidden;
}

.loading {
  padding: 16rpx 16rpx;
}

.result-list {
  height: 100%;
}

.result-item {
  padding: 16rpx 16rpx;
  border-radius: var(--radius-md);
}

.result-item:active {
  background: var(--bg-surface-subtle-2);
}

.result-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.result-title rich-text {
  display: inline-block;
  font-size: inherit;
  font-weight: inherit;
  color: inherit;
}

.highlight {
  color: var(--text-accent);
  background-color: var(--bg-surface-accent);
  padding: 16rpx 16rpx;
  border-radius: var(--radius-md);
  font-weight: 700;
}

.result-sub {
  margin-top: 16rpx;
  font-size: 24rpx;
}

.empty {
  padding: 32rpx 16rpx;
  text-align: center;
}

.empty-icon {
  font-size: 40rpx;
  line-height: 1;
}

.empty-title {
  margin-top: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.empty-desc {
  margin-top: 16rpx;
}