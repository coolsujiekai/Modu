.page {
  min-height: 100vh;
  padding: 32rpx 32rpx 60rpx;
}

.page-head {
  margin-bottom: 14rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D2A26;
}

.page-sub {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #8C8279;
}

.card {
  background: #fff;
  border-radius: 22rpx;
  overflow: hidden;
  box-shadow: none;
  border: 1rpx solid #EDE8E0;
  margin-bottom: 24rpx;
}

.weui-cells_in-card {
  margin-top: 0 !important;
}

.weui-cells_in-card:before,
.weui-cells_in-card:after {
  display: none;
}

.weui-cells_in-card .weui-cell:before {
  left: 76rpx;
}

.icon-wrap {
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  box-shadow: none;
  background: #D4C4A8;
  border: 1rpx solid #D4C4A8;
}

.icon-wishlist {
  background: #D4C4A8;
}

.icon-search {
  background: #D4C4A8;
}

.icon-privacy {
  background: #D4C4A8;
}

.icon-personalize {
  background: #D4C4A8;
}

.icon-danger {
  background: #C07D6B;
  border-color: #C07D6B;
}

.cell-icon {
  width: 30rpx;
  height: 30rpx;
}

[data-weui-theme="dark"] .icon-wrap {
  background: #4a433c;
  border-color: #3f3a34;
}

.danger-text {
  color: #C07D6B;
  font-weight: 700;
}

.muted {
  color: #8C8279;
  font-size: 26rpx;
}

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 998;
}

.modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 72vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 999;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -12rpx 40rpx rgba(0, 0, 0, 0.12);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 22rpx 10rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111;
}

.modal-close {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 44rpx;
  color: #666;
}

.seg {
  margin: 0 22rpx 10rpx;
  background: #f3f4f6;
  border-radius: 999rpx;
  padding: 6rpx;
  display: flex;
  gap: 6rpx;
}

.seg-item {
  flex: 1 1 0;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 28rpx;
  color: #6b7280;
  border-radius: 999rpx;
}

.seg-item.active {
  background: #fff;
  color: #111;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.06);
}

.modal-search {
  display: flex;
  align-items: center;
  padding: 10rpx 22rpx 16rpx;
}

.modal-input {
  flex: 1 1 auto;
  height: 76rpx;
  background: #f3f4f6;
  border-radius: 14rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  color: #111;
}

.placeholder {
  color: #9ca3af;
}

.modal-clear {
  flex: 0 0 auto;
  margin-left: 14rpx;
  font-size: 28rpx;
  color: #8B7355;
  padding: 10rpx 10rpx;
}

.modal-body {
  flex: 1 1 auto;
  padding: 0 12rpx 18rpx;
  overflow: hidden;
}

.loading {
  padding: 18rpx 10rpx;
}

.result-list {
  height: 100%;
}

.result-item {
  padding: 18rpx 18rpx;
  border-radius: 16rpx;
}

.result-item:active {
  background: #f6f7f9;
}

.result-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111;
}

.result-title rich-text {
  display: inline-block;
  font-size: inherit;
  font-weight: inherit;
  color: inherit;
}

.highlight {
  color: #8B7355;
  background-color: #F6EFE4;
  padding: 1rpx 6rpx;
  border-radius: 4rpx;
  font-weight: 700;
}

.result-sub {
  margin-top: 8rpx;
  font-size: 26rpx;
}

.empty {
  padding: 40rpx 18rpx;
  text-align: center;
}

.empty-icon {
  font-size: 90rpx;
  line-height: 1;
}

.empty-title {
  margin-top: 12rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #111;
}

.empty-desc {
  margin-top: 8rpx;
}