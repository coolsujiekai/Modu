<view class="page">
  <view class="header">
    <view class="title">翻书随手记</view>
    <view class="sub muted">{{motto}}</view>
  </view>

  <view class="weui-cells__title">📚 书单小助手</view>
  <view class="weui-cells">
    <view class="weui-cell weui-cell_access" bindtap="goWishlist">
      <view class="weui-cell__bd">
        <view>打开书单</view>
        <view class="muted">收集别人推荐或自己想读的书</view>
      </view>
      <view class="weui-cell__ft"></view>
    </view>
  </view>

  <view class="weui-cells__title">🔎 查询小助手</view>
  <view class="weui-cells">
    <view class="weui-cell weui-cell_access" bindtap="openBookSearch">
      <view class="weui-cell__bd">
        <view>书名搜索</view>
        <view class="muted">不进新页面，直接弹窗搜索</view>
      </view>
      <view class="weui-cell__ft"></view>
    </view>
    <view class="weui-cell weui-cell_access" bindtap="openAuthorSearch">
      <view class="weui-cell__bd">
        <view>作家搜索</view>
        <view class="muted">不进新页面，直接弹窗搜索</view>
      </view>
      <view class="weui-cell__ft"></view>
    </view>
  </view>

  <view class="weui-cells__title">🔐 隐私与个性化</view>
  <view class="weui-cells">
    <view class="weui-cell weui-cell_access" bindtap="goPrivacy">
      <view class="weui-cell__bd">
        <view>隐私指引与说明</view>
        <view class="muted">说明我们收集什么、用途与保护方式</view>
      </view>
      <view class="weui-cell__ft"></view>
    </view>
    <view class="weui-cell weui-cell_access" bindtap="goPersonalize">
      <view class="weui-cell__bd">
        <view>个性化显示（头像 / 昵称）</view>
        <view class="muted">可选开启，不影响使用</view>
      </view>
      <view class="weui-cell__ft"></view>
    </view>
  </view>

  <view class="weui-cells__title">ℹ️ 关于翻书随手记</view>
  <view class="weui-cells">
    <view class="weui-cell">
      <view class="weui-cell__bd">版本</view>
      <view class="weui-cell__ft">{{version}}</view>
    </view>
    <view class="weui-cell">
      <view class="weui-cell__bd">程序制作</view>
      <view class="weui-cell__ft">默存</view>
    </view>
  </view>

  <view class="weui-cells__title" style="color:#fa5151;">⚠️ 危险操作</view>
  <view class="weui-cells">
    <view class="weui-cell weui-cell_access" bindtap="openDangerZone">
      <view class="weui-cell__bd" style="color:#fa5151;">危险操作</view>
      <view class="weui-cell__ft"></view>
    </view>
  </view>

  <view class="weui-footer" style="margin-top: 60rpx;">
    <view class="weui-footer__text">危险操作不可恢复，请谨慎。</view>
  </view>
</view>

<!-- Half-screen search modal -->
<view class="modal-mask" wx:if="{{searchVisible}}" catchtap="closeSearch"></view>
<view class="modal" wx:if="{{searchVisible}}">
  <view class="modal-header">
    <view class="modal-title">{{searchTitle}}</view>
    <view class="modal-close" catchtap="closeSearch">×</view>
  </view>

  <view class="modal-search">
    <input
      class="modal-input"
      value="{{searchQuery}}"
      placeholder="{{searchPlaceholder}}"
      placeholder-class="placeholder"
      confirm-type="search"
      bindinput="onSearchInput"
      bindconfirm="onSearchConfirm"
      focus="{{true}}"
    />
    <view class="modal-clear" wx:if="{{searchQuery}}" catchtap="clearSearch">清空</view>
  </view>

  <view class="modal-body">
    <view class="loading muted" wx:if="{{searchLoading}}">搜索中…</view>

    <scroll-view scroll-y class="result-list" wx:if="{{!searchLoading && searchResults.length}}">
      <view
        class="result-item"
        wx:for="{{searchResults}}"
        wx:key="_id"
        catchtap="onPickResult"
        data-id="{{item._id}}"
        data-type="{{searchType}}"
        data-name="{{item.name}}"
      >
        <view class="result-title">
          <text wx:if="{{searchType === 'book'}}">{{item.bookName}}</text>
          <text wx:if="{{searchType === 'author'}}">{{item.name}}</text>
        </view>
        <view class="result-sub muted" wx:if="{{searchType === 'book'}}">
          <text wx:if="{{item.authorName}}">{{item.authorName}} · </text>
          <text>{{item.status === 'finished' ? '已读' : '在读'}}</text>
        </view>
      </view>
    </scroll-view>

    <view class="empty" wx:if="{{!searchLoading && searchQuery && !searchResults.length}}">
      <view class="empty-icon">🔎</view>
      <view class="empty-title">没有找到</view>
      <view class="empty-desc muted">换个关键词试试</view>
    </view>
  </view>
</view>