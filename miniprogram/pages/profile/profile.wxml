<view class="page">
  <view class="card">
    <view class="weui-cells weui-cells_in-card">
    <view class="weui-cell weui-cell_access" bindtap="goWishlist">
      <view class="weui-cell__hd">
        <view class="icon-wrap icon-wishlist">
          <image class="cell-icon" src="/assets/icons/bookmark.svg" mode="aspectFit" />
        </view>
      </view>
      <view class="weui-cell__bd">书单</view>
      <view class="weui-cell__ft"></view>
    </view>

    <view class="weui-cell weui-cell_access" bindtap="openShelfSearch">
      <view class="weui-cell__hd">
        <view class="icon-wrap icon-search">
          <image class="cell-icon" src="/assets/icons/shelf-search.svg" mode="aspectFit" />
        </view>
      </view>
      <view class="weui-cell__bd">书架搜索</view>
      <view class="weui-cell__ft"></view>
    </view>

    <view class="weui-cell weui-cell_access" bindtap="goPrivacy">
      <view class="weui-cell__hd">
        <view class="icon-wrap icon-privacy">
          <image class="cell-icon" src="/assets/icons/shield.svg" mode="aspectFit" />
        </view>
      </view>
      <view class="weui-cell__bd">隐私指引与说明</view>
      <view class="weui-cell__ft"></view>
    </view>

    <view class="weui-cell weui-cell_access" bindtap="goPersonalize">
      <view class="weui-cell__hd">
        <view class="icon-wrap icon-personalize">
          <image class="cell-icon" src="/assets/icons/user-star.svg" mode="aspectFit" />
        </view>
      </view>
      <view class="weui-cell__bd">个性化设置</view>
      <view class="weui-cell__ft"></view>
    </view>
    </view>
  </view>

  <view class="card">
    <view class="weui-cells weui-cells_in-card">
    <view class="weui-cell weui-cell_access" bindtap="openDangerZone">
      <view class="weui-cell__hd">
        <view class="icon-wrap icon-danger">
          <image class="cell-icon" src="/assets/icons/warning.svg" mode="aspectFit" />
        </view>
      </view>
      <view class="weui-cell__bd danger-text">危险操作</view>
      <view class="weui-cell__ft"></view>
    </view>
    </view>
  </view>
</view>

<!-- Half-screen search modal -->
<view class="modal-mask" wx:if="{{searchVisible}}" catchtap="closeSearch"></view>
<view class="modal" wx:if="{{searchVisible}}">
  <view class="modal-header">
    <view class="modal-title">{{searchTitle}}</view>
    <view class="modal-close" catchtap="closeSearch">×</view>
  </view>

  <view class="seg">
    <view class="seg-item {{searchType === 'book' ? 'active' : ''}}" catchtap="switchSearchType" data-type="book">书名</view>
    <view class="seg-item {{searchType === 'author' ? 'active' : ''}}" catchtap="switchSearchType" data-type="author">作家</view>
  </view>

  <view class="modal-search">
    <input
      class="modal-input"
      value="{{searchQuery}}"
      placeholder="{{searchPlaceholder}}"
      placeholder-class="placeholder"
      confirm-type="search"
      bindinput="onSearchInput"
      bindconfirm="onSearchConfirm"
      focus="{{true}}"
    />
    <view class="modal-clear" wx:if="{{searchQuery}}" catchtap="clearSearch">清空</view>
  </view>

  <view class="modal-body">
    <view class="loading muted" wx:if="{{searchLoading}}">搜索中…</view>

    <scroll-view scroll-y class="result-list" wx:if="{{!searchLoading && searchResults.length}}">
      <view
        class="result-item"
        wx:for="{{searchResults}}"
        wx:key="_id"
        catchtap="onPickResult"
        data-id="{{item._id}}"
        data-type="{{searchType}}"
        data-name="{{item.name}}"
      >
        <view class="result-title">
          <text wx:if="{{searchType === 'book'}}">{{item.bookName}}</text>
          <text wx:if="{{searchType === 'author'}}">{{item.name}}</text>
        </view>
        <view class="result-sub muted" wx:if="{{searchType === 'book'}}">
          <text wx:if="{{item.authorName}}">{{item.authorName}} · </text>
          <text>{{item.status === 'finished' ? '已读' : '在读'}}</text>
        </view>
      </view>
    </scroll-view>

    <view class="empty" wx:if="{{!searchLoading && searchQuery && !searchResults.length}}">
      <view class="empty-icon">🔎</view>
      <view class="empty-title">没有找到</view>
      <view class="empty-desc muted">换个关键词试试</view>
    </view>
  </view>
</view>