<view class="page">
  <view class="weui-cells__title">📚 书单</view>
  <view class="weui-cells">
    <view class="weui-cell weui-cell_access" bindtap="goWishlist">
      <view class="weui-cell__bd">打开书单</view>
      <view class="weui-cell__ft"></view>
    </view>
  </view>

  <view class="weui-cells__title">ℹ️ 关于墨读</view>
  <view class="weui-cells">
    <view class="weui-cell">
      <view class="weui-cell__bd">版本</view>
      <view class="weui-cell__ft">{{version}}</view>
    </view>
    <view class="weui-cell">
      <view class="weui-cell__bd">程序制作</view>
      <view class="weui-cell__ft">默存</view>
    </view>
  </view>

  <view class="weui-cells__title" style="color:#fa5151;">⚠️ 危险操作</view>
  <view class="weui-cells">
    <view class="weui-cell weui-cell_access" bindtap="openDangerZone">
      <view class="weui-cell__bd" style="color:#fa5151;">危险操作</view>
      <view class="weui-cell__ft"></view>
    </view>
  </view>

  <view class="weui-footer" style="margin-top: 60rpx;">
    <view class="weui-footer__text">危险操作不可恢复，请谨慎。</view>
  </view>
</view>