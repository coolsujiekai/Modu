<view class="page {{isDark ? 'dark-theme' : ''}}">
  <view class="search-bar">
    <view class="search-input-wrap">
      <input
        class="search-input"
        value="{{searchQuery}}"
        placeholder="{{placeholder}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        confirm-type="search"
        focus="true"
      />
    </view>
    <view class="search-type-tabs">
      <view
        class="tab {{searchType === 'book' ? 'active' : ''}}"
        bindtap="switchSearchType"
        data-type="book"
      >书籍</view>
      <view
        class="tab {{searchType === 'author' ? 'active' : ''}}"
        bindtap="switchSearchType"
        data-type="author"
      >作者</view>
    </view>
  </view>

  <view class="search-body">
    <block wx:if="{{searchLoading}}">
      <view class="loading-row">搜索中...</view>
    </block>

    <block wx:elif="{{searchResults.length > 0}}">
      <view
        class="result-item"
        wx:for="{{searchResults}}"
        wx:key="_id"
        bindtap="onPickResult"
        data-id="{{item._id}}"
        data-type="{{searchType}}"
        data-name="{{item.name}}"
      >
        <view class="result-title">
          <text wx:if="{{item.highlightedTitle}}" unsafe-template="true">{{item.highlightedTitle}}</text>
          <text wx:else>{{item.bookName || item.name}}</text>
        </view>
        <view class="result-sub" wx:if="{{item.authorName}}">{{item.authorName}}</view>
      </view>
    </block>

    <block wx:elif="{{searchQuery.length > 0}}">
      <view class="empty-tip">未找到相关结果</view>
    </block>

    <block wx:else>
      <view class="empty-tip">输入关键字搜索{{searchType === 'book' ? '书籍' : '作者'}}</view>
    </block>
  </view>
</view>
