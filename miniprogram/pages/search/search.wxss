@import "/styles/theme.wxss";
@import "/styles/common.wxss";

.page {
  min-height: 100vh;
  background: var(--bg-page);
}

.search-bar {
  background: var(--bg-surface);
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--border-soft);
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-input-wrap {
  background: var(--bg-page);
  border-radius: var(--radius-md);
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-body);
}

.search-body {
  padding: 32rpx;
}

.group-title {
  margin-top: 18rpx;
  padding: 10rpx 0;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-light);
}

.group-title:first-child {
  margin-top: 0;
}

.loading-row {
  text-align: center;
  color: var(--text-warm-muted);
  font-size: 26rpx;
  padding: 60rpx 0;
}

.result-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-soft);
}

.result-item:last-child {
  border-bottom: none;
}

.result-title {
  font-size: 30rpx;
  color: var(--text-title);
  font-weight: 500;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.result-rich {
  display: inline;
}

.highlight {
  color: var(--text-accent);
  font-weight: 700;
}

.result-sub {
  font-size: 24rpx;
  color: var(--text-warm-muted);
  margin-top: 8rpx;
}

.result-badge {
  flex: none;
  font-size: 20rpx;
  color: var(--text-accent);
  background: var(--bg-surface-tag);
  border: 1rpx solid rgba(10, 132, 255, 0.14);
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
}

.note-hit-list {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.note-hit {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
}

.note-hit__tag {
  flex: none;
  font-size: 20rpx;
  padding: 6rpx 10rpx;
  border-radius: 10rpx;
  background: var(--bg-page);
  color: var(--text-warm-muted);
  border: 1rpx solid var(--border-soft);
}

.note-hit__text {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.55;
  color: var(--text-body);
  word-break: break-word;
}

.empty-tip {
  text-align: center;
  color: var(--text-warm-muted);
  font-size: 26rpx;
  padding: 120rpx 0;
}
