.page {
  min-height: 100vh;
  padding: 32rpx 32rpx 40rpx;
}

.label {
  width: 90rpx;
  color: #8C8279;
  font-size: 28rpx;
}

.muted {
  color: #8C8279;
}

.suggest-card {
  margin-top: 16rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.suggest-title {
  font-size: 26rpx;
  padding: 14rpx 10rpx 4rpx;
}

.selected {
  margin-top: 16rpx;
  font-size: 28rpx;
}

.author-pill {
  display: inline-block;
  margin: 0 10rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #D4C4A8;
  color: #8B7355;
  font-weight: 600;
}

.actions {
  margin-top: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 0 12rpx 16rpx;
}

