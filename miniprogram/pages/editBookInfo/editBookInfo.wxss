@import "/styles/theme.wxss";
@import "/styles/common.wxss";

.page {
  min-height: 100vh;
}

.hero {
  background: var(--bg-surface);
  border-radius: var(--radius-md);
  padding: 16rpx 16rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid var(--border-warm);
}

.hero-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-title);
}

.hero-sub {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: var(--text-warm-muted);
}

.form-panel {
  margin-top: 0;
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 1rpx solid var(--border-warm);
}

.cells-no-top-margin {
  margin-top: 0 !important;
}

.label {
  width: 90rpx;
  color: var(--text-warm-muted);
  font-size: 24rpx;
}

.muted {
  color: var(--text-warm-muted);
}

.suggest-card {
  margin-top: 16rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
}

.suggest-title {
  font-size: 24rpx;
  padding: 16rpx 16rpx 16rpx;
}

.suggest-cells {
  margin-top: 16rpx !important;
}

.selected {
  margin-top: 16rpx;
  font-size: 24rpx;
}

.clear-link {
  color: var(--text-warm-muted);
}

.author-pill {
  display: inline-block;
  margin: 0 16rpx;
  padding: 16rpx 16rpx;
  border-radius: var(--radius-md);
  background: var(--border-accent);
  color: var(--text-accent);
  font-weight: 600;
}

.actions {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 16rpx 16rpx;
}

