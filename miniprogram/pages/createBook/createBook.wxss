.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
}

.label {
  width: 90rpx;
  color: #666;
  font-size: 28rpx;
}

.muted {
  color: #999;
}

.suggest-card {
  margin-top: 16rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.suggest-title {
  font-size: 26rpx;
  padding: 14rpx 10rpx 4rpx;
}

.selected {
  margin-top: 16rpx;
  font-size: 28rpx;
}

.author-pill {
  display: inline-block;
  margin: 0 10rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(16, 185, 129, 0.12);
  color: #10b981;
  font-weight: 600;
}

.actions {
  margin-top: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 0 12rpx 16rpx;
}

