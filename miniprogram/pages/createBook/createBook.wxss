.page {
  min-height: 100vh;
  padding: 32rpx 32rpx 40rpx;
}

.hero {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 22rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #EDE8E0;
}

.hero-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2D2A26;
}

.hero-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8C8279;
}

.form-panel {
  margin-top: 0;
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid #EDE8E0;
}

.cells-no-top-margin {
  margin-top: 0 !important;
}

.label {
  width: 90rpx;
  color: #8C8279;
  font-size: 28rpx;
}

.muted {
  color: #8C8279;
}

.suggest-card {
  margin-top: 16rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.suggest-title {
  font-size: 26rpx;
  padding: 14rpx 10rpx 4rpx;
}

.suggest-cells {
  margin-top: 10rpx !important;
}

.selected {
  margin-top: 16rpx;
  font-size: 28rpx;
}

.author-pill {
  display: inline-block;
  margin: 0 10rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #D4C4A8;
  color: #8B7355;
  font-weight: 600;
}

.actions {
  margin-top: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 0 12rpx 16rpx;
}

