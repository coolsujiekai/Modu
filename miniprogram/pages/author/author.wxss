.page {
  min-height: 100vh;
  padding: 32rpx 32rpx 40rpx;
}

.muted {
  color: #8C8279;
}

.hero {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #EDE8E0;
}

.hero-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #2D2A26;
}

.hero-sub {
  margin-top: 10rpx;
  font-size: 28rpx;
}

.section {
  margin-top: 12rpx;
}

.section-hd {
  padding: 14rpx 8rpx 10rpx;
  color: #8C8279;
  font-size: 28rpx;
  font-weight: 700;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D2A26;
}

.meta {
  margin-top: 6rpx;
  font-size: 26rpx;
}

.slide-row {
  overflow: hidden;
}

.slide-btn-delete {
  background: #C07D6B;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 0 40rpx;
  font-size: 30rpx;
  font-weight: 600;
}

