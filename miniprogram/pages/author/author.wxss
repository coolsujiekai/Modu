@import "/styles/theme.wxss";
@import "/styles/common.wxss";

.page {
  min-height: 100vh;
}

.muted {
  color: var(--text-warm-muted);
}

.hero {
  background: var(--bg-surface);
  border-radius: var(--radius-md);
  padding: 32rpx 16rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid var(--border-warm);
}

.hero-title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-title);
}

.hero-sub {
  margin-top: 16rpx;
  font-size: 24rpx;
}

.section {
  margin-top: 16rpx;
}

.cells-no-top-margin {
  margin-top: 0 !important;
}

.section-hd {
  padding: 16rpx 16rpx 16rpx;
  color: var(--text-warm-muted);
  font-size: 24rpx;
  font-weight: 700;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-title);
}

.meta {
  margin-top: 16rpx;
  font-size: 24rpx;
}

.slide-row {
  overflow: hidden;
}

.slide-btn-delete {
  background: var(--text-danger);
  color: var(--button-text);
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 0 32rpx;
  font-size: 32rpx;
  font-weight: 600;
}

