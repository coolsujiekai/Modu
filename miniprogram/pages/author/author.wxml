<view class="page" bindtap="onPageTap">
  <view class="hero">
    <view class="hero-title">{{authorName}}</view>
    <view class="hero-sub muted">在读 {{readingBooks.length}} 本 · 已读 {{finishedBooks.length}} 本</view>
  </view>

  <view class="section" wx:if="{{readingBooks.length}}">
    <view class="section-hd">在读</view>
    <view class="weui-cells cells-no-top-margin">
      <view wx:for="{{readingBooks}}" wx:key="_id" class="slide-row">
        <slideview
          buttons="{{item.slideButtons}}"
          show="{{openSlideId === item._id}}"
          data-id="{{item._id}}"
          bind:show="onSlideShow"
          bind:hide="onSlideHide"
          bind:buttontap="onSlideButtonTap"
        >
          <view class="weui-cell weui-cell_access" catchtap="openBook" data-id="{{item._id}}">
            <view class="weui-cell__bd">
              <view class="title">{{item.bookName}}</view>
              <view class="meta muted">开始 {{item.startText}}</view>
            </view>
            <view class="weui-cell__ft"></view>
          </view>
        </slideview>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{finishedBooks.length}}">
    <view class="section-hd">已读</view>
    <view class="weui-cells cells-no-top-margin">
      <view wx:for="{{finishedBooks}}" wx:key="_id" class="slide-row">
        <slideview
          buttons="{{item.slideButtons}}"
          show="{{openSlideId === item._id}}"
          data-id="{{item._id}}"
          bind:show="onSlideShow"
          bind:hide="onSlideHide"
          bind:buttontap="onSlideButtonTap"
        >
          <view class="weui-cell weui-cell_access" catchtap="openBook" data-id="{{item._id}}">
            <view class="weui-cell__bd">
              <view class="title">{{item.bookName}}</view>
              <view class="meta muted">{{item.endText}} 读完</view>
            </view>
            <view class="weui-cell__ft"></view>
          </view>
        </slideview>
      </view>
    </view>
  </view>

  <view class="weui-msg" wx:if="{{!readingBooks.length && !finishedBooks.length && !loading}}">
    <view class="weui-msg__icon-area"><text style="font-size: 80rpx;">📚</text></view>
    <view class="weui-msg__title">还没有这位作者的书</view>
    <view class="weui-msg__desc">可以先去“在读”里添加一本</view>
  </view>
</view>

