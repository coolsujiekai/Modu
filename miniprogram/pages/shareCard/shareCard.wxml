<!-- pages/shareCard/shareCard.wxml -->
<view class="page {{isDark ? 'dark-theme' : ''}}">
<canvas canvas-id="cardCanvas" class="card-canvas" />

<view class="modal-mask" bindtap="onMaskTap"></view>
<view class="modal-content">
  <view class="modal-header">
    <text class="modal-title">生成阅读分享图片</text>
    <text class="modal-sub">默认样式可在「更多-个性化」调整</text>
  </view>

  <view class="book-info-section">
    <view class="book-info-row">
      <text class="book-info-label">书名</text>
      <input
        class="book-info-input"
        placeholder-class="book-info-placeholder"
        value="{{bookName}}"
        bindinput="onBookNameInput"
        placeholder="书名"
      />
    </view>
    <view class="book-info-row">
      <text class="book-info-label">作者</text>
      <input
        class="book-info-input"
        placeholder-class="book-info-placeholder"
        value="{{authorName}}"
        bindinput="onAuthorNameInput"
        placeholder="作者"
      />
    </view>
  </view>

  <view class="control-section">
    <view class="control-title">选择模板</view>
    <scroll-view class="template-list" scroll-x show-scrollbar="{{false}}">
      <view class="template-inner">
        <view
          wx:for="{{templates}}"
          wx:key="id"
          class="template-pill {{templateId === item.id ? 'template-pill--active' : ''}}"
          bindtap="onTemplateChange"
          data-id="{{item.id}}"
        >
          {{item.name}}
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="quote-section">
    <view class="section-head">
      <view class="section-label">选择金句（可多选）</view>
      <view class="section-count">已选 {{selectedCount}} 条</view>
    </view>
    <view class="section-sub">{{limitHint}}</view>
    <view wx:if="{{layoutHint}}" class="section-sub section-sub--info">{{layoutHint}}</view>
    <block wx:if="{{quotes.length === 0}}">
      <view class="quote-empty muted">这本书还没有金句，去添加一条吧</view>
    </block>
    <scroll-view class="quote-list" scroll-y show-scrollbar="{{true}}" enhanced>
      <view
        wx:for="{{displayQuotes}}"
        wx:key="timestamp"
        class="quote-item {{item.selected ? 'quote-item--selected' : ''}}"
        bindtap="onQuoteSelect"
        data-idx="{{index}}"
      >
        <view class="quote-main">
          <view class="quote-text {{item.selected ? 'quote-text--selected' : ''}}">{{item.text}}</view>
        </view>
        <view wx:if="{{item.selected}}" class="quote-check">✓</view>
      </view>
    </scroll-view>
  </view>

  <!-- 预览打开时移除此处原生 button，否则小程序原生层会叠在预览按钮上，出现「取消」压在「分享到微信」上 -->
  <view class="modal-actions" wx:if="{{!previewVisible}}">
    <button class="btn-cancel" bindtap="onCancel">取消</button>
    <button class="btn-confirm {{!canGenerate ? 'btn-disabled' : ''}}" bindtap="onConfirm" disabled="{{!canGenerate}}">生成图片</button>
  </view>
</view>

<view wx:if="{{generating}}" class="generating-overlay">
  <view class="generating-box">
    <view class="spinner"></view>
    <text class="generating-text">正在生成…</text>
  </view>
</view>

<view wx:if="{{previewVisible}}" class="preview-overlay" catchtouchmove="noop">
  <view class="preview-close" bindtap="onPreviewClose">×</view>
  <image class="preview-image" src="{{previewSrc}}" />
  <view class="preview-footer">
    <text class="preview-hint">{{previewSavedHint}}</text>
    <view class="preview-btns">
      <button class="preview-btn preview-btn--primary" bindtap="onPreviewShare">分享到微信</button>
      <button class="preview-btn preview-btn--primary" bindtap="onPreviewSave">保存到相册</button>
    </view>
  </view>
</view>
</view>
