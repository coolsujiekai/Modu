<!-- pages/shareCard/shareCard.wxml -->
<!-- 绘制用 canvas（视觉透明，用 positioning 移出屏幕） -->
<canvas canvas-id="cardCanvas" class="card-canvas" />

<!-- 遮罩层 -->
<view class="modal-mask" bindtap="onMaskTap"></view>

<!-- 主内容 -->
<view class="modal-content">
  <!-- 顶部标题 -->
  <view class="modal-header">
    <text class="modal-title">生成阅读分享卡</text>
  </view>

  <!-- 书本信息确认 -->
  <view class="book-info-section">
    <view class="book-info-row">
      <text class="book-info-label">书名</text>
      <input class="book-info-input" value="{{bookName}}" bindinput="onBookNameInput" placeholder="书名" />
    </view>
    <view class="book-info-row">
      <text class="book-info-label">作者</text>
      <input class="book-info-input" value="{{authorName}}" bindinput="onAuthorNameInput" placeholder="作者" />
    </view>
  </view>

  <!-- 金句选择 -->
  <view class="quote-section">
    <view class="section-label">选择一条金句</view>
    <block wx:if="{{quotes.length === 0}}">
      <view class="quote-empty muted">这本书还没有金句，去添加一条吧</view>
    </block>
    <scroll-view class="quote-list" scroll-y>
      <view
        wx:for="{{quotes}}"
        wx:key="timestamp"
        class="quote-item {{selectedQuoteIdx === index ? 'quote-item--selected' : ''}}"
        bindtap="onQuoteSelect"
        data-idx="{{index}}"
      >
        <view class="quote-text {{selectedQuoteIdx === index ? 'quote-text--selected' : ''}}">{{item.text}}</view>
        <view wx:if="{{selectedQuoteIdx === index}}" class="quote-check">✓</view>
      </view>
    </scroll-view>
  </view>

  <!-- 按钮组 -->
  <view class="modal-actions">
    <button class="btn-cancel" bindtap="onCancel">取消</button>
    <button class="btn-confirm {{!canGenerate ? 'btn-disabled' : ''}}" bindtap="onConfirm" disabled="{{!canGenerate}}">生成图片</button>
  </view>
</view>

<!-- 生成中 loading -->
<view wx:if="{{generating}}" class="generating-overlay">
  <view class="generating-box">
    <view class="spinner"></view>
    <text class="generating-text">正在生成…</text>
  </view>
</view>
