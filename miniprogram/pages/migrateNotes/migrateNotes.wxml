<view class="page {{isDark ? 'dark-theme' : ''}}">
  <view class="card">
    <view class="title">一次性迁移</view>
    <view class="desc">
      将所有书籍里的记录（books.notes）写入到全局集合（notes），用于首页「全局最近」。
    </view>

    <view class="warn">
      注意：请先在云开发控制台创建集合 <text class="mono">notes</text>（否则会迁移失败）。
    </view>

    <button class="weui-btn weui-btn_primary btn" bindtap="onStart" disabled="{{running}}">
      {{ running ? '迁移中…' : '开始迁移' }}
    </button>

    <button class="weui-btn weui-btn_default btn" bindtap="onDryRun" disabled="{{running}}">
      仅统计（不写入）
    </button>
  </view>

  <view class="card" wx:if="{{hasResult}}">
    <view class="row"><text class="k">扫描书籍</text><text class="v">{{booksScanned}}</text></view>
    <view class="row"><text class="k">扫描记录</text><text class="v">{{notesScanned}}</text></view>
    <view class="row"><text class="k">写入成功</text><text class="v">{{notesWritten}}</text></view>
    <view class="row"><text class="k">跳过重复</text><text class="v">{{notesSkipped}}</text></view>
    <view class="row"><text class="k">写入失败</text><text class="v">{{notesFailed}}</text></view>
    <view class="row"><text class="k">耗时</text><text class="v">{{elapsedMs}}ms</text></view>
  </view>

  <view class="card" wx:if="{{logLines.length > 0}}">
    <view class="title">日志</view>
    <view class="log">
      <view wx:for="{{logLines}}" wx:key="idx" class="log-line">{{item}}</view>
    </view>
  </view>
</view>

