<view class="page {{isDark ? 'dark-theme' : ''}}">

  <!-- 对话区域 -->
  <scroll-view
    class="chat-msgs"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    scroll-into-view="{{toView}}"
    scroll-with-animation
  >
    <!-- 空状态 -->
    <view wx:if="{{messages.length === 0}}" class="empty-state">
      <view class="empty-icon">
        <!-- 元宝图标 -->
        <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
          <ellipse cx="24" cy="33" rx="16" ry="9" fill="var(--accent-light)"/>
          <path d="M8 24 C8 15, 12 9, 24 9 C36 9, 40 15, 40 24 C40 30, 34 34, 24 34 C14 34, 8 30, 8 24Z" fill="var(--accent)"/>
          <path d="M15 16 C17 13, 20 12, 24 12 C28 12, 31 13, 33 16 C30 14, 27 13, 24 13 C21 13, 18 14, 15 16Z" fill="rgba(255,255,255,0.35)"/>
        </svg>
      </view>
      <view class="empty-title">我是很懂你的阅读助手</view>
      <view class="empty-sub">你可以随便和我聊点什么……</view>
      <view class="empty-hint">
        <text wx:for="{{hints}}" wx:key="index" class="hint-pill" bindtap="onHintTap" data-text="{{item}}">{{item}}</text>
      </view>
    </view>

    <!-- 消息列表 -->
    <view wx:for="{{messages}}" wx:key="index" class="msg msg-{{item.role}}">
      <view class="msg-avatar">
        <image
          wx:if="{{item.role === 'ai'}}"
          class="ai-avatar-img"
          src="/images/avatar/avatar_female_2.png"
          mode="aspectFill"
        />
        <image
          wx:elif="{{userAvatarUrl}}"
          class="user-avatar-img"
          src="{{userAvatarUrl}}"
          mode="aspectFill"
        />
        <text wx:else class="user-avatar-icon">👤</text>
      </view>
      <view class="msg-bubble">{{item.content}}</view>
    </view>

    <!-- AI 思考中 -->
    <view wx:if="{{loading}}" class="msg msg-ai">
      <view class="msg-avatar">
        <image
          class="ai-avatar-img"
          src="/images/avatar/avatar_female_2.png"
          mode="aspectFill"
        />
      </view>
      <view class="msg-bubble typing-bubble">
        <view class="typing-dot"></view>
        <view class="typing-dot"></view>
        <view class="typing-dot"></view>
      </view>
    </view>

    <!-- 底部锚点：用于 scroll-into-view -->
    <view id="chat-bottom" style="height: 1px;"></view>
  </scroll-view>

  <!-- 输入区域 -->
  <view class="chat-input-bar">
    <textarea
      class="chat-input"
      value="{{inputValue}}"
      placeholder="问点什么…"
      placeholder-class="input-placeholder"
      maxlength="1000"
      auto-height
      hold-keyboard
      bindinput="onInput"
      bindconfirm="onConfirm"
    />
    <view
      class="send-btn {{(inputValue && inputValue.trim()) || loading ? 'send-btn--active' : ''}}"
      bindtap="onSend"
    >
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M2 21l21-9L2 3v7l15 2-15 2v7z" fill="white"/>
      </svg>
    </view>
  </view>

</view>
