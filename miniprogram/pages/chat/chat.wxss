@import "/styles/theme.wxss";
@import "/styles/common.wxss";

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

/* ─── 空状态 ─────────────────────────────── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
  gap: 16rpx;
}
.empty-icon {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 8rpx;
  animation: float 3s ease-in-out infinite;
}
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}
.empty-title {
  font-size: 36rpx;
  font-weight: 300;
  color: var(--text-primary);
  letter-spacing: -0.02em;
}
.empty-sub {
  font-size: 26rpx;
  color: var(--text-light);
  text-align: center;
  line-height: 1.6;
  max-width: 500rpx;
}
.empty-hint {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: center;
  margin-top: 20rpx;
  max-width: 600rpx;
}
.hint-pill {
  font-size: 24rpx;
  color: var(--accent);
  background: var(--accent-light);
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
}

/* ─── 消息列表 ─────────────────────────────── */
.chat-msgs {
  flex: 1;
  padding: 12rpx 12rpx;
  overflow-anchor: auto;
  min-height: 0;
}

/* ─── 消息气泡 ─────────────────────────────── */
.msg {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
  animation: msg-in 0.4s cubic-bezier(0.34, 1.2, 0.64, 1);
}
@keyframes msg-in {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.msg-ai { align-items: flex-start; }
.msg-user { align-items: flex-end; flex-direction: row-reverse; }

.msg-avatar {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.msg-ai .msg-avatar {
  background: var(--accent-light);
}
.msg-user .msg-avatar {
  background: var(--bg-surface-muted);
}
.ai-avatar-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ai-avatar-img {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  display: block;
}
.user-avatar-img {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  display: block;
}
.user-avatar-icon {
  font-size: 26rpx;
}

.msg-bubble {
  max-width: 500rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  line-height: 1.7;
  color: var(--text-primary);
  white-space: pre-wrap;
  word-break: break-word;
}
.msg-ai .msg-bubble {
  background: var(--bg-surface);
  border-radius: 4rpx 24rpx 24rpx 24rpx;
  box-shadow: var(--shadow-soft);
}
.msg-user .msg-bubble {
  background: var(--accent);
  color: white;
  border-radius: 24rpx 4rpx 24rpx 24rpx;
}

/* 思考中三点 */
.typing-bubble {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 28rpx;
}
.typing-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 5rpx;
  background: var(--text-light);
  animation: typing 1.2s ease-in-out infinite;
}
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes typing {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
  30% { transform: translateY(-6rpx); opacity: 1; }
}

/* ─── 输入区域 ─────────────────────────────── */
.chat-input-bar {
  flex-shrink: 0;
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  padding: 16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--border-color);
  background: var(--bg-primary);
}

.chat-input {
  flex: 1;
  min-height: 72rpx;
  max-height: 200rpx;
  background: var(--bg-surface);
  border: 1.5rpx solid var(--border-color);
  border-radius: 36rpx;
  padding: 16rpx 28rpx;
  font-size: 30rpx;
  line-height: 1.5;
  color: var(--text-primary);
  box-sizing: border-box;
  outline: none;
  transition: border-color 0.2s;
}
.chat-input:focus {
  border-color: var(--accent);
}
.input-placeholder {
  color: var(--text-light);
  font-size: 30rpx;
}

.send-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  flex-shrink: 0;
  background: var(--bg-surface-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s, transform 0.2s;
  opacity: 0.4;
  position: relative;
  overflow: hidden;
}
.send-btn--active {
  background: var(--accent);
  opacity: 1;
  box-shadow: 0 4rpx 16rpx rgba(24, 22, 21, 0.35);
}
.send-btn--active:active {
  transform: scale(0.88);
  background: var(--accent-hover);
}
.send-btn svg {
  width: 40rpx;
  height: 40rpx;
  display: none;
}

/* 发送按钮：简洁“笔”图标（纯 CSS） */
.send-btn::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 30rpx;
  height: 8rpx;
  transform: translate(-50%, -60%) rotate(-35deg);
  border-radius: 999rpx;
  background: var(--text-light);
  opacity: 0.9;
}
.send-btn::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 0;
  height: 0;
  transform: translate(-50%, -60%) rotate(-35deg);
  margin-left: 16rpx;
  border-left: 9rpx solid var(--text-light);
  border-top: 5rpx solid transparent;
  border-bottom: 5rpx solid transparent;
  opacity: 0.9;
}

/* 激活态：笔变成白色，和按钮底色形成对比 */
.send-btn--active::before {
  background: white;
  opacity: 1;
}
.send-btn--active::after {
  border-left-color: white;
  opacity: 1;
}
